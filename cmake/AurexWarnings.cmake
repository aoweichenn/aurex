                )
            elseif(CMAKE_CXX_COMPILER_ID STREQUAL "GNU")
                set(AUREX_STRICT_WARNING_FLAGS
                    -Waggressive-loop-optimizations
                    -Waligned-new=all
                    -Walloca
                    -Walloc-zero
                    -Warith-conversion
                    -Warray-bounds=2
                    -Wattribute-alias=2
                    -Wbidi-chars=any
                    -Wbool-compare
                    -Wbool-operation
                    -Wcast-function-type
                    -Wcast-align=strict
                    -Wcast-qual
