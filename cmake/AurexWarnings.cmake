                    -Wextra-semi-stmt
                    -Wextra-tokens
                    -Wfixed-enum-extension
                    -Wfloat-equal
                    -Wformat=2
                    -Wformat-nonliteral
                    -Wformat-security
                    -Wheader-hygiene
                    -Widiomatic-parentheses
