            else()
                set(AUREX_STRICT_WARNING_FLAGS)
            endif()

            foreach(flag IN LISTS AUREX_STRICT_WARNING_FLAGS)
                aurex_add_supported_warning(${target} "${flag}")
            endforeach()
        endif()

        if(AUREX_WARNINGS_AS_ERRORS)
            target_compile_options(${target} PRIVATE -Werror)
        endif()
    endforeach()
endfunction()
