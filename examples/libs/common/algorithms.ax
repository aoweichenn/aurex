module common.algorithms;

pub fn countdown(value: i32) -> i32;
pub fn is_even(value: i32) -> bool;
pub fn is_odd(value: i32) -> bool;

pub fn countdown(value: i32) -> i32 {
    if value == 0 {
        return 0;
    }
    return countdown(value - 1);
}

pub fn is_even(value: i32) -> bool {
    if value == 0 {
        return true;
    }
    return is_odd(value - 1);
}

pub fn is_odd(value: i32) -> bool {
    if value == 0 {
        return false;
    }
    return is_even(value - 1);
}
