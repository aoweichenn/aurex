module common.buffers;

import common.status;
import std.core.vec;

pub struct PacketPage {
    pub bytes: [8]u8;
}

pub fn packet_page_size() -> usize {
    return size_of(PacketPage);
}

pub fn packet_page_align() -> usize {
    return align_of(PacketPage);
}

pub fn append_health_prefix(buffer: *mut VecU8, state: Health) -> bool {
    return match state {
        .ok => buffer.push(b'O') && buffer.push(b'K'),
        .degraded | .failed => buffer.push(b'!'),
    };
}
