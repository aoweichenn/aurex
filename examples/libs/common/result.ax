module common.result;

pub enum OutcomeI32: u8 {
    ok(i32) = 1,
    err(i32) = 2,
}

pub fn outcome_code_i32(value: OutcomeI32) -> i32 {
    return match value {
        .ok(code) if code >= 0 => code,
        .ok(code) => -code,
        .err(code) => code,
    };
}

pub fn outcome_is_ok_i32(value: OutcomeI32) -> bool {
    return match value {
        .ok(_) => true,
        .err(_) => false,
    };
}
