module common.result;

pub enum Outcome<T>: u8 {
    ok(T) = 1,
    err(i32) = 2,
}

pub fn outcome_code_i32(value: Outcome<i32>) -> i32 {
    return match value {
        .ok(code) if code >= 0 => code,
        .ok(code) => -code,
        .err(code) => code,
    };
}

pub fn outcome_is_ok_i32(value: Outcome<i32>) -> bool {
    return match value {
        .ok(_) => true,
        .err(_) => false,
    };
}
