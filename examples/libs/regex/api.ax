}

pub fn deserialize_set(bytes: []u8) -> t.RegexSet {
    return database.deserialize_set(bytes);
}

pub fn serialize_regex(compiled: &t.Regex, out: *mut u8, out_capacity: usize) -> t.DatabaseResult {
    return database.serialize_regex(compiled, out, out_capacity);
}

pub fn deserialize_regex(bytes: []u8) -> t.Regex {
    return database.deserialize_regex(bytes);
}

pub fn destroy_captures(captures: &mut t.Captures) -> void {
    results.destroy_captures(captures);
}

pub fn capture_at(captures: &t.Captures, index: usize) -> t.CaptureSpan {
    return results.capture_at(captures, index);
}

pub fn capture_text(input: str, captures: &t.Captures, index: usize) -> str {
    return results.capture_text(input, captures, index);
}

pub fn capture_name(compiled: &t.Regex, index: usize) -> str {
    return results.capture_name(compiled, index);
}

pub fn capture_index(compiled: &t.Regex, name: str) -> usize {
    return results.capture_index(compiled, name);
}

pub fn capture_count(compiled: &t.Regex) -> usize {
    return compiled.capture_len;
}

pub fn error_offset(compiled: &t.Regex) -> usize {
    return compiled.error_offset;
}

pub fn error_kind(compiled: &t.Regex) -> u8 {
    return compiled.error_kind;
}

pub fn diagnostic(compiled: &t.Regex) -> t.RegexDiagnostic {
    return t.RegexDiagnostic {
        status: compiled.status,
        status_code: status_code(compiled.status),
        error_offset: compiled.error_offset,
        error_kind: compiled.error_kind,
        error_kind_code: error_kind_code(compiled.error_kind),
        pattern_index: t.CAPTURE_MISSING,
        pattern_len: strblen(compiled.pattern),
    };
}

pub fn set_diagnostic(compiled: &t.RegexSet) -> t.RegexDiagnostic {
    return t.RegexDiagnostic {
        status: compiled.status,
        status_code: status_code(compiled.status),
        error_offset: t.ERROR_OFFSET_NONE,
        error_kind: t.ERROR_KIND_NONE,
        error_kind_code: error_kind_code(t.ERROR_KIND_NONE),
        pattern_index: compiled.error_index,
        pattern_len: 0usize,
    };
}

