module regex.api;

import regex.compile.parser as parser;
import regex.compile.program as program;
import regex.compile.set as set_compile;
import regex.compile.database as database;
import regex.config.limits as limits;
import regex.core.results as results;
import regex.core.types as t;
import regex.ops.escape as escape_ops;
import regex.ops.iter as iter_ops;
import regex.ops.replace as replace_ops;
import regex.ops.split as split_ops;
import regex.ops.stream as stream_ops;
import regex.vm.engine as engine;

pub type Regex = t.Regex;
pub type RegexOptions = t.RegexOptions;
pub type RegexMatchOptions = t.RegexMatchOptions;
pub type RegexBuilder = t.RegexBuilder;
pub type MatchResult = t.MatchResult;
pub type RegexStatus = t.RegexStatus;
pub type RegexDiagnostic = t.RegexDiagnostic;
pub type CaptureSpan = t.CaptureSpan;
pub type Captures = t.Captures;
pub type FindIter = t.FindIter;
pub type BytesFindIter = t.BytesFindIter;
pub type CaptureIter = t.CaptureIter;
pub type BytesCaptureIter = t.BytesCaptureIter;
pub type SplitIter = t.SplitIter;
pub type BytesSplitIter = t.BytesSplitIter;
pub type SplitPart = t.SplitPart;
pub type ReplaceResult = t.ReplaceResult;
pub type ReplaceCallback = t.ReplaceCallback;
pub type BytesReplaceCallback = t.BytesReplaceCallback;
pub type RegexSet = t.RegexSet;
pub type SetMatchesResult = t.SetMatchesResult;
pub type SetMatchSpan = t.SetMatchSpan;
pub type SetScanCallback = t.SetScanCallback;
pub type RegexChunk = t.RegexChunk;
pub type TextChunk = t.TextChunk;
pub type RegexStream = t.RegexStream;
pub type DatabaseResult = t.DatabaseResult;
pub type BufferResult = t.BufferResult;

type TextMatchCheck = fn(&t.Regex, str) -> t.MatchResult;
type TextCapturesCheck = fn(&t.Regex, str) -> t.Captures;

pub fn default_options() -> t.RegexOptions {
    return t.default_options();
}

pub fn default_match_options() -> t.RegexMatchOptions {
    return t.default_match_options();
}

pub fn match_options_not_bol(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return match_option_flag(value, t.MATCH_NOT_BOL, enabled);
}

pub fn match_options_not_eol(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return match_option_flag(value, t.MATCH_NOT_EOL, enabled);
}

pub fn match_options_not_bow(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return match_option_flag(value, t.MATCH_NOT_BOW, enabled);
}

pub fn match_options_not_eow(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return match_option_flag(value, t.MATCH_NOT_EOW, enabled);
}

pub fn match_options_not_null(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return match_option_flag(value, t.MATCH_NOT_NULL, enabled);
}

pub fn match_options_continuous(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return match_option_flag(value, t.MATCH_CONTINUOUS, enabled);
}

pub fn match_options_anchored(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return match_option_flag(value, t.MATCH_ANCHORED, enabled);
}

pub fn builder(pattern: str) -> t.RegexBuilder {
    return t.builder(pattern, t.MODE_TEXT);
}

pub fn builder_bytes(pattern: str) -> t.RegexBuilder {
    return t.builder(pattern, t.MODE_BYTES);
}

pub fn builder_case_insensitive(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return builder_flag(value, t.FLAG_CASE_INSENSITIVE, enabled);
}

pub fn builder_multiline(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return builder_flag(value, t.FLAG_MULTILINE, enabled);
}

pub fn builder_dotall(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return builder_flag(value, t.FLAG_DOTALL, enabled);
}

pub fn builder_extended(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return builder_flag(value, t.FLAG_EXTENDED, enabled);
}

pub fn builder_ungreedy(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return builder_flag(value, t.FLAG_UNGREEDY, enabled);
}

pub fn builder_ascii(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    var next: t.RegexBuilder = builder_flag(value, t.FLAG_ASCII, enabled);
    if enabled {
        next.options.flags = clear_flag(next.options.flags, t.FLAG_UNICODE);
    }
    return next;
}

pub fn builder_unicode(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    var next: t.RegexBuilder = builder_flag(value, t.FLAG_UNICODE, enabled);
    if enabled {
        next.options.flags = clear_flag(next.options.flags, t.FLAG_ASCII);
    }
    return next;
}

pub fn builder_newline_unicode(value: t.RegexBuilder) -> t.RegexBuilder {
    var next: t.RegexBuilder = value;
    next.options.newline_mode = t.NEWLINE_UNICODE;
    return next;
}

pub fn builder_newline_lf(value: t.RegexBuilder) -> t.RegexBuilder {
    var next: t.RegexBuilder = value;
    next.options.newline_mode = t.NEWLINE_LF;
    return next;
}

pub fn builder_newline_crlf(value: t.RegexBuilder) -> t.RegexBuilder {
    var next: t.RegexBuilder = value;
    next.options.newline_mode = t.NEWLINE_CRLF;
    return next;
}

pub fn builder_stream_history_limit(value: t.RegexBuilder, limit: usize) -> t.RegexBuilder {
    var next: t.RegexBuilder = value;
    next.options.stream_history_limit = limit;
    return next;
}

pub fn builder_workspace_limit(value: t.RegexBuilder, limit: usize) -> t.RegexBuilder {
    var next: t.RegexBuilder = value;
    next.options.max_workspace_states = limit;
    return next;
}

pub fn builder_program_limits(value: t.RegexBuilder, max_states: usize, max_ranges: usize) -> t.RegexBuilder {
    var next: t.RegexBuilder = value;
    next.options.max_state_capacity = max_states;
    next.options.max_range_capacity = max_ranges;
    return next;
}

pub fn builder_compile(value: &t.RegexBuilder) -> t.Regex {
    if value.mode == t.MODE_BYTES {
        return compile_bytes_with_options(value.pattern, value.options);
    }
    return compile_with_options(value.pattern, value.options);
}

pub fn compile(pattern: str) -> t.Regex {
    return parser.compile(pattern);
}

pub fn compile_bytes(pattern: str) -> t.Regex {
    return parser.compile_bytes(pattern);
}

pub fn compile_with_options(pattern: str, options: t.RegexOptions) -> t.Regex {
    return parser.compile_with_options(pattern, options);
}

pub fn compile_bytes_with_options(pattern: str, options: t.RegexOptions) -> t.Regex {
    return parser.compile_bytes_with_options(pattern, options);
}

pub fn compile_set(patterns: []str) -> t.RegexSet {
    return set_compile.compile_set(patterns);
}

pub fn compile_set_bytes(patterns: []str) -> t.RegexSet {
    return set_compile.compile_set_bytes(patterns);
}

pub fn compile_set_with_options(patterns: []str, options: t.RegexOptions) -> t.RegexSet {
    return set_compile.compile_set_with_options(patterns, options);
}

pub fn compile_set_bytes_with_options(patterns: []str, options: t.RegexOptions) -> t.RegexSet {
    return set_compile.compile_set_bytes_with_options(patterns, options);
}

pub fn no_capture() -> usize {
    return t.NO_CAPTURE;
}

pub fn destroy(compiled: &mut t.Regex) -> void {
    program.destroy(compiled);
}

pub fn destroy_set(compiled: &mut t.RegexSet) -> void {
    set_compile.destroy_set(compiled);
}

pub fn is_valid(compiled: &t.Regex) -> bool {
    return compiled.status == t.RegexStatus.ok;
}

pub fn set_is_valid(compiled: &t.RegexSet) -> bool {
    return compiled.status == t.RegexStatus.ok;
}

pub fn state_count(compiled: &t.Regex) -> usize {
    return program.state_count(compiled);
}

pub fn range_count(compiled: &t.Regex) -> usize {
    return program.range_count(compiled);
}

pub fn program_bytes(compiled: &t.Regex) -> usize {
    return program.program_bytes(compiled);
}

pub fn set_state_count(compiled: &t.RegexSet) -> usize {
    return set_compile.state_count(compiled);
}

pub fn set_range_count(compiled: &t.RegexSet) -> usize {
    return set_compile.range_count(compiled);
}

pub fn set_program_bytes(compiled: &t.RegexSet) -> usize {
    return set_compile.program_bytes(compiled);
}

pub fn database_bytes(compiled: &t.RegexSet) -> usize {
    return database.database_bytes(compiled);
}

pub fn regex_database_bytes(compiled: &t.Regex) -> usize {
    return database.regex_database_bytes(compiled);
}

pub fn workspace_bytes(compiled: &t.Regex) -> usize {
    return engine.workspace_bytes(compiled);
}

pub fn set_workspace_bytes(compiled: &t.RegexSet) -> usize {
    return engine.set_workspace_bytes(compiled);
}

pub fn max_pattern_bytes() -> usize {
    return limits.MAX_PATTERN_BYTES;
}

pub fn max_state_capacity() -> usize {
    return limits.MAX_STATE_CAPACITY;
}

pub fn max_range_capacity() -> usize {
    return limits.MAX_RANGE_CAPACITY;
}

pub fn max_workspace_states() -> usize {
