pub fn open_stream(compiled: &t.Regex) -> t.RegexStream {
    return stream_ops.open_stream(compiled);
}

pub fn open_bytes_stream(compiled: &t.Regex) -> t.RegexStream {
    return stream_ops.open_bytes_stream(compiled);
}

pub fn stream_feed(stream: &mut t.RegexStream, chunk: str) -> t.RegexStatus {
    return stream_ops.stream_feed(stream, chunk);
}

pub fn stream_feed_bytes(stream: &mut t.RegexStream, chunk: []u8) -> t.RegexStatus {
    return stream_ops.stream_feed_bytes(stream, chunk);
}

pub fn stream_finish(stream: &mut t.RegexStream) -> t.RegexStatus {
    return stream_ops.stream_finish(stream);
}

pub fn stream_next(stream: &mut t.RegexStream) -> t.MatchResult {
    return stream_ops.stream_next(stream);
}

pub fn destroy_stream(stream: &mut t.RegexStream) -> void {
    stream_ops.destroy_stream(stream);
}

pub fn stream_buffer_bytes(stream: &t.RegexStream) -> usize {
    return stream_ops.stream_buffer_bytes(stream);
}

pub fn search(pattern: str, input: str) -> bool {
    return match_once(pattern, input, search_compiled);
}

pub fn is_match(pattern: str, input: str) -> bool {
    return search(pattern, input);
}

pub fn find(pattern: str, input: str) -> t.MatchResult {
    return match_result_once(pattern, input, search_compiled);
}

pub fn fullmatch(pattern: str, input: str) -> bool {
    return match_once(pattern, input, fullmatch_compiled);
}

pub fn captures(pattern: str, input: str) -> t.Captures {
    return captures_once(pattern, input, captures_compiled);
}

fn match_once(pattern: str, input: str, check: TextMatchCheck) -> bool {
    var compiled: t.Regex = compile(pattern);
    defer destroy(&mut compiled);
    let result: t.MatchResult = check(&compiled, input);
    return result.status == t.RegexStatus.ok && result.matched;
}

fn match_result_once(pattern: str, input: str, check: TextMatchCheck) -> t.MatchResult {
    var compiled: t.Regex = compile(pattern);
    defer destroy(&mut compiled);
    return check(&compiled, input);
}

fn captures_once(pattern: str, input: str, check: TextCapturesCheck) -> t.Captures {
    var compiled: t.Regex = compile(pattern);
    defer destroy(&mut compiled);
    return check(&compiled, input);
}

pub fn replace(pattern: str, input: str, replacement: str, out: *mut u8, out_capacity: usize) -> t.ReplaceResult {
    var compiled: t.Regex = compile(pattern);
    defer destroy(&mut compiled);
    return replace_all(&compiled, input, replacement, out, out_capacity);
}

fn builder_flag(value: t.RegexBuilder, flag: u8, enabled: bool) -> t.RegexBuilder {
    var next: t.RegexBuilder = value;
    if enabled {
        next.options.flags = next.options.flags | flag;
    } else {
        next.options.flags = clear_flag(next.options.flags, flag);
    }
    return next;
}

fn match_option_flag(value: t.RegexMatchOptions, flag: usize, enabled: bool) -> t.RegexMatchOptions {
    var next: t.RegexMatchOptions = value;
    if enabled {
        next.flags = next.flags | flag;
    } else {
        next.flags = next.flags & ~flag;
    }
    return next;
}

fn clear_flag(flags: u8, flag: u8) -> u8 {
    return flags & ~flag;
}

pub fn status_code(status: t.RegexStatus) -> i32 {
    return match status {
        .ok => 0,
        .no_match => 1,
        .syntax_error => 2,
        .unsupported => 3,
        .out_of_memory => 4,
        .repeat_too_large => 5,
        .pattern_too_large => 6,
        .program_too_large => 7,
        .workspace_too_large => 8,
        .capture_too_large => 9,
        .invalid_group_name => 10,
        .buffer_too_small => 11,
        .replacement_error => 12,
        .database_error => 13,
    };
}

pub fn error_kind_code(kind: u8) -> i32 {
    if kind == t.ERROR_KIND_NONE {
        return 0;
    }
    if kind == t.ERROR_KIND_UNEXPECTED_TOKEN {
        return 1;
    }
    if kind == t.ERROR_KIND_UNCLOSED_GROUP {
        return 2;
    }
    if kind == t.ERROR_KIND_UNCLOSED_CLASS {
        return 3;
    }
    if kind == t.ERROR_KIND_INVALID_REPEAT {
        return 4;
    }
    if kind == t.ERROR_KIND_REPEAT_TOO_LARGE {
        return 5;
    }
    if kind == t.ERROR_KIND_INVALID_RANGE {
        return 6;
    }
    if kind == t.ERROR_KIND_UNSUPPORTED_ESCAPE {
        return 7;
    }
    if kind == t.ERROR_KIND_TRAILING_INPUT {
        return 8;
    }
    if kind == t.ERROR_KIND_CAPTURE_TOO_LARGE {
        return 9;
    }
    if kind == t.ERROR_KIND_INVALID_GROUP_NAME {
        return 10;
    }
    if kind == t.ERROR_KIND_UNEXPECTED_EOF {
        return 11;
    }
    if kind == t.ERROR_KIND_PROGRAM_TOO_LARGE {
        return 12;
    }
    if kind == t.ERROR_KIND_INVALID_ESCAPE {
        return 13;
    }
    return -1;
}
