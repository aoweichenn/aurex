pub fn serialize_set(compiled: &t.RegexSet, out: *mut u8, out_capacity: usize) -> t.DatabaseResult {
    return api.serialize_set(compiled, out, out_capacity);
}

pub fn deserialize_set(input: []u8) -> t.RegexSet {
    return api.deserialize_set(input);
}

pub fn regex_database_bytes(compiled: &t.Regex) -> usize {
    return api.regex_database_bytes(compiled);
}

pub fn serialize_regex(compiled: &t.Regex, out: *mut u8, out_capacity: usize) -> t.DatabaseResult {
    return api.serialize_regex(compiled, out, out_capacity);
}

pub fn deserialize_regex(input: []u8) -> t.Regex {
    return api.deserialize_regex(input);
}

pub fn diagnostic(compiled: &t.Regex) -> t.RegexDiagnostic {
    return api.diagnostic(compiled);
}

pub fn set_diagnostic(compiled: &t.RegexSet) -> t.RegexDiagnostic {
    return api.set_diagnostic(compiled);
}

pub fn escape_pattern(input: str, out: *mut u8, out_capacity: usize) -> t.BufferResult {
    return api.escape_pattern(input, out, out_capacity);
}

pub fn quote(input: str, out: *mut u8, out_capacity: usize) -> t.BufferResult {
    return api.quote(input, out, out_capacity);
}

pub fn escape_replacement(input: str, out: *mut u8, out_capacity: usize) -> t.BufferResult {
    return api.escape_replacement(input, out, out_capacity);
}

pub fn open_stream(compiled: &t.Regex) -> t.RegexStream {
    return api.open_bytes_stream(compiled);
}

pub fn stream_feed(stream: &mut t.RegexStream, chunk: []u8) -> t.RegexStatus {
    return api.stream_feed_bytes(stream, chunk);
}

pub fn stream_finish(stream: &mut t.RegexStream) -> t.RegexStatus {
    return api.stream_finish(stream);
}

pub fn stream_next(stream: &mut t.RegexStream) -> t.MatchResult {
    return api.stream_next(stream);
}

pub fn destroy_stream(stream: &mut t.RegexStream) -> void {
    api.destroy_stream(stream);
}

pub fn stream_buffer_bytes(stream: &t.RegexStream) -> usize {
    return api.stream_buffer_bytes(stream);
}

pub fn destroy_captures(captures: &mut t.Captures) -> void {
    api.destroy_captures(captures);
}

pub fn capture_at(captures: &t.Captures, index: usize) -> t.CaptureSpan {
    return api.capture_at(captures, index);
}

pub fn no_capture() -> usize {
    return api.no_capture();
}

pub fn status_code(status: t.RegexStatus) -> i32 {
    return api.status_code(status);
}

pub fn search(pattern: str, input: []u8) -> bool {
    return match_once(pattern, input, search_compiled);
}

pub fn fullmatch(pattern: str, input: []u8) -> bool {
    return match_once(pattern, input, fullmatch_compiled);
}

fn match_once(pattern: str, input: []u8, check: BytesMatchCheck) -> bool {
    var compiled: t.Regex = compile(pattern);
    defer destroy(&mut compiled);
    let result: t.MatchResult = check(&compiled, input);
    return result.status == t.RegexStatus.ok && result.matched;
}
