module regex.bytes;

import regex.api as api;
import regex.core.types as t;

pub type Regex = t.Regex;
pub type RegexOptions = t.RegexOptions;
pub type RegexMatchOptions = t.RegexMatchOptions;
pub type RegexBuilder = t.RegexBuilder;
pub type MatchResult = t.MatchResult;
pub type Captures = t.Captures;
pub type CaptureSpan = t.CaptureSpan;
pub type RegexStatus = t.RegexStatus;
pub type RegexDiagnostic = t.RegexDiagnostic;
pub type RegexSet = t.RegexSet;
pub type SetMatchesResult = t.SetMatchesResult;
pub type SetMatchSpan = t.SetMatchSpan;
pub type SetScanCallback = t.SetScanCallback;
pub type FindIter = t.BytesFindIter;
pub type CaptureIter = t.BytesCaptureIter;
pub type SplitIter = t.BytesSplitIter;
pub type SplitPart = t.SplitPart;
pub type ReplaceResult = t.ReplaceResult;
pub type ReplaceCallback = t.BytesReplaceCallback;
pub type RegexStream = t.RegexStream;
pub type DatabaseResult = t.DatabaseResult;
pub type BufferResult = t.BufferResult;
pub type RegexChunk = t.RegexChunk;

type BytesMatchCheck = fn(&t.Regex, []u8) -> t.MatchResult;

pub fn compile(pattern: str) -> t.Regex {
    return api.compile_bytes(pattern);
}

pub fn compile_with_options(pattern: str, options: t.RegexOptions) -> t.Regex {
    return api.compile_bytes_with_options(pattern, options);
}

pub fn compile_set(patterns: []str) -> t.RegexSet {
    return api.compile_set_bytes(patterns);
}

pub fn compile_set_with_options(patterns: []str, options: t.RegexOptions) -> t.RegexSet {
    return api.compile_set_bytes_with_options(patterns, options);
}

pub fn default_options() -> t.RegexOptions {
    return api.default_options();
}

pub fn default_match_options() -> t.RegexMatchOptions {
    return api.default_match_options();
}

pub fn match_options_not_bol(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return api.match_options_not_bol(value, enabled);
}

pub fn match_options_not_eol(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return api.match_options_not_eol(value, enabled);
}

pub fn match_options_not_bow(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return api.match_options_not_bow(value, enabled);
}

pub fn match_options_not_eow(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return api.match_options_not_eow(value, enabled);
}

pub fn match_options_not_null(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return api.match_options_not_null(value, enabled);
}

pub fn match_options_continuous(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return api.match_options_continuous(value, enabled);
}

pub fn match_options_anchored(value: t.RegexMatchOptions, enabled: bool) -> t.RegexMatchOptions {
    return api.match_options_anchored(value, enabled);
}

pub fn builder(pattern: str) -> t.RegexBuilder {
    return api.builder_bytes(pattern);
}

pub fn builder_case_insensitive(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return api.builder_case_insensitive(value, enabled);
}

pub fn builder_multiline(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return api.builder_multiline(value, enabled);
}

pub fn builder_dotall(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return api.builder_dotall(value, enabled);
}

pub fn builder_ascii(value: t.RegexBuilder, enabled: bool) -> t.RegexBuilder {
    return api.builder_ascii(value, enabled);
}

pub fn builder_stream_history_limit(value: t.RegexBuilder, limit: usize) -> t.RegexBuilder {
    return api.builder_stream_history_limit(value, limit);
}

pub fn builder_compile(value: &t.RegexBuilder) -> t.Regex {
    return api.builder_compile(value);
}

pub fn destroy(compiled: &mut t.Regex) -> void {
    api.destroy(compiled);
}

pub fn destroy_set(compiled: &mut t.RegexSet) -> void {
    api.destroy_set(compiled);
}

pub fn is_valid(compiled: &t.Regex) -> bool {
    return api.is_valid(compiled);
}

pub fn set_is_valid(compiled: &t.RegexSet) -> bool {
    return api.set_is_valid(compiled);
}

pub fn search_compiled(compiled: &t.Regex, input: []u8) -> t.MatchResult {
