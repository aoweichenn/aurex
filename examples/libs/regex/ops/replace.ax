module regex.ops.replace;

import regex.core.results as results;
import regex.core.types as t;
import regex.ops.input as input_ops;
import regex.syntax.ascii as ascii;
import regex.vm.engine as engine;

pub fn replace_all(
    compiled: &t.Regex,
    input: str,
    replacement: str,
    out: *mut u8,
    out_capacity: usize
) -> t.ReplaceResult {
    return replace_n(compiled, input, replacement, t.CAPTURE_MISSING, out, out_capacity);
}

pub fn replace_first(
    compiled: &t.Regex,
    input: str,
    replacement: str,
    out: *mut u8,
    out_capacity: usize
) -> t.ReplaceResult {
    return replace_n(compiled, input, replacement, 1usize, out, out_capacity);
}

pub fn replace_n(
    compiled: &t.Regex,
    input: str,
    replacement: str,
    limit: usize,
    out: *mut u8,
    out_capacity: usize
) -> t.ReplaceResult {
    return replace_n_from(compiled, input, replacement, limit, out, out_capacity, 0usize, 0usize);
}

pub fn replace_all_append(
    compiled: &t.Regex,
    input: str,
    replacement: str,
    out: *mut u8,
    out_capacity: usize,
    initial_len: usize
) -> t.ReplaceResult {
    return replace_n_from(compiled, input, replacement, t.CAPTURE_MISSING, out, out_capacity, initial_len, initial_len);
}

pub fn replace_first_append(
    compiled: &t.Regex,
    input: str,
    replacement: str,
    out: *mut u8,
    out_capacity: usize,
    initial_len: usize
) -> t.ReplaceResult {
    return replace_n_from(compiled, input, replacement, 1usize, out, out_capacity, initial_len, initial_len);
}

pub fn replace_n_append(
    compiled: &t.Regex,
    input: str,
    replacement: str,
    limit: usize,
    out: *mut u8,
    out_capacity: usize,
    initial_len: usize
) -> t.ReplaceResult {
    return replace_n_from(compiled, input, replacement, limit, out, out_capacity, initial_len, initial_len);
}

fn replace_n_from(
    compiled: &t.Regex,
    input: str,
    replacement: str,
    limit: usize,
    out: *mut u8,
    out_capacity: usize,
    initial_written: usize,
    initial_required: usize
) -> t.ReplaceResult {
    return replace_input_n_from(
        compiled,
        input_ops.text(input),
        replacement,
        limit,
        out,
        out_capacity,
        initial_written,
        initial_required
    );
}

fn replace_input_n_from(
    compiled: &t.Regex,
    input: input_ops.RegexInput,
    replacement: str,
    limit: usize,
    out: *mut u8,
    out_capacity: usize,
    initial_written: usize,
    initial_required: usize
) -> t.ReplaceResult {
    if compiled.status != t.RegexStatus.ok {
        return t.replace_result(compiled.status, initial_written, initial_required, 0usize);
    }
    var workspace: engine.Workspace = engine.create_match_workspace(compiled);
    defer engine.destroy_match_workspace(&mut workspace);
    if engine.match_workspace_status(&workspace) != t.RegexStatus.ok {
        return t.replace_result(engine.match_workspace_status(&workspace), initial_written, initial_required, 0usize);
    }
    var captures: t.Captures = t.empty_captures(t.RegexStatus.no_match);
    defer results.destroy_captures(&mut captures);
    var search_start: usize = 0usize;
    var copy_cursor: usize = 0usize;
    var written: usize = bounded_initial_written(initial_written, out_capacity);
    var required: usize = initial_required;
    var replacements: usize = 0usize;
    let input_len: usize = input.len;
    while search_start <= input_len {
        if limit != t.CAPTURE_MISSING && replacements >= limit {
            let limited_tail: CopyState = copy_input_range(input, copy_cursor, input_len, out, out_capacity, written, required);
            return finish_result(limited_tail.written, limited_tail.required, replacements, out_capacity);
        }
        input.captures_compiled_into(compiled, search_start, &mut workspace, &mut captures);
        if captures.status == t.RegexStatus.no_match || !captures.matched {
            let tail: CopyState = copy_input_range(input, copy_cursor, input_len, out, out_capacity, written, required);
            written = tail.written;
            required = tail.required;
            return finish_result(written, required, replacements, out_capacity);
        }
        if captures.status != t.RegexStatus.ok {
            return t.replace_result(captures.status, written, required, replacements);
        }
        let prefix: CopyState = copy_input_range(input, copy_cursor, captures.start, out, out_capacity, written, required);
        written = prefix.written;
        required = prefix.required;
        let replacement_copy: CopyState = expand_replacement(compiled, input, &captures, replacement, out, out_capacity, written, required);
        if replacement_copy.status != t.RegexStatus.ok {
            return t.replace_result(replacement_copy.status, written, required, replacements);
        }
        written = replacement_copy.written;
        required = replacement_copy.required;
        replacements += 1usize;
        copy_cursor = captures.end;
        search_start = input.next_match_start(captures.start, captures.end);
    }
    let trailing: CopyState = copy_input_range(input, copy_cursor, input_len, out, out_capacity, written, required);
    return finish_result(trailing.written, trailing.required, replacements, out_capacity);
}

pub fn replace_all_with(
    compiled: &t.Regex,
    input: str,
    callback: t.ReplaceCallback,
    out: *mut u8,
    out_capacity: usize
) -> t.ReplaceResult {
    return replace_n_with(compiled, input, callback, t.CAPTURE_MISSING, out, out_capacity);
}

pub fn replace_first_with(
    compiled: &t.Regex,
    input: str,
    callback: t.ReplaceCallback,
    out: *mut u8,
    out_capacity: usize
) -> t.ReplaceResult {
    return replace_n_with(compiled, input, callback, 1usize, out, out_capacity);
}

pub fn replace_n_with(
    compiled: &t.Regex,
    input: str,
    callback: t.ReplaceCallback,
    limit: usize,
    out: *mut u8,
    out_capacity: usize
) -> t.ReplaceResult {
    if compiled.status != t.RegexStatus.ok {
        return t.replace_result(compiled.status, 0usize, 0usize, 0usize);
    }
    var workspace: engine.Workspace = engine.create_match_workspace(compiled);
    defer engine.destroy_match_workspace(&mut workspace);
    if engine.match_workspace_status(&workspace) != t.RegexStatus.ok {
        return t.replace_result(engine.match_workspace_status(&workspace), 0usize, 0usize, 0usize);
    }
    var captures: t.Captures = t.empty_captures(t.RegexStatus.no_match);
    defer results.destroy_captures(&mut captures);
    var search_start: usize = 0usize;
    var copy_cursor: usize = 0usize;
    var written: usize = 0usize;
    var required: usize = 0usize;
    var replacements: usize = 0usize;
    let source: input_ops.RegexInput = input_ops.text(input);
    let input_len: usize = source.len;
    while search_start <= input_len {
        if limit != t.CAPTURE_MISSING && replacements >= limit {
            let limited_tail: CopyState = copy_input_range(source, copy_cursor, input_len, out, out_capacity, written, required);
            return finish_result(limited_tail.written, limited_tail.required, replacements, out_capacity);
        }
        source.captures_compiled_into(compiled, search_start, &mut workspace, &mut captures);
        if captures.status == t.RegexStatus.no_match || !captures.matched {
            let tail: CopyState = copy_input_range(source, copy_cursor, input_len, out, out_capacity, written, required);
            written = tail.written;
            required = tail.required;
            return finish_result(written, required, replacements, out_capacity);
        }
        if captures.status != t.RegexStatus.ok {
            return t.replace_result(captures.status, written, required, replacements);
        }
        let prefix: CopyState = copy_input_range(source, copy_cursor, captures.start, out, out_capacity, written, required);
        written = prefix.written;
        required = prefix.required;

        let replacement_out: *mut u8 = output_tail(out, out_capacity, written);
        let replacement_capacity: usize = remaining_capacity(out_capacity, written);
        let callback_result: t.ReplaceResult = callback(input, &captures, replacement_out, replacement_capacity);
        if callback_result.status != t.RegexStatus.ok && callback_result.status != t.RegexStatus.buffer_too_small {
            return t.replace_result(callback_result.status, written, required, replacements);
        }
        written = append_callback_written(written, callback_result.written, out_capacity);
        required += callback_result.required;
        replacements += 1usize;
        copy_cursor = captures.end;
        search_start = source.next_match_start(captures.start, captures.end);
    }
    let trailing: CopyState = copy_input_range(source, copy_cursor, input_len, out, out_capacity, written, required);
    return finish_result(trailing.written, trailing.required, replacements, out_capacity);
}

