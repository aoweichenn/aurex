    compiled: &t.Regex,
    input: []u8,
    replacement: str,
    limit: usize,
    out: *mut u8,
    out_capacity: usize,
    initial_len: usize
) -> t.ReplaceResult {
    return bytes_replace_n_from(compiled, input, replacement, limit, out, out_capacity, initial_len, initial_len);
}

pub fn bytes_replace_all_with(
    compiled: &t.Regex,
    input: []u8,
    callback: t.BytesReplaceCallback,
    out: *mut u8,
    out_capacity: usize
) -> t.ReplaceResult {
    return replace_bytes_with_callback(compiled, input, callback, t.CAPTURE_MISSING, out, out_capacity);
}

pub fn bytes_replace_first_with(
    compiled: &t.Regex,
    input: []u8,
    callback: t.BytesReplaceCallback,
    out: *mut u8,
    out_capacity: usize
