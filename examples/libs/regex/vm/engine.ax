pub fn search_bytes_raw_compiled_from(compiled: &t.Regex, data: *const u8, len: usize, start_offset: usize) -> t.MatchResult {
    if compiled.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_BYTES {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, workspace.status);
    }
    return search_with_workspace(compiled, raw_bytes_input(data, len, compiled.options), start_offset, &mut workspace);
}

pub fn captures_bytes_raw_compiled_from(compiled: &t.Regex, data: *const u8, len: usize, start_offset: usize) -> t.Captures {
    if compiled.status != t.RegexStatus.ok {
        return t.empty_captures(compiled.status);
    }
    if compiled.mode != t.MODE_BYTES {
        return t.empty_captures(t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.empty_captures(workspace.status);
    }
    var captures: t.Captures = t.empty_captures(t.RegexStatus.no_match);
    captures_bytes_raw_compiled_from_into(compiled, data, len, start_offset, &mut workspace, &mut captures);
    return captures;
}

pub fn set_workspace_bytes(compiled: &t.RegexSet) -> usize {
    if set_has_literal_automaton(compiled) {
        return compiled.pattern_count * sizeof<bool>();
    }
    return workspace_bytes_for(compiled.state_len, 2usize) + compiled.pattern_count * sizeof<bool>();
}

pub fn create_match_workspace(compiled: &t.Regex) -> Workspace {
    if compiled.status != t.RegexStatus.ok {
        return empty_workspace(compiled.status);
    }
    return create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
}

pub fn destroy_match_workspace(workspace: &mut Workspace) -> void {
    destroy_workspace(workspace);
}

pub fn match_workspace_status(workspace: &Workspace) -> t.RegexStatus {
    return workspace.status;
}

pub fn captures_compiled_from_into(
    compiled: &t.Regex,
    input: str,
    start_offset: usize,
    workspace: &mut Workspace,
    captures: &mut t.Captures
) -> t.RegexStatus {
    if compiled.status != t.RegexStatus.ok {
        results.reset_captures(captures, compiled.status);
        return compiled.status;
    }
    if compiled.mode != t.MODE_TEXT {
        results.reset_captures(captures, t.RegexStatus.unsupported);
        return t.RegexStatus.unsupported;
    }
    let status: t.RegexStatus = captures_from_input_into(compiled, text_input_with_options(input, compiled.options), start_offset, workspace, captures);
    return status;
}

