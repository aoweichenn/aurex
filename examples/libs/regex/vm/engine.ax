pub fn matches_set_compiled(
    compiled: &t.RegexSet,
    input: str,
    out_pattern_ids: *mut usize,
    out_capacity: usize
) -> t.SetMatchesResult {
    if compiled.status != t.RegexStatus.ok {
        return t.set_matches_result(compiled.status, false, 0usize, 0usize);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.set_matches_result(t.RegexStatus.unsupported, false, 0usize, 0usize);
    }
    return matches_set_input(compiled, set_text_input(compiled, input), out_pattern_ids, out_capacity);
}

pub fn matches_bytes_set_compiled(
    compiled: &t.RegexSet,
    input: []const u8,
    out_pattern_ids: *mut usize,
    out_capacity: usize
) -> t.SetMatchesResult {
