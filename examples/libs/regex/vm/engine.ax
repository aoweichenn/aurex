pub fn scan_set_spans_vectored_compiled(compiled: &t.RegexSet, chunks: []const t.TextChunk, callback: t.SetScanCallback) -> t.SetMatchesResult {
    if compiled.status != t.RegexStatus.ok {
        return t.set_matches_result(compiled.status, false, 0usize, 0usize);
