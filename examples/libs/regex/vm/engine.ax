    var flat: FlatInput = flatten_text_chunks(chunks);
    defer destroy_flat_input(&mut flat);
    if flat.status != t.RegexStatus.ok {
        return t.set_matches_result(flat.status, false, 0usize, 0usize);
    }
    return scan_set_all_spans_input(compiled, raw_text_input(unsafe { ptrcast[*const u8](flat.data) }, flat.len, compiled.options), callback);
}

pub fn scan_set_overlapping_vectored_compiled(compiled: &t.RegexSet, chunks: []const t.TextChunk, callback: t.SetScanCallback) -> t.SetMatchesResult {
    return scan_set_spans_vectored_compiled(compiled, chunks, callback);
}

pub fn find_bytes_set_vectored_compiled(compiled: &t.RegexSet, chunks: []const t.RegexChunk) -> t.SetMatchSpan {
    if compiled.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_BYTES {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var flat: FlatInput = flatten_byte_chunks(chunks);
    defer destroy_flat_input(&mut flat);
    if flat.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, flat.status);
    }
    return find_set_input(compiled, raw_bytes_input(unsafe { ptrcast[*const u8](flat.data) }, flat.len, compiled.options), 0usize);
}

pub fn scan_bytes_set_spans_vectored_compiled(compiled: &t.RegexSet, chunks: []const t.RegexChunk, callback: t.SetScanCallback) -> t.SetMatchesResult {
    if compiled.status != t.RegexStatus.ok {
        return t.set_matches_result(compiled.status, false, 0usize, 0usize);
    }
    if compiled.mode != t.MODE_BYTES {
        return t.set_matches_result(t.RegexStatus.unsupported, false, 0usize, 0usize);
    }
    var flat: FlatInput = flatten_byte_chunks(chunks);
    defer destroy_flat_input(&mut flat);
    if flat.status != t.RegexStatus.ok {
        return t.set_matches_result(flat.status, false, 0usize, 0usize);
    }
    return scan_set_all_spans_input(compiled, raw_bytes_input(unsafe { ptrcast[*const u8](flat.data) }, flat.len, compiled.options), callback);
}

pub fn scan_bytes_set_overlapping_vectored_compiled(compiled: &t.RegexSet, chunks: []const t.RegexChunk, callback: t.SetScanCallback) -> t.SetMatchesResult {
    return scan_bytes_set_spans_vectored_compiled(compiled, chunks, callback);
}

fn search_with_workspace(compiled: &t.Regex, input: InputView, start_offset: usize, workspace: &mut Workspace) -> t.MatchResult {
    let input_len: usize = input.len;
    if start_offset > input_len {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
    }
    if starts_with_input_start_assertion(compiled) {
        if start_offset != 0usize {
            return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
        }
        return run_at(compiled, input, 0usize, false, workspace);
    }
    return run_search(compiled, input, align_forward_boundary(input, start_offset), workspace);
}

fn matches_set_input(
    compiled: &t.RegexSet,
    input: InputView,
    out_pattern_ids: *mut usize,
    out_capacity: usize
) -> t.SetMatchesResult {
    if compiled.pattern_count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    let matched: *mut bool = unsafe {
        ptrcast[*mut bool](alloc.alloc_zeroed_bytes(compiled.pattern_count, sizeof[bool]))
    };
    if matched == null {
        return t.set_matches_result(t.RegexStatus.out_of_memory, false, 0usize, 0usize);
    }
    defer alloc.free_bytes(unsafe { ptrcast[*mut u8](matched) });

    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, 2usize, compiled.options.max_workspace_states);
    defer destroy_workspace(&mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.set_matches_result(workspace.status, false, 0usize, 0usize);
    }

    var matched_count: usize = 0usize;
    let matched_count_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut matched_count)) };
    run_set_search(compiled, input, &mut workspace, matched, matched_count_ptr);
    if workspace.status != t.RegexStatus.ok {
        return t.set_matches_result(workspace.status, false, matched_count, 0usize);
    }
    if matched_count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    let written: usize = write_set_matches(matched, compiled.pattern_count, out_pattern_ids, out_capacity);
    return t.set_matches_result(t.RegexStatus.ok, true, matched_count, written);
}

fn find_set_input(compiled: &t.RegexSet, input: InputView, start_offset: usize) -> t.SetMatchSpan {
    if compiled.pattern_count == 0usize {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.no_match);
    }
    if start_offset > input.len {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.no_match);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, 2usize, compiled.options.max_workspace_states);
    defer destroy_workspace(&mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, workspace.status);
    }
    return run_set_find(compiled, input, align_forward_boundary(input, start_offset), start_offset, &mut workspace);
}

fn scan_set_input(compiled: &t.RegexSet, input: InputView, callback: t.SetScanCallback) -> t.SetMatchesResult {
    var cursor: usize = 0usize;
    var count: usize = 0usize;
    while cursor <= input.len {
        let found: t.SetMatchSpan = find_set_input(compiled, input, cursor);
        if found.status == t.RegexStatus.no_match || !found.matched {
            if count == 0usize {
                return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
            }
            return t.set_matches_result(t.RegexStatus.ok, true, count, count);
        }
        if found.status != t.RegexStatus.ok {
            return t.set_matches_result(found.status, count > 0usize, count, count);
        }
        let status: t.RegexStatus = callback(found.pattern_id, found.start, found.end);
        if status != t.RegexStatus.ok {
            return t.set_matches_result(status, count > 0usize, count, count);
        }
        count += 1usize;
        cursor = next_match_cursor(input, found.start, found.end);
    }
    if count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    return t.set_matches_result(t.RegexStatus.ok, true, count, count);
}

fn scan_set_all_spans_input(compiled: &t.RegexSet, input: InputView, callback: t.SetScanCallback) -> t.SetMatchesResult {
    if compiled.pattern_count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    let emitted: *mut bool = alloc_bool_array(compiled.pattern_count);
    if emitted == null {
        return t.set_matches_result(t.RegexStatus.out_of_memory, false, 0usize, 0usize);
    }
    defer alloc.free_bytes(unsafe { ptrcast[*mut u8](emitted) });

    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, 2usize, compiled.options.max_workspace_states);
    defer destroy_workspace(&mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.set_matches_result(workspace.status, false, 0usize, 0usize);
    }
    workspace.newline_mode = input.newline_mode;
    let start_filter: StartFilter = build_set_start_filter(compiled, &mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.set_matches_result(workspace.status, false, 0usize, 0usize);
    }

    var cursor: usize = 0usize;
    var count: usize = 0usize;
    let count_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut count)) };
    while cursor <= input.len {
        let status: t.RegexStatus = run_set_collect_at(compiled, input, cursor, start_filter, &mut workspace, emitted, callback, count_ptr);
        if status != t.RegexStatus.ok {
            return t.set_matches_result(status, count > 0usize, count, count);
        }
        if cursor >= input.len {
            break;
        }
        cursor = next_boundary(input, cursor);
    }
    if count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    return t.set_matches_result(t.RegexStatus.ok, true, count, count);
}

fn run_set_collect_at(
    compiled: &t.RegexSet,
    input: InputView,
    start: usize,
    start_filter: StartFilter,
    workspace: &mut Workspace,
    emitted: *mut bool,
    callback: t.SetScanCallback,
    count: *mut usize
) -> t.RegexStatus {
    clear_marks(workspace);
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    let current_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut next_len)) };
    if set_start_filter_allows(compiled, start_filter, input, start, workspace) &&
        set_literal_prefix_matches(compiled, start_filter, input, start, workspace) {
        init_capture_seed_with_search_start(workspace.seed_caps, workspace.capture_slot_count, start, start);
        add_set_closure(
            compiled,
            workspace.current,
            workspace.current_caps,
            current_len_ptr,
            workspace,
            stamp,
            compiled.start,
            start,
            input,
            input.len,
            workspace.seed_caps
        );
    }
    if workspace.status != t.RegexStatus.ok {
        return workspace.status;
    }
    var position: usize = start;
    while true {
        clear_emitted_patterns(emitted, compiled.pattern_count);
        let status: t.RegexStatus = emit_set_accepts(compiled, workspace, workspace.current, workspace.current_caps, current_len, position, emitted, callback, count);
        if status != t.RegexStatus.ok {
            return status;
        }
        if position >= input.len || current_len == 0usize {
            break;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        var index: usize = 0usize;
        while index < current_len {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = set_transition_out(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_set_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input.len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return workspace.status;
                }
            }
            index += 1usize;
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
    return t.RegexStatus.ok;
}

fn emit_set_accepts(
    compiled: &t.RegexSet,
    workspace: &Workspace,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: usize,
    position: usize,
    emitted: *mut bool,
    callback: t.SetScanCallback,
    count: *mut usize
) -> t.RegexStatus {
    var index: usize = 0usize;
    while index < list_len {
        let state_id: usize = unsafe { list[index] };
        if state_id < compiled.state_len && unsafe { compiled.states[state_id].opcode } == t.OP_MATCH {
            let pattern_id: usize = unsafe { compiled.states[state_id].value };
            if pattern_id < compiled.pattern_count && !unsafe { emitted[pattern_id] } {
                let row: *mut usize = capture_row_ptr(list_caps, index, workspace.capture_slot_count);
                let start: usize = unsafe { row[0usize] };
                let status: t.RegexStatus = callback(pattern_id, start, position);
                if status != t.RegexStatus.ok {
                    return status;
                }
                unsafe {
                    emitted[pattern_id] = true;
                    *count = *count + 1usize;
                }
            }
        }
        index += 1usize;
    }
    return t.RegexStatus.ok;
}

fn clear_emitted_patterns(emitted: *mut bool, pattern_count: usize) -> void {
    var index: usize = 0usize;
    while index < pattern_count {
        unsafe {
            emitted[index] = false;
        }
        index += 1usize;
    }
}

fn run_set_search(
    compiled: &t.RegexSet,
    input: InputView,
    workspace: &mut Workspace,
    matched: *mut bool,
    matched_count: *mut usize
) -> void {
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    let start_filter: StartFilter = build_set_start_filter(compiled, workspace);
    if workspace.status != t.RegexStatus.ok {
        return;
    }
    clear_marks(workspace);
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    let input_len: usize = input.len;
    let current_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut next_len)) };
    var position: usize = 0usize;
    while true {
        if current_len == 0usize && start_filter.byte_filter_enabled {
            position = advance_to_next_start_byte_candidate(start_filter, input, position, workspace);
        } else if current_len == 0usize && start_filter.literal_prefix_enabled {
            position = advance_to_next_set_prefix_candidate(compiled, start_filter, input, position, workspace);
        }
        if set_start_filter_allows(compiled, start_filter, input, position, workspace) &&
            set_literal_prefix_matches(compiled, start_filter, input, position, workspace) {
            init_capture_seed_with_search_start(workspace.seed_caps, workspace.capture_slot_count, position, 0usize);
            add_set_closure(
                compiled,
                workspace.current,
                workspace.current_caps,
                current_len_ptr,
                workspace,
                stamp,
                compiled.start,
                position,
                input,
                input_len,
                workspace.seed_caps
            );
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
        update_set_accepts(compiled, workspace.current, current_len, matched, matched_count);
        if unsafe { *matched_count } >= compiled.pattern_count {
            return;
        }
        if position >= input_len {
            return;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        var index: usize = 0usize;
        while index < current_len {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = set_transition_out(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_set_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input_len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return;
                }
            }
            index += 1usize;
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
}

fn run_set_find(
    compiled: &t.RegexSet,
    input: InputView,
    start: usize,
    search_start: usize,
    workspace: &mut Workspace
) -> t.SetMatchSpan {
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    let start_filter: StartFilter = build_set_start_filter(compiled, workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, start, start, workspace.status);
    }
    clear_marks(workspace);
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    var best_matched: bool = false;
    var best_pattern_id: usize = t.NO_CAPTURE;
    var best_start: usize = start;
    var best_end: usize = start;
    let input_len: usize = input.len;
    let current_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut next_len)) };
    let best_matched_ptr: *mut bool = unsafe { ptrat[*mut bool](ptraddr(&mut best_matched)) };
    let best_pattern_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut best_pattern_id)) };
    let best_start_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut best_start)) };
    let best_end_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut best_end)) };
    var position: usize = start;
    while true {
        if !best_matched && current_len == 0usize && start_filter.byte_filter_enabled {
            position = advance_to_next_start_byte_candidate(start_filter, input, position, workspace);
        } else if !best_matched && current_len == 0usize && start_filter.literal_prefix_enabled {
            position = advance_to_next_set_prefix_candidate(compiled, start_filter, input, position, workspace);
        }
        if best_matched && !list_has_start_at_or_before(workspace.current_caps, current_len, workspace.capture_slot_count, best_start) {
            return t.set_match_span(true, best_pattern_id, best_start, best_end, t.RegexStatus.ok);
        }
        if !best_matched && set_start_filter_allows(compiled, start_filter, input, position, workspace) &&
            set_literal_prefix_matches(compiled, start_filter, input, position, workspace) {
            init_capture_seed_with_search_start(workspace.seed_caps, workspace.capture_slot_count, position, search_start);
            add_set_closure(
                compiled,
                workspace.current,
                workspace.current_caps,
                current_len_ptr,
                workspace,
                stamp,
                compiled.start,
                position,
                input,
                input_len,
                workspace.seed_caps
            );
        }
        if workspace.status != t.RegexStatus.ok {
            return t.set_match_span(false, t.NO_CAPTURE, position, position, workspace.status);
        }
        update_set_best_accept(
            compiled,
            workspace,
            workspace.current,
            workspace.current_caps,
            current_len,
            position,
            best_matched_ptr,
            best_pattern_ptr,
            best_start_ptr,
            best_end_ptr
        );
        if position >= input_len {
            break;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        var index: usize = 0usize;
        while index < current_len {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = set_transition_out(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_set_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input_len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return t.set_match_span(false, t.NO_CAPTURE, position, position, workspace.status);
                }
            }
            index += 1usize;
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
    if best_matched {
        return t.set_match_span(true, best_pattern_id, best_start, best_end, t.RegexStatus.ok);
    }
    return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.no_match);
}

fn run_search(compiled: &t.Regex, input: InputView, start: usize, workspace: &mut Workspace) -> t.MatchResult {
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    let start_filter: StartFilter = build_start_filter(compiled, workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, start, start, workspace.status);
    }
    clear_marks(workspace);
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    var best_matched: bool = false;
    var best_start: usize = start;
    var best_end: usize = start;
    let input_len: usize = input.len;
    let current_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut next_len)) };
    let best_matched_ptr: *mut bool = unsafe { ptrat[*mut bool](ptraddr(&mut best_matched)) };
    let best_start_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut best_start)) };
    let best_end_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut best_end)) };
    var position: usize = start;
    while true {
        if !best_matched && current_len == 0usize && start_filter.byte_filter_enabled {
            position = advance_to_next_start_byte_candidate(start_filter, input, position, workspace);
        } else if !best_matched && current_len == 0usize && start_filter.literal_prefix_enabled {
            position = advance_to_next_prefix_candidate(compiled, start_filter, input, position, workspace);
        }
        if best_matched && !list_has_start_at_or_before(workspace.current_caps, current_len, workspace.capture_slot_count, best_start) {
            return t.match_result(true, best_start, best_end, t.RegexStatus.ok);
        }
        if !best_matched && start_filter_allows(compiled, start_filter, input, position, workspace) &&
            literal_prefix_matches(compiled, start_filter, input, position, workspace) {
            init_capture_seed_with_search_start(workspace.seed_caps, workspace.capture_slot_count, position, start);
            add_closure(
                compiled,
                workspace.current,
                workspace.current_caps,
                current_len_ptr,
                workspace,
                stamp,
                compiled.start,
                position,
                input,
                input_len,
                workspace.seed_caps
            );
        }
        if workspace.status != t.RegexStatus.ok {
            return t.match_result(false, position, position, workspace.status);
        }
        let accept_state: u8 = update_search_accept(
            compiled,
            workspace,
            workspace.current,
            workspace.current_caps,
            current_len,
            position,
            input,
            input_len,
            best_matched_ptr,
            best_start_ptr,
            best_end_ptr
        );
        if accept_state == ACCEPT_READY {
            return t.match_result(true, best_start, best_end, t.RegexStatus.ok);
        }
        if position >= input_len {
            break;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        var index: usize = 0usize;
        while index < current_len {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = regex_transition_out(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input_len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return t.match_result(false, position, position, workspace.status);
                }
            }
            index += 1usize;
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
    if best_matched {
        return t.match_result(true, best_start, best_end, t.RegexStatus.ok);
    }
    return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
}

fn build_start_filter(compiled: &t.Regex, workspace: &mut Workspace) -> StartFilter {
    clear_marks(workspace);
    var stack_len: usize = 0usize;
    var state_len: usize = 0usize;
    var accepts_empty: bool = false;
    let stack_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut stack_len)) };
    push_filter_state(workspace, stack_len_ptr, compiled.start);
    while stack_len > 0usize {
        stack_len -= 1usize;
        let state_id: usize = unsafe { workspace.stack[stack_len] };
        if state_id == t.NO_STATE || state_id >= compiled.state_len {
            continue;
        }
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_SPLIT {
            push_filter_state(workspace, stack_len_ptr, unsafe { compiled.states[state_id].out2 });
            push_filter_state(workspace, stack_len_ptr, unsafe { compiled.states[state_id].out1 });
        } else if opcode == t.OP_MATCH {
            accepts_empty = true;
        } else if opcode_is_epsilon_like(opcode) {
            push_filter_state(workspace, stack_len_ptr, unsafe { compiled.states[state_id].out1 });
        } else {
            if state_len >= workspace.capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return empty_start_filter();
            }
            unsafe {
                workspace.start_states[state_len] = state_id;
            }
            state_len += 1usize;
        }
        if workspace.status != t.RegexStatus.ok {
            return empty_start_filter();
        }
    }
    let prefix_start: usize = regex_literal_prefix_start(compiled, workspace, state_len);
    let prefix_len: usize = regex_literal_prefix_len(compiled, prefix_start);
    let byte_filter_enabled: bool = build_regex_start_byte_filter(compiled, workspace, state_len, accepts_empty);
    return StartFilter {
        enabled: state_len > 0usize && !accepts_empty,
        state_len: state_len,
        byte_filter_enabled: byte_filter_enabled,
        literal_prefix_enabled: prefix_len > 0usize && !accepts_empty,
        literal_prefix_start: prefix_start,
        literal_prefix_len: prefix_len,
    };
}

fn build_set_start_filter(compiled: &t.RegexSet, workspace: &mut Workspace) -> StartFilter {
    clear_marks(workspace);
    var stack_len: usize = 0usize;
    var state_len: usize = 0usize;
    var accepts_empty: bool = false;
    let stack_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut stack_len)) };
    push_filter_state(workspace, stack_len_ptr, compiled.start);
    while stack_len > 0usize {
        stack_len -= 1usize;
        let state_id: usize = unsafe { workspace.stack[stack_len] };
        if state_id == t.NO_STATE || state_id >= compiled.state_len {
            continue;
        }
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_SPLIT {
            push_filter_state(workspace, stack_len_ptr, unsafe { compiled.states[state_id].out2 });
            push_filter_state(workspace, stack_len_ptr, unsafe { compiled.states[state_id].out1 });
        } else if opcode == t.OP_MATCH {
            accepts_empty = true;
        } else if opcode_is_epsilon_like(opcode) {
            push_filter_state(workspace, stack_len_ptr, unsafe { compiled.states[state_id].out1 });
        } else {
            if state_len >= workspace.capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return empty_start_filter();
            }
            unsafe {
                workspace.start_states[state_len] = state_id;
            }
            state_len += 1usize;
        }
        if workspace.status != t.RegexStatus.ok {
            return empty_start_filter();
        }
    }
    let prefix_start: usize = set_literal_prefix_start(compiled, workspace, state_len);
    let prefix_len: usize = set_literal_prefix_len(compiled, prefix_start);
    let byte_filter_enabled: bool = build_set_start_byte_filter(compiled, workspace, state_len, accepts_empty);
    return StartFilter {
        enabled: state_len > 0usize && !accepts_empty,
        state_len: state_len,
        byte_filter_enabled: byte_filter_enabled,
        literal_prefix_enabled: prefix_len > 0usize && !accepts_empty,
        literal_prefix_start: prefix_start,
        literal_prefix_len: prefix_len,
    };
}

fn empty_start_filter() -> StartFilter {
    return StartFilter {
        enabled: false,
        state_len: 0usize,
        byte_filter_enabled: false,
        literal_prefix_enabled: false,
        literal_prefix_start: t.NO_STATE,
        literal_prefix_len: 0usize,
    };
}

fn push_filter_state(workspace: &mut Workspace, stack_len: *mut usize, state_id: usize) -> void {
    if state_id == t.NO_STATE || state_id >= workspace.capacity {
        return;
    }
    if unsafe { workspace.marks[state_id] } == 1usize {
        return;
    }
    if unsafe { *stack_len } >= workspace.capacity {
        workspace.status = t.RegexStatus.workspace_too_large;
        return;
    }
    unsafe {
        workspace.marks[state_id] = 1usize;
        workspace.stack[*stack_len] = state_id;
        *stack_len = *stack_len + 1usize;
    }
}

fn start_filter_allows(
    compiled: &t.Regex,
    filter: StartFilter,
    input: InputView,
    position: usize,
    workspace: &mut Workspace
) -> bool {
    if !filter.enabled {
        return true;
    }
    if position >= input.len {
        return false;
    }
    let value: usize = decode_at(input, position).value;
    var index: usize = 0usize;
    while index < filter.state_len {
        let state_id: usize = unsafe { workspace.start_states[index] };
        if state_matches(compiled, state_id, value, workspace) ||
            regex_full_fold_sequence_out(compiled, state_id, value) != t.NO_STATE {
            return true;
        }
        index += 1usize;
    }
    return false;
}

fn set_start_filter_allows(
    compiled: &t.RegexSet,
    filter: StartFilter,
    input: InputView,
    position: usize,
    workspace: &mut Workspace
) -> bool {
    if !filter.enabled {
        return true;
    }
    if position >= input.len {
        return false;
    }
    let value: usize = decode_at(input, position).value;
    var index: usize = 0usize;
    while index < filter.state_len {
        let state_id: usize = unsafe { workspace.start_states[index] };
        if set_state_matches(compiled, state_id, value, workspace) ||
            set_full_fold_sequence_out(compiled, state_id, value) != t.NO_STATE {
            return true;
        }
        index += 1usize;
    }
    return false;
}

fn build_regex_start_byte_filter(compiled: &t.Regex, workspace: &mut Workspace, state_len: usize, accepts_empty: bool) -> bool {
    clear_start_bytes(workspace);
    if accepts_empty || state_len == 0usize {
        return false;
    }
    var index: usize = 0usize;
    while index < state_len {
        let state_id: usize = unsafe { workspace.start_states[index] };
        mark_regex_state_start_bytes(compiled, state_id, workspace);
        if workspace.status != t.RegexStatus.ok {
            return false;
        }
        index += 1usize;
    }
    return start_byte_filter_useful(compiled.mode, workspace);
}

fn build_set_start_byte_filter(compiled: &t.RegexSet, workspace: &mut Workspace, state_len: usize, accepts_empty: bool) -> bool {
    clear_start_bytes(workspace);
    if accepts_empty || state_len == 0usize {
        return false;
    }
    var index: usize = 0usize;
    while index < state_len {
        let state_id: usize = unsafe { workspace.start_states[index] };
        mark_set_state_start_bytes(compiled, state_id, workspace);
        if workspace.status != t.RegexStatus.ok {
            return false;
        }
        index += 1usize;
    }
    return start_byte_filter_useful(compiled.mode, workspace);
}

fn mark_regex_state_start_bytes(compiled: &t.Regex, state_id: usize, workspace: &mut Workspace) -> void {
    if state_id == t.NO_STATE || state_id >= compiled.state_len {
        mark_valid_input_start_bytes(compiled.mode, workspace);
        return;
    }
    let opcode: u8 = unsafe { compiled.states[state_id].opcode };
    let flags: u8 = unsafe { compiled.states[state_id].flags };
    if compiled.mode == t.MODE_BYTES {
        if opcode == t.OP_LITERAL && !has_flag(flags, t.FLAG_CASE_INSENSITIVE) {
            mark_start_byte(workspace, unsafe { compiled.states[state_id].value });
        } else if opcode == t.OP_ANY {
            mark_bytes_any_start_bytes(flags, workspace);
        } else {
            mark_regex_bytes_by_scan(compiled, state_id, workspace);
        }
        return;
    }
    if opcode == t.OP_LITERAL {
        mark_text_literal_start_bytes(compiled, state_id, flags, workspace);
    } else if opcode == t.OP_ANY {
        mark_text_any_start_bytes(flags, workspace);
    } else if opcode == t.OP_CLASS {
        mark_regex_ascii_by_scan(compiled, state_id, workspace);
        if regex_class_may_match_non_ascii(compiled, state_id, workspace) {
            mark_text_non_ascii_start_bytes(workspace);
        }
    } else {
        mark_text_non_ascii_start_bytes(workspace);
    }
}

fn mark_set_state_start_bytes(compiled: &t.RegexSet, state_id: usize, workspace: &mut Workspace) -> void {
    if state_id == t.NO_STATE || state_id >= compiled.state_len {
        mark_valid_input_start_bytes(compiled.mode, workspace);
        return;
    }
    let opcode: u8 = unsafe { compiled.states[state_id].opcode };
    let flags: u8 = unsafe { compiled.states[state_id].flags };
    if compiled.mode == t.MODE_BYTES {
        if opcode == t.OP_LITERAL && !has_flag(flags, t.FLAG_CASE_INSENSITIVE) {
            mark_start_byte(workspace, unsafe { compiled.states[state_id].value });
        } else if opcode == t.OP_ANY {
            mark_bytes_any_start_bytes(flags, workspace);
        } else {
            mark_set_bytes_by_scan(compiled, state_id, workspace);
        }
        return;
    }
    if opcode == t.OP_LITERAL {
        mark_set_text_literal_start_bytes(compiled, state_id, flags, workspace);
    } else if opcode == t.OP_ANY {
        mark_text_any_start_bytes(flags, workspace);
    } else if opcode == t.OP_CLASS {
        mark_set_ascii_by_scan(compiled, state_id, workspace);
        if set_class_may_match_non_ascii(compiled, state_id, workspace) {
            mark_text_non_ascii_start_bytes(workspace);
        }
    } else {
        mark_text_non_ascii_start_bytes(workspace);
    }
}

fn mark_regex_bytes_by_scan(compiled: &t.Regex, state_id: usize, workspace: &mut Workspace) -> void {
    var value: usize = 0usize;
    while value < limits.START_BYTE_COUNT {
        if state_matches(compiled, state_id, value, workspace) {
            mark_start_byte(workspace, value);
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
        value += 1usize;
    }
}

fn mark_set_bytes_by_scan(compiled: &t.RegexSet, state_id: usize, workspace: &mut Workspace) -> void {
    var value: usize = 0usize;
    while value < limits.START_BYTE_COUNT {
        if set_state_matches(compiled, state_id, value, workspace) {
            mark_start_byte(workspace, value);
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
        value += 1usize;
    }
}

fn mark_regex_ascii_by_scan(compiled: &t.Regex, state_id: usize, workspace: &mut Workspace) -> void {
    var value: usize = 0usize;
    while value < ASCII_BYTE_COUNT {
        if state_matches(compiled, state_id, value, workspace) {
            mark_start_byte(workspace, value);
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
        value += 1usize;
    }
}

fn mark_set_ascii_by_scan(compiled: &t.RegexSet, state_id: usize, workspace: &mut Workspace) -> void {
    var value: usize = 0usize;
    while value < ASCII_BYTE_COUNT {
        if set_state_matches(compiled, state_id, value, workspace) {
            mark_start_byte(workspace, value);
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
        value += 1usize;
    }
}

fn mark_text_literal_start_bytes(compiled: &t.Regex, state_id: usize, flags: u8, workspace: &mut Workspace) -> void {
    if has_flag(flags, t.FLAG_CASE_INSENSITIVE) {
        mark_regex_ascii_by_scan(compiled, state_id, workspace);
        mark_text_non_ascii_start_bytes(workspace);
        return;
    }
    let value: usize = unsafe { compiled.states[state_id].value };
    mark_utf8_first_byte(workspace, value);
}

fn mark_set_text_literal_start_bytes(compiled: &t.RegexSet, state_id: usize, flags: u8, workspace: &mut Workspace) -> void {
    if has_flag(flags, t.FLAG_CASE_INSENSITIVE) {
        mark_set_ascii_by_scan(compiled, state_id, workspace);
        mark_text_non_ascii_start_bytes(workspace);
        return;
    }
    let value: usize = unsafe { compiled.states[state_id].value };
    mark_utf8_first_byte(workspace, value);
}

fn mark_text_any_start_bytes(flags: u8, workspace: &mut Workspace) -> void {
    var value: usize = 0usize;
    while value < ASCII_BYTE_COUNT {
        if has_flag(flags, t.FLAG_DOTALL) || !unicode.is_line_break_scalar(value) {
            mark_start_byte(workspace, value);
        }
        value += 1usize;
    }
    mark_text_non_ascii_start_bytes(workspace);
}

fn mark_bytes_any_start_bytes(flags: u8, workspace: &mut Workspace) -> void {
    var value: usize = 0usize;
    while value < limits.START_BYTE_COUNT {
        if has_flag(flags, t.FLAG_DOTALL) || !unicode.is_line_break_scalar(value) {
            mark_start_byte(workspace, value);
        }
        value += 1usize;
    }
}

fn regex_class_may_match_non_ascii(compiled: &t.Regex, state_id: usize, workspace: &mut Workspace) -> bool {
    let flags: u8 = unsafe { compiled.states[state_id].flags };
    if has_flag(flags, t.FLAG_CLASS_NEGATED) {
        return true;
    }
    return regex_class_expr_may_match_non_ascii(
        compiled,
        unsafe { compiled.states[state_id].class_start },
        unsafe { compiled.states[state_id].class_len },
        workspace,
        has_flag(flags, t.FLAG_CASE_INSENSITIVE),
        has_flag(flags, t.FLAG_ASCII)
    );
}

fn set_class_may_match_non_ascii(compiled: &t.RegexSet, state_id: usize, workspace: &mut Workspace) -> bool {
    let flags: u8 = unsafe { compiled.states[state_id].flags };
    if has_flag(flags, t.FLAG_CLASS_NEGATED) {
        return true;
    }
    return set_class_expr_may_match_non_ascii(
        compiled,
        unsafe { compiled.states[state_id].class_start },
        unsafe { compiled.states[state_id].class_len },
        workspace,
        has_flag(flags, t.FLAG_CASE_INSENSITIVE),
        has_flag(flags, t.FLAG_ASCII)
    );
}

fn regex_class_expr_may_match_non_ascii(
    compiled: &t.Regex,
    class_start: usize,
    class_len: usize,
    workspace: &mut Workspace,
    folded: bool,
    ascii_mode: bool
) -> bool {
    var depth: usize = 0usize;
    var offset: usize = 0usize;
    while offset < class_len {
        let range_index: usize = class_start + offset;
        let kind: u8 = unsafe { compiled.ranges[range_index].kind };
        if kind == t.CLASS_RANGE_SCALAR || kind == t.CLASS_RANGE_PROPERTY || kind == t.CLASS_RANGE_PROPERTY_NEGATED {
            if depth >= workspace.class_capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return true;
            }
            unsafe {
                workspace.class_stack[depth] = class_primitive_may_match_non_ascii(
                    kind,
                    compiled.ranges[range_index].first,
                    compiled.ranges[range_index].last,
                    folded,
                    ascii_mode
                );
            }
            depth += 1usize;
        } else if kind == t.CLASS_EXPR_COMPLEMENT {
            if depth == 0usize {
                return true;
            }
            unsafe {
                workspace.class_stack[depth - 1usize] = true;
            }
        } else {
            if depth < 2usize {
                return true;
            }
            let right: bool = unsafe { workspace.class_stack[depth - 1usize] };
            let left: bool = unsafe { workspace.class_stack[depth - 2usize] };
            depth -= 1usize;
            unsafe {
                workspace.class_stack[depth - 1usize] = class_expr_op_may_match_non_ascii(kind, left, right);
            }
        }
        offset += 1usize;
    }
    if depth != 1usize {
        return true;
    }
    return unsafe { workspace.class_stack[0usize] };
}

fn set_class_expr_may_match_non_ascii(
    compiled: &t.RegexSet,
    class_start: usize,
    class_len: usize,
    workspace: &mut Workspace,
    folded: bool,
    ascii_mode: bool
) -> bool {
    var depth: usize = 0usize;
    var offset: usize = 0usize;
    while offset < class_len {
        let range_index: usize = class_start + offset;
        let kind: u8 = unsafe { compiled.ranges[range_index].kind };
        if kind == t.CLASS_RANGE_SCALAR || kind == t.CLASS_RANGE_PROPERTY || kind == t.CLASS_RANGE_PROPERTY_NEGATED {
            if depth >= workspace.class_capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return true;
            }
            unsafe {
                workspace.class_stack[depth] = class_primitive_may_match_non_ascii(
                    kind,
                    compiled.ranges[range_index].first,
                    compiled.ranges[range_index].last,
                    folded,
                    ascii_mode
                );
            }
            depth += 1usize;
        } else if kind == t.CLASS_EXPR_COMPLEMENT {
            if depth == 0usize {
                return true;
            }
            unsafe {
                workspace.class_stack[depth - 1usize] = true;
            }
        } else {
            if depth < 2usize {
                return true;
            }
            let right: bool = unsafe { workspace.class_stack[depth - 1usize] };
            let left: bool = unsafe { workspace.class_stack[depth - 2usize] };
            depth -= 1usize;
            unsafe {
                workspace.class_stack[depth - 1usize] = class_expr_op_may_match_non_ascii(kind, left, right);
            }
        }
        offset += 1usize;
    }
    if depth != 1usize {
        return true;
    }
    return unsafe { workspace.class_stack[0usize] };
}

fn class_primitive_may_match_non_ascii(kind: u8, first: usize, last: usize, folded: bool, ascii_mode: bool) -> bool {
    if ascii_mode && is_ascii_shorthand_property(first) {
        return false;
    }
    if kind == t.CLASS_RANGE_SCALAR {
        return last > ASCII_BYTE_MAX || folded;
    }
    if kind == t.CLASS_RANGE_PROPERTY_NEGATED {
        return true;
    }
    if folded {
        return true;
    }
    return first != unicode.PROPERTY_ASCII && first != unicode.PROPERTY_ASCII_HEX_DIGIT;
}

fn class_expr_op_may_match_non_ascii(kind: u8, left: bool, right: bool) -> bool {
    if kind == t.CLASS_EXPR_UNION {
        return left || right;
    }
    if kind == t.CLASS_EXPR_INTERSECTION {
        return left && right;
    }
    if kind == t.CLASS_EXPR_DIFFERENCE {
        return left;
    }
    if kind == t.CLASS_EXPR_SYMMETRIC_DIFFERENCE {
        return left || right;
    }
    return true;
}

fn mark_valid_input_start_bytes(mode: u8, workspace: &mut Workspace) -> void {
    if mode == t.MODE_TEXT {
        mark_text_ascii_start_bytes(workspace);
        mark_text_non_ascii_start_bytes(workspace);
        return;
    }
    var value: usize = 0usize;
    while value < limits.START_BYTE_COUNT {
        mark_start_byte(workspace, value);
        value += 1usize;
    }
}

fn mark_text_ascii_start_bytes(workspace: &mut Workspace) -> void {
    var value: usize = 0usize;
    while value < ASCII_BYTE_COUNT {
        mark_start_byte(workspace, value);
        value += 1usize;
    }
}

fn mark_text_non_ascii_start_bytes(workspace: &mut Workspace) -> void {
    var value: usize = UTF8_NON_ASCII_FIRST_MIN;
    while value <= UTF8_NON_ASCII_FIRST_MAX {
        mark_start_byte(workspace, value);
        value += 1usize;
    }
}

fn mark_utf8_first_byte(workspace: &mut Workspace, value: usize) -> void {
    if value <= ASCII_BYTE_MAX {
        mark_start_byte(workspace, value);
        return;
    }
    if value >= UTF8_SURROGATE_FIRST && value <= UTF8_SURROGATE_LAST {
        mark_text_non_ascii_start_bytes(workspace);
        return;
    }
    if value > UTF8_SCALAR_MAX {
        mark_text_non_ascii_start_bytes(workspace);
        return;
    }
    if value <= UTF8_TWO_BYTE_SCALAR_MAX {
        mark_start_byte(workspace, UTF8_TWO_BYTE_PREFIX + value / UTF8_TWO_BYTE_SHIFT);
    } else if value <= UTF8_THREE_BYTE_SCALAR_MAX {
        mark_start_byte(workspace, UTF8_THREE_BYTE_PREFIX + value / UTF8_THREE_BYTE_SHIFT);
    } else {
        mark_start_byte(workspace, UTF8_FOUR_BYTE_PREFIX + value / UTF8_FOUR_BYTE_SHIFT);
    }
}

fn mark_start_byte(workspace: &mut Workspace, value: usize) -> void {
    if value < limits.START_BYTE_COUNT {
        unsafe {
            workspace.start_bytes[value] = true;
        }
    }
}

fn start_byte_filter_useful(mode: u8, workspace: &Workspace) -> bool {
    if mode == t.MODE_TEXT {
        return text_start_byte_filter_useful(workspace);
    }
    return byte_start_filter_useful_range(workspace, 0usize, limits.START_BYTE_COUNT);
}

fn text_start_byte_filter_useful(workspace: &Workspace) -> bool {
    let ascii_useful: bool = byte_start_filter_useful_range(workspace, 0usize, ASCII_BYTE_COUNT);
    if ascii_useful {
        return true;
    }
    let non_ascii: bool = byte_start_filter_useful_range(workspace, UTF8_NON_ASCII_FIRST_MIN, UTF8_NON_ASCII_FIRST_MAX + 1usize);
    if non_ascii {
        return true;
    }
    let ascii_allowed: bool = start_byte_range_has_allowed(workspace, 0usize, ASCII_BYTE_COUNT);
    let non_ascii_allowed: bool = start_byte_range_has_allowed(workspace, UTF8_NON_ASCII_FIRST_MIN, UTF8_NON_ASCII_FIRST_MAX + 1usize);
    let ascii_rejected: bool = start_byte_range_has_rejected(workspace, 0usize, ASCII_BYTE_COUNT);
    let non_ascii_rejected: bool = start_byte_range_has_rejected(workspace, UTF8_NON_ASCII_FIRST_MIN, UTF8_NON_ASCII_FIRST_MAX + 1usize);
    return (ascii_allowed || non_ascii_allowed) && (ascii_rejected || non_ascii_rejected);
}

fn byte_start_filter_useful_range(workspace: &Workspace, first: usize, end: usize) -> bool {
    return start_byte_range_has_allowed(workspace, first, end) && start_byte_range_has_rejected(workspace, first, end);
}

fn start_byte_range_has_allowed(workspace: &Workspace, first: usize, end: usize) -> bool {
    var value: usize = first;
    while value < end {
        if unsafe { workspace.start_bytes[value] } {
            return true;
        }
        value += 1usize;
    }
    return false;
}

fn start_byte_range_has_rejected(workspace: &Workspace, first: usize, end: usize) -> bool {
    var value: usize = first;
    while value < end {
        if !unsafe { workspace.start_bytes[value] } {
            return true;
        }
        value += 1usize;
    }
    return false;
}

fn regex_literal_prefix_start(compiled: &t.Regex, workspace: &mut Workspace, state_len: usize) -> usize {
    if state_len != 1usize {
        return t.NO_STATE;
    }
    let state_id: usize = unsafe { workspace.start_states[0usize] };
    if state_id >= compiled.state_len || unsafe { compiled.states[state_id].opcode } != t.OP_LITERAL {
        return t.NO_STATE;
    }
    let flags: u8 = unsafe { compiled.states[state_id].flags };
    if compiled.mode == t.MODE_TEXT && has_flag(flags, t.FLAG_CASE_INSENSITIVE) && !has_flag(flags, t.FLAG_ASCII) {
        return t.NO_STATE;
    }
    return state_id;
}

fn set_literal_prefix_start(compiled: &t.RegexSet, workspace: &mut Workspace, state_len: usize) -> usize {
    if state_len != 1usize {
        return t.NO_STATE;
    }
    let state_id: usize = unsafe { workspace.start_states[0usize] };
    if state_id >= compiled.state_len || unsafe { compiled.states[state_id].opcode } != t.OP_LITERAL {
        return t.NO_STATE;
    }
    let flags: u8 = unsafe { compiled.states[state_id].flags };
    if compiled.mode == t.MODE_TEXT && has_flag(flags, t.FLAG_CASE_INSENSITIVE) && !has_flag(flags, t.FLAG_ASCII) {
        return t.NO_STATE;
    }
    return state_id;
}

fn regex_literal_prefix_len(compiled: &t.Regex, first_state: usize) -> usize {
    if first_state == t.NO_STATE {
        return 0usize;
    }
    var len: usize = 0usize;
    var state_id: usize = first_state;
    var steps: usize = 0usize;
    while state_id != t.NO_STATE && state_id < compiled.state_len && steps <= compiled.state_len {
        if unsafe { compiled.states[state_id].opcode } != t.OP_LITERAL {
            return len;
        }
        len += 1usize;
        state_id = next_regex_prefix_literal(compiled, unsafe { compiled.states[state_id].out1 });
        steps += 1usize;
    }
    return len;
}

fn set_literal_prefix_len(compiled: &t.RegexSet, first_state: usize) -> usize {
    if first_state == t.NO_STATE {
        return 0usize;
    }
    var len: usize = 0usize;
    var state_id: usize = first_state;
    var steps: usize = 0usize;
    while state_id != t.NO_STATE && state_id < compiled.state_len && steps <= compiled.state_len {
        if unsafe { compiled.states[state_id].opcode } != t.OP_LITERAL {
            return len;
        }
        len += 1usize;
        state_id = next_set_prefix_literal(compiled, unsafe { compiled.states[state_id].out1 });
        steps += 1usize;
    }
    return len;
}

fn next_regex_prefix_literal(compiled: &t.Regex, first_state: usize) -> usize {
    var state_id: usize = first_state;
    var steps: usize = 0usize;
    while state_id != t.NO_STATE && state_id < compiled.state_len && steps <= compiled.state_len {
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_LITERAL {
            return state_id;
        }
        if opcode != t.OP_EPSILON && opcode != t.OP_SAVE {
            return t.NO_STATE;
        }
        state_id = unsafe { compiled.states[state_id].out1 };
        steps += 1usize;
    }
    return t.NO_STATE;
}

fn next_set_prefix_literal(compiled: &t.RegexSet, first_state: usize) -> usize {
    var state_id: usize = first_state;
    var steps: usize = 0usize;
    while state_id != t.NO_STATE && state_id < compiled.state_len && steps <= compiled.state_len {
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_LITERAL {
            return state_id;
        }
        if opcode != t.OP_EPSILON && opcode != t.OP_SAVE {
            return t.NO_STATE;
        }
        state_id = unsafe { compiled.states[state_id].out1 };
        steps += 1usize;
    }
    return t.NO_STATE;
}

fn advance_to_next_prefix_candidate(
    compiled: &t.Regex,
    filter: StartFilter,
    input: InputView,
    position: usize,
    workspace: &mut Workspace
) -> usize {
    if !filter.literal_prefix_enabled {
        return position;
    }
    var at: usize = position;
    while at < input.len {
        let decoded: InputDecode = decode_at(input, at);
        if !decoded.valid {
            return input.len;
        }
        if state_matches(compiled, filter.literal_prefix_start, decoded.value, workspace) {
            return at;
        }
        at = decoded.next;
    }
    return input.len;
}

fn advance_to_next_start_byte_candidate(
    filter: StartFilter,
    input: InputView,
    position: usize,
    workspace: &Workspace
) -> usize {
    if !filter.byte_filter_enabled {
        return position;
    }
    var at: usize = position;
    while at < input.len {
        let byte: usize = cast[usize](unsafe { input.data[at] });
        if unsafe { workspace.start_bytes[byte] } {
            if input.mode == t.MODE_TEXT {
                return align_forward_boundary(input, at);
            }
            return at;
        }
        at += 1usize;
    }
    return input.len;
}

fn advance_to_next_set_prefix_candidate(
    compiled: &t.RegexSet,
    filter: StartFilter,
    input: InputView,
    position: usize,
    workspace: &mut Workspace
) -> usize {
    if !filter.literal_prefix_enabled {
        return position;
    }
    var at: usize = position;
    while at < input.len {
        let decoded: InputDecode = decode_at(input, at);
        if !decoded.valid {
            return input.len;
        }
        if set_state_matches(compiled, filter.literal_prefix_start, decoded.value, workspace) {
            return at;
        }
        at = decoded.next;
    }
    return input.len;
}

fn literal_prefix_matches(
    compiled: &t.Regex,
    filter: StartFilter,
    input: InputView,
    position: usize,
    workspace: &mut Workspace
) -> bool {
    if !filter.literal_prefix_enabled {
        return true;
    }
    var state_id: usize = filter.literal_prefix_start;
    var at: usize = position;
    var matched: usize = 0usize;
    while matched < filter.literal_prefix_len {
        if at >= input.len || state_id == t.NO_STATE || state_id >= compiled.state_len {
            return false;
        }
        let decoded: InputDecode = decode_at(input, at);
        if !decoded.valid || !state_matches(compiled, state_id, decoded.value, workspace) {
            return false;
        }
        at = decoded.next;
        state_id = next_regex_prefix_literal(compiled, unsafe { compiled.states[state_id].out1 });
        matched += 1usize;
    }
    return true;
}

fn set_literal_prefix_matches(
    compiled: &t.RegexSet,
    filter: StartFilter,
    input: InputView,
    position: usize,
    workspace: &mut Workspace
) -> bool {
    if !filter.literal_prefix_enabled {
        return true;
    }
    var state_id: usize = filter.literal_prefix_start;
    var at: usize = position;
    var matched: usize = 0usize;
    while matched < filter.literal_prefix_len {
        if at >= input.len || state_id == t.NO_STATE || state_id >= compiled.state_len {
            return false;
        }
        let decoded: InputDecode = decode_at(input, at);
        if !decoded.valid || !set_state_matches(compiled, state_id, decoded.value, workspace) {
            return false;
        }
        at = decoded.next;
        state_id = next_set_prefix_literal(compiled, unsafe { compiled.states[state_id].out1 });
        matched += 1usize;
    }
    return true;
}

fn opcode_is_epsilon_like(opcode: u8) -> bool {
    return opcode == t.OP_EPSILON ||
        opcode == t.OP_SAVE ||
        opcode == t.OP_ASSERT_START ||
        opcode == t.OP_ASSERT_END ||
        opcode == t.OP_ASSERT_ABSOLUTE_START ||
        opcode == t.OP_ASSERT_ABSOLUTE_END ||
        opcode == t.OP_ASSERT_WORD_BOUNDARY ||
        opcode == t.OP_ASSERT_NOT_WORD_BOUNDARY ||
        opcode == t.OP_ASSERT_WORD_START ||
        opcode == t.OP_ASSERT_WORD_END ||
        opcode == t.OP_ASSERT_SEARCH_START;
}

fn add_set_closure(
    compiled: &t.RegexSet,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: *mut usize,
    workspace: &mut Workspace,
    stamp: usize,
    first_state: usize,
    position: usize,
    input: InputView,
    input_len: usize,
    source_caps: *mut usize
) -> void {
    var stack_len: usize = 0usize;
    let stack_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut stack_len)) };
    push_set_state(workspace, stack_len_ptr, stamp, first_state, source_caps);
    while stack_len > 0usize {
        stack_len -= 1usize;
        let state_id: usize = unsafe { workspace.stack[stack_len] };
        if state_id == t.NO_STATE || state_id >= compiled.state_len {
            continue;
        }
        let row: *mut usize = capture_row_ptr(workspace.stack_caps, stack_len, workspace.capture_slot_count);
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_EPSILON || opcode == t.OP_SAVE {
            push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_SPLIT {
            push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out2 }, row);
            push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_ASSERT_START {
            if position == 0usize || (has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_MULTILINE) && is_line_start(input, position)) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_END {
            if position == input_len || (has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_MULTILINE) && is_line_end(input, position, input_len)) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_ABSOLUTE_START {
            if position == 0usize {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_ABSOLUTE_END {
            if position == input_len {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_BOUNDARY {
            if is_word_boundary_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_NOT_WORD_BOUNDARY {
            if !is_word_boundary_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_START {
            if is_word_start_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_END {
            if is_word_end_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_SEARCH_START {
            if workspace.capture_slot_count > 1usize && position == unsafe { row[1usize] } {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else {
            if unsafe { *list_len } >= workspace.capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return;
            }
            unsafe {
                list[*list_len] = state_id;
            }
            copy_capture_row(capture_row_ptr(list_caps, unsafe { *list_len }, workspace.capture_slot_count), row, workspace.capture_slot_count);
            unsafe {
                *list_len = *list_len + 1usize;
            }
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
    }
}

fn push_set_state(workspace: &mut Workspace, stack_len: *mut usize, stamp: usize, state_id: usize, source_caps: *mut usize) -> void {
    if state_id == t.NO_STATE || state_id >= workspace.capacity {
        return;
    }
    if unsafe { workspace.marks[state_id] } == stamp {
        return;
    }
    if unsafe { *stack_len } >= workspace.capacity {
        workspace.status = t.RegexStatus.workspace_too_large;
        return;
    }
    unsafe {
        workspace.marks[state_id] = stamp;
        workspace.stack[*stack_len] = state_id;
    }
    copy_capture_row(capture_row_ptr(workspace.stack_caps, unsafe { *stack_len }, workspace.capture_slot_count), source_caps, workspace.capture_slot_count);
    unsafe {
        *stack_len = *stack_len + 1usize;
    }
}

fn update_set_accepts(
    compiled: &t.RegexSet,
    list: *mut usize,
    list_len: usize,
    matched: *mut bool,
    matched_count: *mut usize
) -> void {
    var index: usize = 0usize;
    while index < list_len {
        let state_id: usize = unsafe { list[index] };
        if state_id < compiled.state_len && unsafe { compiled.states[state_id].opcode } == t.OP_MATCH {
            let pattern_id: usize = unsafe { compiled.states[state_id].value };
            if pattern_id < compiled.pattern_count && !unsafe { matched[pattern_id] } {
                unsafe {
                    matched[pattern_id] = true;
                    *matched_count = *matched_count + 1usize;
                }
            }
        }
        index += 1usize;
    }
}

fn update_set_best_accept(
    compiled: &t.RegexSet,
    workspace: &Workspace,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: usize,
    position: usize,
    best_matched: *mut bool,
    best_pattern_id: *mut usize,
    best_start: *mut usize,
    best_end: *mut usize
) -> void {
    var index: usize = 0usize;
    while index < list_len {
        let state_id: usize = unsafe { list[index] };
        if state_id < compiled.state_len && unsafe { compiled.states[state_id].opcode } == t.OP_MATCH {
            let pattern_id: usize = unsafe { compiled.states[state_id].value };
            let candidate_caps: *mut usize = capture_row_ptr(list_caps, index, workspace.capture_slot_count);
            let candidate_start: usize = unsafe { candidate_caps[0usize] };
            let replace: bool = !unsafe { *best_matched } ||
                candidate_start < unsafe { *best_start } ||
                (candidate_start == unsafe { *best_start } && position < unsafe { *best_end }) ||
                (candidate_start == unsafe { *best_start } && position == unsafe { *best_end } && pattern_id < unsafe { *best_pattern_id });
            if pattern_id < compiled.pattern_count && replace {
                unsafe {
                    *best_matched = true;
                    *best_pattern_id = pattern_id;
                    *best_start = candidate_start;
                    *best_end = position;
                }
            }
        }
        index += 1usize;
    }
}

fn captures_from_match(compiled: &t.Regex, found: t.MatchResult, capture_slots: *mut usize) -> t.Captures {
    if found.status != t.RegexStatus.ok {
        return t.empty_captures(found.status);
    }
    if !found.matched {
        return t.empty_captures(t.RegexStatus.no_match);
    }
    return results.create_captures(compiled, found.start, found.end, capture_slots);
}

fn captures_from_input_into(
    compiled: &t.Regex,
    input: InputView,
    start_offset: usize,
    workspace: &mut Workspace,
    captures: &mut t.Captures
) -> t.RegexStatus {
    if workspace.status != t.RegexStatus.ok {
        results.reset_captures(captures, workspace.status);
        return workspace.status;
    }
    let found: t.MatchResult = search_with_workspace(compiled, input, start_offset, workspace);
    if found.status != t.RegexStatus.ok {
        results.reset_captures(captures, found.status);
        return found.status;
    }
    if !found.matched {
        results.reset_captures(captures, t.RegexStatus.no_match);
        return t.RegexStatus.no_match;
    }
    let status: t.RegexStatus = results.fill_captures(compiled, found.start, found.end, workspace.best_caps, captures);
    return status;
}

fn run_at(compiled: &t.Regex, input: InputView, start: usize, require_end: bool, workspace: &mut Workspace) -> t.MatchResult {
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    clear_marks(workspace);
    init_capture_seed(workspace.best_caps, workspace.capture_slot_count, start);
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    var best_matched: bool = false;
    var best_end: usize = start;
    let input_len: usize = input.len;
    let current_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut next_len)) };
    add_closure(
        compiled,
        workspace.current,
        workspace.current_caps,
        current_len_ptr,
        workspace,
        stamp,
        compiled.start,
        start,
        input,
        input_len,
        workspace.best_caps
    );
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, start, start, workspace.status);
    }
    var position: usize = start;
    while true {
        let accept_state: u8 = update_best_accept(
            compiled,
            workspace,
            workspace.current,
            workspace.current_caps,
            current_len,
            position,
            input,
            input_len
        );
        if accept_state != ACCEPT_NONE {
            best_matched = true;
            best_end = position;
            if !require_end && accept_state == ACCEPT_READY {
                return t.match_result(true, start, position, t.RegexStatus.ok);
            }
        }
        if position >= input_len {
            break;
        }
        if current_len == 0usize {
            break;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        var index: usize = 0usize;
        while index < current_len {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = regex_transition_out(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input_len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return t.match_result(false, start, start, workspace.status);
                }
            }
            index += 1usize;
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
    if best_matched {
        if !require_end || best_end == input_len {
            return t.match_result(true, start, best_end, t.RegexStatus.ok);
        }
    }
    return t.match_result(false, start, start, t.RegexStatus.no_match);
}

fn add_closure(
    compiled: &t.Regex,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: *mut usize,
    workspace: &mut Workspace,
    stamp: usize,
    first_state: usize,
    position: usize,
    input: InputView,
    input_len: usize,
    source_caps: *mut usize
) -> void {
    var stack_len: usize = 0usize;
    let stack_len_ptr: *mut usize = unsafe { ptrat[*mut usize](ptraddr(&mut stack_len)) };
    push_state(workspace, stack_len_ptr, stamp, first_state, source_caps);
    while stack_len > 0usize {
        stack_len -= 1usize;
        let state_id: usize = unsafe { workspace.stack[stack_len] };
        if state_id == t.NO_STATE || state_id >= compiled.state_len {
            continue;
        }
        let row: *mut usize = capture_row_ptr(workspace.stack_caps, stack_len, workspace.capture_slot_count);
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_EPSILON {
            push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_SPLIT {
            push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out2 }, row);
            push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_SAVE {
            let slot: usize = unsafe { compiled.states[state_id].class_start };
            if slot >= workspace.capture_slot_count {
                workspace.status = t.RegexStatus.program_too_large;
                return;
            }
            unsafe {
                row[slot] = position;
            }
            push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_ASSERT_START {
            if position == 0usize || (has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_MULTILINE) && is_line_start(input, position)) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_END {
            if position == input_len || (has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_MULTILINE) && is_line_end(input, position, input_len)) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_ABSOLUTE_START {
            if position == 0usize {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_ABSOLUTE_END {
            if position == input_len {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_BOUNDARY {
            if is_word_boundary_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_NOT_WORD_BOUNDARY {
            if !is_word_boundary_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_START {
            if is_word_start_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_END {
            if is_word_end_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_SEARCH_START {
            if workspace.capture_slot_count > 1usize && position == unsafe { row[1usize] } {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else {
            if unsafe { *list_len } >= workspace.capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return;
            }
            unsafe {
                list[*list_len] = state_id;
            }
            copy_capture_row(capture_row_ptr(list_caps, unsafe { *list_len }, workspace.capture_slot_count), row, workspace.capture_slot_count);
            unsafe {
                *list_len = *list_len + 1usize;
            }
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
    }
}

fn push_state(workspace: &mut Workspace, stack_len: *mut usize, stamp: usize, state_id: usize, source_caps: *mut usize) -> void {
    if state_id == t.NO_STATE || state_id >= workspace.capacity {
        return;
    }
    if unsafe { workspace.marks[state_id] } == stamp {
        return;
    }
    if unsafe { *stack_len } >= workspace.capacity {
        workspace.status = t.RegexStatus.workspace_too_large;
        return;
    }
    unsafe {
        workspace.marks[state_id] = stamp;
        workspace.stack[*stack_len] = state_id;
    }
    copy_capture_row(capture_row_ptr(workspace.stack_caps, unsafe { *stack_len }, workspace.capture_slot_count), source_caps, workspace.capture_slot_count);
    unsafe {
        *stack_len = *stack_len + 1usize;
    }
}

fn starts_with_input_start_assertion(compiled: &t.Regex) -> bool {
    var steps: usize = 0usize;
    var state_id: usize = compiled.start;
    while state_id != t.NO_STATE && state_id < compiled.state_len {
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_EPSILON || opcode == t.OP_SAVE {
            state_id = unsafe { compiled.states[state_id].out1 };
        } else if opcode == t.OP_ASSERT_START {
            return !has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_MULTILINE);
        } else {
            return opcode == t.OP_ASSERT_ABSOLUTE_START;
        }
        steps += 1usize;
        if steps > compiled.state_len {
            return false;
        }
    }
    return false;
}

fn update_best_accept(
    compiled: &t.Regex,
    workspace: &mut Workspace,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: usize,
    position: usize,
    input: InputView,
    input_len: usize
) -> u8 {
    var index: usize = 0usize;
    while index < list_len {
        let state_id: usize = unsafe { list[index] };
        if state_id == compiled.accept {
            copy_capture_row(workspace.best_caps, capture_row_ptr(list_caps, index, workspace.capture_slot_count), workspace.capture_slot_count);
            if workspace.capture_slot_count > 1usize {
                unsafe {
                    workspace.best_caps[1usize] = position;
                }
            }
            if has_higher_priority_consumer(compiled, list, index, input, position, input_len, workspace) {
                return ACCEPT_DEFERRED;
            }
            return ACCEPT_READY;
        }
        index += 1usize;
    }
    return ACCEPT_NONE;
}

fn update_search_accept(
    compiled: &t.Regex,
    workspace: &mut Workspace,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: usize,
    position: usize,
    input: InputView,
    input_len: usize,
    best_matched: *mut bool,
    best_start: *mut usize,
    best_end: *mut usize
) -> u8 {
    var index: usize = 0usize;
    while index < list_len {
        let state_id: usize = unsafe { list[index] };
        if state_id == compiled.accept {
            let candidate_caps: *mut usize = capture_row_ptr(list_caps, index, workspace.capture_slot_count);
            let candidate_start: usize = unsafe { candidate_caps[0usize] };
            if !unsafe { *best_matched } || candidate_start < unsafe { *best_start } ||
                candidate_start == unsafe { *best_start } {
                copy_capture_row(workspace.best_caps, candidate_caps, workspace.capture_slot_count);
                if workspace.capture_slot_count > 1usize {
                    unsafe {
                        workspace.best_caps[1usize] = position;
                    }
                }
                unsafe {
                    *best_matched = true;
                    *best_start = candidate_start;
                    *best_end = position;
                }
            }
            if has_higher_priority_consumer(compiled, list, index, input, position, input_len, workspace) {
                return ACCEPT_DEFERRED;
            }
            return ACCEPT_READY;
        }
        index += 1usize;
    }
    return ACCEPT_NONE;
}

fn has_higher_priority_consumer(
    compiled: &t.Regex,
    list: *mut usize,
    accept_index: usize,
    input: InputView,
    position: usize,
    input_len: usize,
    workspace: &mut Workspace
) -> bool {
    if position >= input_len {
        return false;
    }
    let value: usize = decode_at(input, position).value;
    var index: usize = 0usize;
    while index < accept_index {
        let state_id: usize = unsafe { list[index] };
        if regex_transition_out(compiled, state_id, value, workspace) != t.NO_STATE {
            return true;
        }
        index += 1usize;
    }
    return false;
}

fn regex_transition_out(compiled: &t.Regex, state_id: usize, value: usize, workspace: &mut Workspace) -> usize {
    if state_matches(compiled, state_id, value, workspace) {
        return unsafe { compiled.states[state_id].out1 };
    }
    return regex_full_fold_sequence_out(compiled, state_id, value);
}

fn set_transition_out(compiled: &t.RegexSet, state_id: usize, value: usize, workspace: &mut Workspace) -> usize {
    if set_state_matches(compiled, state_id, value, workspace) {
        return unsafe { compiled.states[state_id].out1 };
    }
    return set_full_fold_sequence_out(compiled, state_id, value);
}

fn state_matches(compiled: &t.Regex, state_id: usize, value: usize, workspace: &mut Workspace) -> bool {
    let opcode: u8 = unsafe { compiled.states[state_id].opcode };
    if opcode == t.OP_LITERAL {
        let expected: usize = unsafe { compiled.states[state_id].value };
        if has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_CASE_INSENSITIVE) {
            return folded_equals(expected, value, has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_ASCII));
        }
        return expected == value;
    }
    if opcode == t.OP_ANY {
        return has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_DOTALL) || !is_line_break_mode(workspace.newline_mode, value);
    }
    if opcode == t.OP_CLASS {
        return class_matches(compiled, state_id, value, workspace);
    }
    return false;
}

fn regex_full_fold_sequence_out(compiled: &t.Regex, state_id: usize, value: usize) -> usize {
    if compiled.mode != t.MODE_TEXT {
        return t.NO_STATE;
    }
    return full_fold_sequence_out(
        unsafe { ptrcast[*const t.State](compiled.states) },
        compiled.state_len,
        state_id,
        value
    );
}

fn set_full_fold_sequence_out(compiled: &t.RegexSet, state_id: usize, value: usize) -> usize {
    if compiled.mode != t.MODE_TEXT {
        return t.NO_STATE;
    }
    return full_fold_sequence_out(
        unsafe { ptrcast[*const t.State](compiled.states) },
        compiled.state_len,
        state_id,
        value
    );
}

fn full_fold_sequence_out(states: *const t.State, state_len: usize, state_id: usize, value: usize) -> usize {
    let fold_len: usize = unicode.full_fold_len(value);
    if fold_len <= 1usize {
        return t.NO_STATE;
    }
    var current: usize = state_id;
    var index: usize = 0usize;
    while index < fold_len {
        if current == t.NO_STATE || current >= state_len {
            return t.NO_STATE;
        }
        let state: t.State = unsafe { states[current] };
        if state.opcode != t.OP_LITERAL ||
            !has_flag(state.flags, t.FLAG_CASE_INSENSITIVE) ||
            has_flag(state.flags, t.FLAG_ASCII) {
            return t.NO_STATE;
        }
        if !folded_equals(state.value, unicode.full_fold_at(value, index), false) {
            return t.NO_STATE;
        }
        if index + 1usize == fold_len {
            return state.out1;
        }
        current = next_full_fold_literal(states, state_len, state.out1);
        index += 1usize;
    }
    return t.NO_STATE;
}

fn next_full_fold_literal(states: *const t.State, state_len: usize, first_state: usize) -> usize {
    var state_id: usize = first_state;
    var steps: usize = 0usize;
    while state_id != t.NO_STATE && state_id < state_len && steps <= state_len {
        let opcode: u8 = unsafe { states[state_id].opcode };
        if opcode == t.OP_LITERAL {
            return state_id;
        }
        if opcode != t.OP_EPSILON {
            return t.NO_STATE;
        }
        state_id = unsafe { states[state_id].out1 };
        steps += 1usize;
    }
    return t.NO_STATE;
}

fn set_state_matches(compiled: &t.RegexSet, state_id: usize, value: usize, workspace: &mut Workspace) -> bool {
    let opcode: u8 = unsafe { compiled.states[state_id].opcode };
    if opcode == t.OP_LITERAL {
        let expected: usize = unsafe { compiled.states[state_id].value };
        if has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_CASE_INSENSITIVE) {
            return folded_equals(expected, value, has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_ASCII));
        }
        return expected == value;
    }
    if opcode == t.OP_ANY {
        return has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_DOTALL) || !is_line_break_mode(workspace.newline_mode, value);
    }
    if opcode == t.OP_CLASS {
        return set_class_matches(compiled, state_id, value, workspace);
    }
    return false;
}

fn class_matches(compiled: &t.Regex, state_id: usize, value: usize, workspace: &mut Workspace) -> bool {
    let class_start: usize = unsafe { compiled.states[state_id].class_start };
    let class_len: usize = unsafe { compiled.states[state_id].class_len };
    let flags: u8 = unsafe { compiled.states[state_id].flags };
    let negated: bool = has_flag(flags, t.FLAG_CLASS_NEGATED);
    let matched: bool = class_expr_matches(
        compiled,
        class_start,
        class_len,
        value,
        workspace,
        has_flag(flags, t.FLAG_CASE_INSENSITIVE),
        has_flag(flags, t.FLAG_ASCII)
    );
    if negated {
        return !matched;
    }
    return matched;
}

fn set_class_matches(compiled: &t.RegexSet, state_id: usize, value: usize, workspace: &mut Workspace) -> bool {
    let class_start: usize = unsafe { compiled.states[state_id].class_start };
    let class_len: usize = unsafe { compiled.states[state_id].class_len };
    let flags: u8 = unsafe { compiled.states[state_id].flags };
    let negated: bool = has_flag(flags, t.FLAG_CLASS_NEGATED);
    let matched: bool = set_class_expr_matches(
        compiled,
        class_start,
        class_len,
        value,
        workspace,
        has_flag(flags, t.FLAG_CASE_INSENSITIVE),
        has_flag(flags, t.FLAG_ASCII)
    );
    if negated {
        return !matched;
    }
    return matched;
}

fn class_expr_matches(
    compiled: &t.Regex,
    class_start: usize,
    class_len: usize,
    value: usize,
    workspace: &mut Workspace,
    folded: bool,
    ascii_mode: bool
) -> bool {
    var depth: usize = 0usize;
    var offset: usize = 0usize;
    while offset < class_len {
        let range_index: usize = class_start + offset;
        let kind: u8 = unsafe { compiled.ranges[range_index].kind };
        let first: usize = unsafe { compiled.ranges[range_index].first };
        let last: usize = unsafe { compiled.ranges[range_index].last };
        if kind == t.CLASS_RANGE_SCALAR || kind == t.CLASS_RANGE_PROPERTY || kind == t.CLASS_RANGE_PROPERTY_NEGATED {
            if depth >= workspace.class_capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return false;
            }
            unsafe {
                workspace.class_stack[depth] = class_primitive_matches(kind, first, last, value, folded, ascii_mode);
            }
            depth += 1usize;
        } else if kind == t.CLASS_EXPR_COMPLEMENT {
            if depth == 0usize {
                return false;
            }
            unsafe {
                workspace.class_stack[depth - 1usize] = !workspace.class_stack[depth - 1usize];
            }
        } else {
            if depth < 2usize {
                return false;
            }
            let right: bool = unsafe { workspace.class_stack[depth - 1usize] };
            let left: bool = unsafe { workspace.class_stack[depth - 2usize] };
            depth -= 1usize;
            unsafe {
                workspace.class_stack[depth - 1usize] = apply_class_expr_op(kind, left, right);
            }
        }
        offset += 1usize;
    }
    if depth != 1usize {
        return false;
    }
    return unsafe { workspace.class_stack[0usize] };
}

fn set_class_expr_matches(
    compiled: &t.RegexSet,
    class_start: usize,
    class_len: usize,
    value: usize,
    workspace: &mut Workspace,
    folded: bool,
    ascii_mode: bool
) -> bool {
    var depth: usize = 0usize;
    var offset: usize = 0usize;
    while offset < class_len {
        let range_index: usize = class_start + offset;
        let kind: u8 = unsafe { compiled.ranges[range_index].kind };
        let first: usize = unsafe { compiled.ranges[range_index].first };
        let last: usize = unsafe { compiled.ranges[range_index].last };
        if kind == t.CLASS_RANGE_SCALAR || kind == t.CLASS_RANGE_PROPERTY || kind == t.CLASS_RANGE_PROPERTY_NEGATED {
            if depth >= workspace.class_capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return false;
            }
            unsafe {
                workspace.class_stack[depth] = class_primitive_matches(kind, first, last, value, folded, ascii_mode);
            }
            depth += 1usize;
        } else if kind == t.CLASS_EXPR_COMPLEMENT {
            if depth == 0usize {
                return false;
            }
            unsafe {
                workspace.class_stack[depth - 1usize] = !workspace.class_stack[depth - 1usize];
            }
        } else {
            if depth < 2usize {
                return false;
            }
            let right: bool = unsafe { workspace.class_stack[depth - 1usize] };
            let left: bool = unsafe { workspace.class_stack[depth - 2usize] };
            depth -= 1usize;
            unsafe {
                workspace.class_stack[depth - 1usize] = apply_class_expr_op(kind, left, right);
            }
        }
        offset += 1usize;
    }
    if depth != 1usize {
        return false;
    }
    return unsafe { workspace.class_stack[0usize] };
}

fn class_primitive_matches(kind: u8, first: usize, last: usize, value: usize, folded: bool, ascii_mode: bool) -> bool {
    if kind == t.CLASS_RANGE_SCALAR {
        if folded {
            if ascii_mode {
                return ascii_fold_equivalent_in_range(value, first, last);
            }
            return unicode.fold_equivalent_in_range(value, first, last);
        }
        return first <= value && value <= last;
    }
    if ascii_mode && is_ascii_shorthand_property(first) {
        let matched_ascii: bool = ascii_property_matches(first, value);
        if kind == t.CLASS_RANGE_PROPERTY {
            return matched_ascii;
        }
        return !matched_ascii;
    }
    if kind == t.CLASS_RANGE_PROPERTY {
        if folded {
            return unicode.property_case_fold_matches(first, value);
        }
        return unicode.property_matches(first, value);
    }
    if folded {
        return !unicode.property_case_fold_matches(first, value);
    }
    return !unicode.property_matches(first, value);
}

fn apply_class_expr_op(kind: u8, left: bool, right: bool) -> bool {
    if kind == t.CLASS_EXPR_UNION {
        return left || right;
    }
    if kind == t.CLASS_EXPR_INTERSECTION {
        return left && right;
    }
    if kind == t.CLASS_EXPR_DIFFERENCE {
        return left && !right;
    }
    if kind == t.CLASS_EXPR_SYMMETRIC_DIFFERENCE {
        return left != right;
    }
    return false;
}

fn has_flag(flags: u8, flag: u8) -> bool {
    return (flags & flag) != t.FLAGS_NONE;
}

fn folded_equals(expected: usize, value: usize, ascii_mode: bool) -> bool {
    if ascii_mode {
        if expected > ASCII_BYTE_MAX || value > ASCII_BYTE_MAX {
            return expected == value;
        }
        return ascii.to_lower(cast[u8](expected)) == ascii.to_lower(cast[u8](value));
    }
    return unicode.simple_fold(expected) == unicode.simple_fold(value);
}

fn ascii_fold_equivalent_in_range(value: usize, first: usize, last: usize) -> bool {
    if first <= value && value <= last {
        return true;
    }
    if value > ASCII_BYTE_MAX {
        return false;
    }
    let lower: usize = cast[usize](ascii.to_lower(cast[u8](value)));
    if first <= lower && lower <= last {
        return true;
    }
    let upper: usize = cast[usize](ascii.to_upper(cast[u8](value)));
    return first <= upper && upper <= last;
}

fn is_ascii_shorthand_property(kind: usize) -> bool {
    return kind == unicode.PROPERTY_GC_ND ||
        kind == unicode.PROPERTY_WORD ||
        kind == unicode.PROPERTY_WHITE_SPACE;
}

fn ascii_property_matches(kind: usize, value: usize) -> bool {
    if value > ASCII_BYTE_MAX {
        return false;
    }
    let byte: u8 = cast[u8](value);
    if kind == unicode.PROPERTY_GC_ND {
        return ascii.is_digit(byte);
    }
    if kind == unicode.PROPERTY_WORD {
        return ascii.is_word(byte);
    }
    if kind == unicode.PROPERTY_WHITE_SPACE {
        return ascii.is_ascii_whitespace(byte);
    }
    return unicode.property_matches(kind, value);
}

fn is_line_break(input: InputView, value: usize) -> bool {
    return is_line_break_mode(input.newline_mode, value);
}

fn is_line_break_mode(newline_mode: u8, value: usize) -> bool {
    if newline_mode == t.NEWLINE_LF {
        return value == unicode.LINE_FEED;
    }
    if newline_mode == t.NEWLINE_CRLF {
        return value == unicode.LINE_FEED || value == unicode.CARRIAGE_RETURN;
    }
    return unicode.is_line_break_scalar(value);
}

fn is_line_start(input: InputView, position: usize) -> bool {
    if position == 0usize {
        return true;
    }
    let previous: InputDecode = previous_decode(input, position);
    return previous.valid && is_line_break(input, previous.value);
}

fn is_line_end(input: InputView, position: usize, input_len: usize) -> bool {
    if position == input_len {
        return true;
    }
    let current: InputDecode = decode_at(input, position);
    return current.valid && is_line_break(input, current.value);
}

fn is_word_boundary_flags(input: InputView, position: usize, input_len: usize, flags: u8) -> bool {
    let left: InputDecode = previous_decode(input, position);
    let right: InputDecode = decode_at(input, position);
    let left_is_word: bool = position > 0usize && left.valid && is_word_flags(input, left.value, flags);
    let right_is_word: bool = position < input_len && right.valid && is_word_flags(input, right.value, flags);
    return left_is_word != right_is_word;
}

fn is_word_start_flags(input: InputView, position: usize, input_len: usize, flags: u8) -> bool {
    if position >= input_len {
        return false;
    }
    let left: InputDecode = previous_decode(input, position);
    let right: InputDecode = decode_at(input, position);
    let left_is_word: bool = position > 0usize && left.valid && is_word_flags(input, left.value, flags);
    let right_is_word: bool = right.valid && is_word_flags(input, right.value, flags);
    return !left_is_word && right_is_word;
}

fn is_word_end_flags(input: InputView, position: usize, input_len: usize, flags: u8) -> bool {
    if position == 0usize {
        return false;
    }
    let left: InputDecode = previous_decode(input, position);
    let right: InputDecode = decode_at(input, position);
    let left_is_word: bool = left.valid && is_word_flags(input, left.value, flags);
    let right_is_word: bool = position < input_len && right.valid && is_word_flags(input, right.value, flags);
    return left_is_word && !right_is_word;
}

fn create_workspace_with_limit(capacity: usize, slots: usize, max_workspace_states: usize) -> Workspace {
    if capacity > max_workspace_states {
        return empty_workspace(t.RegexStatus.workspace_too_large);
    }
    let current: *mut usize = alloc_usize_array(capacity);
    if current == null {
        return empty_workspace(t.RegexStatus.out_of_memory);
    }
    let next: *mut usize = alloc_usize_array(capacity);
    if next == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current) });
        return empty_workspace(t.RegexStatus.out_of_memory);
    }
    let marks: *mut usize = alloc_usize_array(capacity);
    if marks == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](next) });
        return empty_workspace(t.RegexStatus.out_of_memory);
    }
    let stack: *mut usize = alloc_usize_array(capacity);
    if stack == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](next) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](marks) });
        return empty_workspace(t.RegexStatus.out_of_memory);
    }
    let start_states: *mut usize = alloc_usize_array(capacity);
    if start_states == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](next) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](marks) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](stack) });
        return empty_workspace(t.RegexStatus.out_of_memory);
    }
    let start_bytes: *mut bool = alloc_bool_array(limits.START_BYTE_COUNT);
    if start_bytes == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](next) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](marks) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](stack) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](start_states) });
        return empty_workspace(t.RegexStatus.out_of_memory);
    }
    let row_count: usize = capacity * slots;
    let current_caps: *mut usize = alloc_usize_array(row_count);
    if current_caps == null {
        return free_base_workspace(current, next, marks, stack, start_states, start_bytes, t.RegexStatus.out_of_memory);
    }
    let next_caps: *mut usize = alloc_usize_array(row_count);
    if next_caps == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current_caps) });
        return free_base_workspace(current, next, marks, stack, start_states, start_bytes, t.RegexStatus.out_of_memory);
    }
    let stack_caps: *mut usize = alloc_usize_array(row_count);
    if stack_caps == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](next_caps) });
        return free_base_workspace(current, next, marks, stack, start_states, start_bytes, t.RegexStatus.out_of_memory);
    }
    let best_caps: *mut usize = alloc_usize_array(slots);
    if best_caps == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](next_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](stack_caps) });
        return free_base_workspace(current, next, marks, stack, start_states, start_bytes, t.RegexStatus.out_of_memory);
    }
    let seed_caps: *mut usize = alloc_usize_array(slots);
    if seed_caps == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](next_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](stack_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](best_caps) });
        return free_base_workspace(current, next, marks, stack, start_states, start_bytes, t.RegexStatus.out_of_memory);
    }
    let class_stack: *mut bool = alloc_bool_array(limits.MAX_RANGE_CAPACITY);
    if class_stack == null {
        alloc.free_bytes(unsafe { ptrcast[*mut u8](current_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](next_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](stack_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](best_caps) });
        alloc.free_bytes(unsafe { ptrcast[*mut u8](seed_caps) });
        return free_base_workspace(current, next, marks, stack, start_states, start_bytes, t.RegexStatus.out_of_memory);
    }
    return Workspace {
        current: current,
        next: next,
        marks: marks,
        stack: stack,
        start_states: start_states,
        start_bytes: start_bytes,
        current_caps: current_caps,
        next_caps: next_caps,
        stack_caps: stack_caps,
        best_caps: best_caps,
        seed_caps: seed_caps,
        class_stack: class_stack,
        capacity: capacity,
        class_capacity: limits.MAX_RANGE_CAPACITY,
        capture_slot_count: slots,
        newline_mode: t.NEWLINE_UNICODE,
        status: t.RegexStatus.ok,
    };
}

fn destroy_workspace(workspace: &mut Workspace) -> void {
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.current) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.next) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.marks) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.stack) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.start_states) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.start_bytes) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.current_caps) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.next_caps) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.stack_caps) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.best_caps) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.seed_caps) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](workspace.class_stack) });
    workspace.current = null;
    workspace.next = null;
    workspace.marks = null;
    workspace.stack = null;
    workspace.start_states = null;
    workspace.start_bytes = null;
    workspace.current_caps = null;
    workspace.next_caps = null;
    workspace.stack_caps = null;
    workspace.best_caps = null;
    workspace.seed_caps = null;
    workspace.class_stack = null;
    workspace.capacity = 0usize;
    workspace.class_capacity = 0usize;
    workspace.capture_slot_count = 0usize;
    workspace.newline_mode = t.NEWLINE_UNICODE;
    workspace.status = t.RegexStatus.unsupported;
}

fn free_base_workspace(
    current: *mut usize,
    next: *mut usize,
    marks: *mut usize,
    stack: *mut usize,
    start_states: *mut usize,
    start_bytes: *mut bool,
    status: t.RegexStatus
) -> Workspace {
    alloc.free_bytes(unsafe { ptrcast[*mut u8](current) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](next) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](marks) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](stack) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](start_states) });
    alloc.free_bytes(unsafe { ptrcast[*mut u8](start_bytes) });
    return empty_workspace(status);
}

fn empty_workspace(status: t.RegexStatus) -> Workspace {
    return Workspace {
        current: null,
        next: null,
        marks: null,
        stack: null,
        start_states: null,
        start_bytes: null,
        current_caps: null,
        next_caps: null,
        stack_caps: null,
        best_caps: null,
        seed_caps: null,
        class_stack: null,
        capacity: 0usize,
        class_capacity: 0usize,
        capture_slot_count: 0usize,
        newline_mode: t.NEWLINE_UNICODE,
        status: status,
    };
}

fn clear_marks(workspace: &mut Workspace) -> void {
    var index: usize = 0usize;
    while index < workspace.capacity {
        unsafe {
            workspace.marks[index] = 0usize;
        }
        index += 1usize;
    }
}

fn clear_start_bytes(workspace: &mut Workspace) -> void {
    var index: usize = 0usize;
    while index < limits.START_BYTE_COUNT {
        unsafe {
            workspace.start_bytes[index] = false;
        }
        index += 1usize;
    }
}

fn swap_lists(workspace: &mut Workspace) -> void {
    let old_current: *mut usize = workspace.current;
    let old_current_caps: *mut usize = workspace.current_caps;
    workspace.current = workspace.next;
    workspace.next = old_current;
    workspace.current_caps = workspace.next_caps;
    workspace.next_caps = old_current_caps;
}

fn list_has_start_at_or_before(list_caps: *mut usize, list_len: usize, slot_count: usize, start: usize) -> bool {
    var index: usize = 0usize;
    while index < list_len {
        if unsafe { capture_row_ptr(list_caps, index, slot_count)[0usize] } <= start {
            return true;
        }
        index += 1usize;
    }
    return false;
}

fn write_set_matches(matched: *mut bool, pattern_count: usize, out_pattern_ids: *mut usize, out_capacity: usize) -> usize {
    var index: usize = 0usize;
    var written: usize = 0usize;
    while index < pattern_count {
        if unsafe { matched[index] } {
            if written < out_capacity && out_pattern_ids != null {
                unsafe {
                    out_pattern_ids[written] = index;
                }
            }
            written += 1usize;
        }
        index += 1usize;
    }
    if written > out_capacity {
        return out_capacity;
    }
    return written;
}

fn alloc_usize_array(count: usize) -> *mut usize {
    return unsafe {
        ptrcast[*mut usize](alloc.alloc_zeroed_bytes(count, sizeof[usize]))
    };
}

fn alloc_bool_array(count: usize) -> *mut bool {
    return unsafe {
        ptrcast[*mut bool](alloc.alloc_zeroed_bytes(count, sizeof[bool]))
    };
}

fn init_capture_seed(row: *mut usize, slot_count: usize, start: usize) -> void {
    init_capture_seed_with_search_start(row, slot_count, start, start);
}

fn init_capture_seed_with_search_start(row: *mut usize, slot_count: usize, start: usize, search_start: usize) -> void {
    var slot: usize = 0usize;
    while slot < slot_count {
        unsafe {
            row[slot] = t.CAPTURE_MISSING;
        }
        slot += 1usize;
    }
    if slot_count > 0usize {
        unsafe {
            row[0usize] = start;
        }
    }
    if slot_count > 1usize {
        unsafe {
            row[1usize] = search_start;
        }
    }
}

fn copy_capture_row(dst: *mut usize, src: *mut usize, slot_count: usize) -> void {
    var slot: usize = 0usize;
    while slot < slot_count {
        unsafe {
            dst[slot] = src[slot];
        }
        slot += 1usize;
    }
}

fn capture_row_ptr(base: *mut usize, row: usize, slot_count: usize) -> *mut usize {
    return unsafe {
        ptrat[*mut usize](ptraddr(base) + row * slot_count * sizeof[usize])
    };
}

fn capture_slot_count(compiled: &t.Regex) -> usize {
    return compiled.capture_len * 2usize;
}

fn workspace_bytes_for(state_count: usize, slots: usize) -> usize {
    return state_count * limits.WORKSPACE_LIST_COUNT * sizeof[usize]
        + state_count * slots * limits.WORKSPACE_STATE_CAPTURE_ROW_COUNT * sizeof[usize]
        + slots * limits.WORKSPACE_FIXED_CAPTURE_ROW_COUNT * sizeof[usize]
        + limits.START_BYTE_COUNT * sizeof[bool]
        + limits.MAX_RANGE_CAPACITY * sizeof[bool];
}

fn text_input_with_options(input: str, options: t.RegexOptions) -> InputView {
    return InputView {
        text: input,
        data: strptr(input),
        len: strblen(input),
        mode: t.MODE_TEXT,
        newline_mode: options.newline_mode,
    };
}

fn bytes_input_with_options(input: []const u8, options: t.RegexOptions) -> InputView {
    return InputView {
        text: "",
        data: sliceptr(input),
        len: slicelen(input),
        mode: t.MODE_BYTES,
        newline_mode: options.newline_mode,
    };
}

fn flatten_text_chunks(chunks: []const t.TextChunk) -> FlatInput {
    let chunk_count: usize = slicelen(chunks);
    var total: usize = 0usize;
    var index: usize = 0usize;
    while index < chunk_count {
        total += strblen(chunks[index].text);
        index += 1usize;
    }
    return flatten_text_chunks_with_len(chunks, total);
}

fn flatten_text_chunks_with_len(chunks: []const t.TextChunk, total: usize) -> FlatInput {
    let allocation_len: usize = if total == 0usize { 1usize } else { total };
    let data: *mut u8 = alloc.alloc_zeroed_bytes(allocation_len, sizeof[u8]);
    if data == null {
        return FlatInput { data: null, len: 0usize, status: t.RegexStatus.out_of_memory };
    }
    var dst: usize = 0usize;
    var index: usize = 0usize;
    while index < slicelen(chunks) {
        let text: str = chunks[index].text;
        let src: *const u8 = strptr(text);
        var offset: usize = 0usize;
        while offset < strblen(text) {
            unsafe {
                data[dst + offset] = src[offset];
            }
            offset += 1usize;
        }
        dst += strblen(text);
        index += 1usize;
    }
    return FlatInput { data: data, len: total, status: t.RegexStatus.ok };
}

fn flatten_byte_chunks(chunks: []const t.RegexChunk) -> FlatInput {
    let chunk_count: usize = slicelen(chunks);
    var total: usize = 0usize;
    var index: usize = 0usize;
    while index < chunk_count {
        total += chunks[index].len;
        index += 1usize;
    }
    let allocation_len: usize = if total == 0usize { 1usize } else { total };
    let data: *mut u8 = alloc.alloc_zeroed_bytes(allocation_len, sizeof[u8]);
    if data == null {
        return FlatInput { data: null, len: 0usize, status: t.RegexStatus.out_of_memory };
    }
    var dst: usize = 0usize;
    index = 0usize;
    while index < chunk_count {
        let src: *const u8 = chunks[index].data;
        var offset: usize = 0usize;
        while offset < chunks[index].len {
            unsafe {
                data[dst + offset] = src[offset];
            }
            offset += 1usize;
        }
        dst += chunks[index].len;
        index += 1usize;
    }
    return FlatInput { data: data, len: total, status: t.RegexStatus.ok };
}

fn destroy_flat_input(flat: &mut FlatInput) -> void {
    alloc.free_bytes(flat.data);
    flat.data = null;
    flat.len = 0usize;
    flat.status = t.RegexStatus.unsupported;
}

fn raw_bytes_input(data: *const u8, len: usize, options: t.RegexOptions) -> InputView {
    return InputView {
        text: "",
        data: data,
        len: len,
        mode: t.MODE_BYTES,
        newline_mode: options.newline_mode,
    };
}

fn raw_text_input(data: *const u8, len: usize, options: t.RegexOptions) -> InputView {
    return InputView {
        text: unsafe { strraw(data, len) },
        data: data,
        len: len,
        mode: t.MODE_TEXT,
        newline_mode: options.newline_mode,
    };
}

fn set_text_input(compiled: &t.RegexSet, input: str) -> InputView {
    return text_input_with_options(input, compiled.options);
}

fn set_bytes_input(compiled: &t.RegexSet, input: []const u8) -> InputView {
    return bytes_input_with_options(input, compiled.options);
}

fn decode_at(input: InputView, position: usize) -> InputDecode {
    if input.mode == t.MODE_TEXT {
        let decoded: unicode.Decode = unicode.decode_at(input.text, position);
        return InputDecode { value: decoded.value, next: decoded.next, valid: decoded.valid };
    }
    if position >= input.len {
        return InputDecode { value: 0usize, next: position, valid: false };
    }
    return InputDecode {
        value: cast[usize](unsafe { input.data[position] }),
        next: position + 1usize,
        valid: true,
    };
}

fn previous_decode(input: InputView, position: usize) -> InputDecode {
    if input.mode == t.MODE_TEXT {
        let decoded: unicode.Decode = unicode.previous_decode(input.text, position);
        return InputDecode { value: decoded.value, next: decoded.next, valid: decoded.valid };
    }
    if position == 0usize || position > input.len {
        return InputDecode { value: 0usize, next: position, valid: false };
    }
    let previous: usize = position - 1usize;
    return InputDecode {
        value: cast[usize](unsafe { input.data[previous] }),
        next: previous,
        valid: true,
    };
}

fn align_forward_boundary(input: InputView, position: usize) -> usize {
    if input.mode == t.MODE_TEXT {
        return unicode.align_forward_boundary(input.text, position);
    }
    return position;
}

fn next_boundary(input: InputView, position: usize) -> usize {
    if input.mode == t.MODE_TEXT {
        return unicode.next_boundary(input.text, position);
    }
    return position + 1usize;
}

fn next_match_cursor(input: InputView, start: usize, end: usize) -> usize {
    if end > start {
        return end;
    }
    if end >= input.len {
        return input.len + 1usize;
    }
    return next_boundary(input, end);
}

fn is_word_flags(input: InputView, value: usize, flags: u8) -> bool {
    if has_flag(flags, t.FLAG_ASCII) {
        return value <= ASCII_BYTE_MAX && ascii.is_word(cast[u8](value));
    }
    if input.mode == t.MODE_TEXT {
        return unicode.is_word(value);
    }
    return value <= 0xffusize && ascii.is_word(cast[u8](value));
}
