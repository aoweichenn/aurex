module regex.vm.engine;

import regex.config.limits as limits;
import regex.core.results as results;
import regex.core.types as t;
import regex.runtime.alloc as alloc;
import regex.syntax.ascii as ascii;
import unicode.ucd as unicode;

const ACCEPT_NONE: u8 = 0u8;
const ACCEPT_DEFERRED: u8 = 1u8;
const ACCEPT_READY: u8 = 2u8;
const ASCII_BYTE_COUNT: usize = 128usize;
const ASCII_BYTE_MAX: usize = 0x7fusize;
const UTF8_TWO_BYTE_SCALAR_MAX: usize = 0x7ffusize;
const UTF8_THREE_BYTE_SCALAR_MAX: usize = 0xffffusize;
const UTF8_SCALAR_MAX: usize = 0x10ffffusize;
const UTF8_SURROGATE_FIRST: usize = 0xd800usize;
const UTF8_SURROGATE_LAST: usize = 0xdfffusize;
const UTF8_TWO_BYTE_PREFIX: usize = 0xc0usize;
const UTF8_THREE_BYTE_PREFIX: usize = 0xe0usize;
const UTF8_FOUR_BYTE_PREFIX: usize = 0xf0usize;
const UTF8_TWO_BYTE_SHIFT: usize = 64usize;
const UTF8_THREE_BYTE_SHIFT: usize = 4096usize;
const UTF8_FOUR_BYTE_SHIFT: usize = 262144usize;
const UTF8_NON_ASCII_FIRST_MIN: usize = 0xc2usize;
const UTF8_NON_ASCII_FIRST_MAX: usize = 0xf4usize;

pub struct Workspace {
    current: *mut usize;
    next: *mut usize;
    marks: *mut usize;
    stack: *mut usize;
    start_states: *mut usize;
    start_bytes: *mut bool;
    current_caps: *mut usize;
    next_caps: *mut usize;
    stack_caps: *mut usize;
    best_caps: *mut usize;
    seed_caps: *mut usize;
    class_stack: *mut bool;
    capacity: usize;
    class_capacity: usize;
    capture_slot_count: usize;
    newline_mode: u8;
    status: t.RegexStatus;
}

struct InputView {
    text: str;
    data: *const u8;
    len: usize;
    mode: u8;
    newline_mode: u8;
}

struct InputDecode {
    value: usize;
    next: usize;
    valid: bool;
}

struct StartFilter {
    enabled: bool;
    state_len: usize;
    byte_filter_enabled: bool;
    literal_prefix_enabled: bool;
    literal_prefix_start: usize;
    literal_prefix_len: usize;
}

struct FlatInput {
    data: *mut u8;
    len: usize;
    status: t.RegexStatus;
}

pub fn search_compiled(compiled: &t.Regex, input: str) -> t.MatchResult {
    return search_compiled_from(compiled, input, 0usize);
}

pub fn search_compiled_from(compiled: &t.Regex, input: str, start_offset: usize) -> t.MatchResult {
    if compiled.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    defer destroy_workspace(&mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, workspace.status);
    }
    return search_with_workspace(compiled, text_input_with_options(input, compiled.options), start_offset, &mut workspace);
}

pub fn fullmatch_compiled(compiled: &t.Regex, input: str) -> t.MatchResult {
    if compiled.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    defer destroy_workspace(&mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, workspace.status);
    }
    return run_at(compiled, text_input_with_options(input, compiled.options), 0usize, true, &mut workspace);
}

pub fn captures_compiled(compiled: &t.Regex, input: str) -> t.Captures {
    return captures_compiled_from(compiled, input, 0usize);
}

pub fn captures_compiled_from(compiled: &t.Regex, input: str, start_offset: usize) -> t.Captures {
    if compiled.status != t.RegexStatus.ok {
        return t.empty_captures(compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.empty_captures(t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    defer destroy_workspace(&mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.empty_captures(workspace.status);
    }
    var captures: t.Captures = t.empty_captures(t.RegexStatus.no_match);
    captures_compiled_from_into(compiled, input, start_offset, &mut workspace, &mut captures);
    return captures;
}

pub fn captures_fullmatch_compiled(compiled: &t.Regex, input: str) -> t.Captures {
    if compiled.status != t.RegexStatus.ok {
        return t.empty_captures(compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.empty_captures(t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    defer destroy_workspace(&mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.empty_captures(workspace.status);
    }
    let found: t.MatchResult = run_at(compiled, text_input_with_options(input, compiled.options), 0usize, true, &mut workspace);
    return captures_from_match(compiled, found, workspace.best_caps);
}

pub fn workspace_bytes(compiled: &t.Regex) -> usize {
    return workspace_bytes_for(compiled.state_len, capture_slot_count(compiled));
}

pub fn workspace_bytes_for_states(state_count: usize) -> usize {
    return workspace_bytes_for(state_count, 2usize);
}

pub fn search_bytes_compiled(compiled: &t.Regex, input: []const u8) -> t.MatchResult {
    return search_bytes_compiled_from(compiled, input, 0usize);
}

pub fn search_bytes_compiled_from(compiled: &t.Regex, input: []const u8, start_offset: usize) -> t.MatchResult {
