pub fn search_vectored_compiled(compiled: &t.Regex, chunks: []t.TextChunk) -> t.MatchResult {
    if compiled.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var flat: FlatInput = flatten_text_chunks(chunks);
    if flat.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, flat.status);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, workspace.status);
    }
    return search_with_workspace(compiled, raw_text_input(unsafe { ptrcast<*const u8>(flat.data) }, flat.len, compiled.options), 0usize, &mut workspace);
}

pub fn search_bytes_vectored_compiled(compiled: &t.Regex, chunks: []t.RegexChunk) -> t.MatchResult {
    if compiled.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_BYTES {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var flat: FlatInput = flatten_byte_chunks(chunks);
    if flat.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, flat.status);
    }
    return search_bytes_raw_compiled_from(compiled, unsafe { ptrcast<*const u8>(flat.data) }, flat.len, 0usize);
}

pub fn matches_set_vectored_compiled(
    compiled: &t.RegexSet,
    chunks: []t.TextChunk,
    out_pattern_ids: *mut usize,
    out_capacity: usize
) -> t.SetMatchesResult {
    if compiled.status != t.RegexStatus.ok {
        return t.set_matches_result(compiled.status, false, 0usize, 0usize);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.set_matches_result(t.RegexStatus.unsupported, false, 0usize, 0usize);
    }
    var flat: FlatInput = flatten_text_chunks(chunks);
    if flat.status != t.RegexStatus.ok {
        return t.set_matches_result(flat.status, false, 0usize, 0usize);
    }
    return matches_set_input(compiled, raw_text_input(unsafe { ptrcast<*const u8>(flat.data) }, flat.len, compiled.options), out_pattern_ids, out_capacity);
}

pub fn matches_bytes_set_vectored_compiled(
    compiled: &t.RegexSet,
    chunks: []t.RegexChunk,
    out_pattern_ids: *mut usize,
    out_capacity: usize
