module regex.vm.engine;

part workspace;
part input;
part literal_set;
part start_filter;

import regex.core.results as results;
import regex.core.types as t;
import regex.runtime.alloc as alloc;
import regex.syntax.ascii as ascii;
import unicode.ucd as unicode;

const ACCEPT_NONE: u8 = 0u8;
const ACCEPT_DEFERRED: u8 = 1u8;
const ACCEPT_READY: u8 = 2u8;
const ASCII_BYTE_MAX: usize = 0x7fusize;

trait RegexVmProgram {
    fn state_storage(self: &Self) -> *mut t.State;
    fn range_storage(self: &Self) -> *mut t.ClassRange;
    fn state_count(self: &Self) -> usize;
    fn input_mode(self: &Self) -> u8;
    fn start_state(self: &Self) -> usize;
}

impl RegexVmProgram for t.Regex {
    fn state_storage(self: &t.Regex) -> *mut t.State {
        return self.states;
    }

    fn range_storage(self: &t.Regex) -> *mut t.ClassRange {
        return self.ranges;
    }

    fn state_count(self: &t.Regex) -> usize {
        return self.state_len;
    }

    fn input_mode(self: &t.Regex) -> u8 {
        return self.mode;
    }

    fn start_state(self: &t.Regex) -> usize {
        return self.start;
    }
}

impl RegexVmProgram for t.RegexSet {
    fn state_storage(self: &t.RegexSet) -> *mut t.State {
        return self.states;
    }

    fn range_storage(self: &t.RegexSet) -> *mut t.ClassRange {
        return self.ranges;
    }

    fn state_count(self: &t.RegexSet) -> usize {
        return self.state_len;
    }

    fn input_mode(self: &t.RegexSet) -> u8 {
        return self.mode;
    }

    fn start_state(self: &t.RegexSet) -> usize {
        return self.start;
    }
}

pub fn search_compiled(compiled: &t.Regex, input: str) -> t.MatchResult {
    return search_compiled_from(compiled, input, 0usize);
}

pub fn search_compiled_from(compiled: &t.Regex, input: str, start_offset: usize) -> t.MatchResult {
    return search_compiled_with_match_options(compiled, input, start_offset, t.default_match_options());
}

pub fn search_compiled_with_match_options(
    compiled: &t.Regex,
    input: str,
    start_offset: usize,
    match_options: t.RegexMatchOptions
) -> t.MatchResult {
    if compiled.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, workspace.status);
    }
    return search_with_match_options(compiled, text_input_with_options(input, compiled.options), start_offset, match_options, &mut workspace);
}

pub fn fullmatch_compiled(compiled: &t.Regex, input: str) -> t.MatchResult {
    return fullmatch_compiled_with_match_options(compiled, input, t.default_match_options());
}

pub fn fullmatch_compiled_with_match_options(
    compiled: &t.Regex,
    input: str,
    match_options: t.RegexMatchOptions
) -> t.MatchResult {
    if compiled.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, 0usize, 0usize, workspace.status);
    }
    let found: t.MatchResult = run_at(compiled, input_with_match_options(text_input_with_options(input, compiled.options), match_options), 0usize, true, &mut workspace);
    return apply_not_null(found, match_options);
}

pub fn captures_compiled(compiled: &t.Regex, input: str) -> t.Captures {
    return captures_compiled_from(compiled, input, 0usize);
}

pub fn captures_compiled_from(compiled: &t.Regex, input: str, start_offset: usize) -> t.Captures {
    return captures_compiled_with_match_options(compiled, input, start_offset, t.default_match_options());
}

pub fn captures_compiled_with_match_options(
    compiled: &t.Regex,
    input: str,
    start_offset: usize,
    match_options: t.RegexMatchOptions
) -> t.Captures {
    if compiled.status != t.RegexStatus.ok {
        return t.empty_captures(compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.empty_captures(t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.empty_captures(workspace.status);
    }
    let found: t.MatchResult = search_with_match_options(compiled, text_input_with_options(input, compiled.options), start_offset, match_options, &mut workspace);
    return captures_from_match(compiled, found, workspace.best_caps);
}

pub fn captures_fullmatch_compiled(compiled: &t.Regex, input: str) -> t.Captures {
    return captures_fullmatch_compiled_with_match_options(compiled, input, t.default_match_options());
}

pub fn captures_fullmatch_compiled_with_match_options(
    compiled: &t.Regex,
    input: str,
    match_options: t.RegexMatchOptions
) -> t.Captures {
    if compiled.status != t.RegexStatus.ok {
        return t.empty_captures(compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.empty_captures(t.RegexStatus.unsupported);
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, capture_slot_count(compiled), compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.empty_captures(workspace.status);
    }
    let found: t.MatchResult = apply_not_null(
        run_at(compiled, input_with_match_options(text_input_with_options(input, compiled.options), match_options), 0usize, true, &mut workspace),
        match_options
    );
    return captures_from_match(compiled, found, workspace.best_caps);
}

pub fn workspace_bytes(compiled: &t.Regex) -> usize {
    return workspace_bytes_for(compiled.state_len, capture_slot_count(compiled));
}

pub fn workspace_bytes_for_states(state_count: usize) -> usize {
    return workspace_bytes_for(state_count, 2usize);
}

