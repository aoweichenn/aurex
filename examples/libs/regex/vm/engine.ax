    if compiled.status != t.RegexStatus.ok {
        return t.set_matches_result(compiled.status, false, 0usize, 0usize);
    }
    if compiled.mode != t.MODE_BYTES {
        return t.set_matches_result(t.RegexStatus.unsupported, false, 0usize, 0usize);
    }
    var flat: FlatInput = flatten_byte_chunks(chunks);
    if flat.status != t.RegexStatus.ok {
        return t.set_matches_result(flat.status, false, 0usize, 0usize);
    }
    return matches_set_input(compiled, raw_bytes_input(unsafe { ptrcast<*const u8>(flat.data) }, flat.len, compiled.options), out_pattern_ids, out_capacity);
}

pub fn find_set_vectored_compiled(compiled: &t.RegexSet, chunks: []t.TextChunk) -> t.SetMatchSpan {
    if compiled.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var flat: FlatInput = flatten_text_chunks(chunks);
    if flat.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, flat.status);
    }
    return find_set_input(compiled, raw_text_input(unsafe { ptrcast<*const u8>(flat.data) }, flat.len, compiled.options), 0usize);
}

pub fn scan_set_spans_vectored_compiled(compiled: &t.RegexSet, chunks: []t.TextChunk, callback: t.SetScanCallback) -> t.SetMatchesResult {
    if compiled.status != t.RegexStatus.ok {
        return t.set_matches_result(compiled.status, false, 0usize, 0usize);
    }
    if compiled.mode != t.MODE_TEXT {
        return t.set_matches_result(t.RegexStatus.unsupported, false, 0usize, 0usize);
    }
    var flat: FlatInput = flatten_text_chunks(chunks);
    if flat.status != t.RegexStatus.ok {
        return t.set_matches_result(flat.status, false, 0usize, 0usize);
    }
    return scan_set_all_spans_input(compiled, raw_text_input(unsafe { ptrcast<*const u8>(flat.data) }, flat.len, compiled.options), callback);
}

pub fn scan_set_overlapping_vectored_compiled(compiled: &t.RegexSet, chunks: []t.TextChunk, callback: t.SetScanCallback) -> t.SetMatchesResult {
    return scan_set_spans_vectored_compiled(compiled, chunks, callback);
}

pub fn find_bytes_set_vectored_compiled(compiled: &t.RegexSet, chunks: []t.RegexChunk) -> t.SetMatchSpan {
    if compiled.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, compiled.status);
    }
    if compiled.mode != t.MODE_BYTES {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.unsupported);
    }
    var flat: FlatInput = flatten_byte_chunks(chunks);
    if flat.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, flat.status);
    }
    return find_set_input(compiled, raw_bytes_input(unsafe { ptrcast<*const u8>(flat.data) }, flat.len, compiled.options), 0usize);
}

pub fn scan_bytes_set_spans_vectored_compiled(compiled: &t.RegexSet, chunks: []t.RegexChunk, callback: t.SetScanCallback) -> t.SetMatchesResult {
    if compiled.status != t.RegexStatus.ok {
        return t.set_matches_result(compiled.status, false, 0usize, 0usize);
    }
    if compiled.mode != t.MODE_BYTES {
        return t.set_matches_result(t.RegexStatus.unsupported, false, 0usize, 0usize);
    }
    var flat: FlatInput = flatten_byte_chunks(chunks);
    if flat.status != t.RegexStatus.ok {
        return t.set_matches_result(flat.status, false, 0usize, 0usize);
    }
    return scan_set_all_spans_input(compiled, raw_bytes_input(unsafe { ptrcast<*const u8>(flat.data) }, flat.len, compiled.options), callback);
}

pub fn scan_bytes_set_overlapping_vectored_compiled(compiled: &t.RegexSet, chunks: []t.RegexChunk, callback: t.SetScanCallback) -> t.SetMatchesResult {
    return scan_bytes_set_spans_vectored_compiled(compiled, chunks, callback);
}

fn search_with_workspace(compiled: &t.Regex, input: InputView, start_offset: usize, workspace: &mut Workspace) -> t.MatchResult {
    let input_len: usize = input.len;
    if start_offset > input_len {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
    }
    if starts_with_input_start_assertion(compiled) {
        if start_offset != 0usize {
            return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
        }
        return run_at(compiled, input, 0usize, false, workspace);
    }
    return run_search(compiled, input, align_forward_boundary(input, start_offset), workspace);
}

fn search_with_match_options(
    compiled: &t.Regex,
    input: InputView,
    start_offset: usize,
    match_options: t.RegexMatchOptions,
    workspace: &mut Workspace
) -> t.MatchResult {
    let configured: InputView = input_with_match_options(input, match_options);
    if start_offset > configured.len {
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
    }
    let start: usize = align_forward_boundary(configured, start_offset);
    if match_option_enabled(match_options, t.MATCH_ANCHORED) ||
        match_option_enabled(match_options, t.MATCH_CONTINUOUS) {
        return apply_not_null(run_at(compiled, configured, start, false, workspace), match_options);
    }
    if match_option_enabled(match_options, t.MATCH_NOT_NULL) {
        var cursor: usize = start;
        while cursor <= configured.len {
            let found: t.MatchResult = search_with_workspace(compiled, configured, cursor, workspace);
            if found.status != t.RegexStatus.ok || !found.matched {
                return found;
            }
            if found.end > found.start {
                return found;
            }
            if found.end >= configured.len {
                return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
            }
            cursor = next_boundary(configured, found.end);
        }
        return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
    }
    return search_with_workspace(compiled, configured, start, workspace);
}

fn matches_set_input(
    compiled: &t.RegexSet,
    input: InputView,
    out_pattern_ids: *mut usize,
    out_capacity: usize
) -> t.SetMatchesResult {
    if compiled.pattern_count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    let matched: *mut bool = alloc.alloc_zeroed<bool>(compiled.pattern_count, sizeof<bool>());
    if matched == null {
        return t.set_matches_result(t.RegexStatus.out_of_memory, false, 0usize, 0usize);
    }
    defer alloc.free_typed<bool>(matched);

    if set_has_literal_automaton(compiled) {
        var literal_matched_count: usize = 0usize;
        let literal_matched_count_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut literal_matched_count)) };
        let literal_status: t.RegexStatus = run_literal_set_search(compiled, input, matched, literal_matched_count_ptr);
        if literal_status != t.RegexStatus.ok {
            return t.set_matches_result(literal_status, false, literal_matched_count, 0usize);
        }
        if literal_matched_count == 0usize {
            return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
        }
        let literal_written: usize = write_set_matches(matched, compiled.pattern_count, out_pattern_ids, out_capacity);
        return t.set_matches_result(t.RegexStatus.ok, true, literal_matched_count, literal_written);
    }

    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, 2usize, compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.set_matches_result(workspace.status, false, 0usize, 0usize);
    }

    var matched_count: usize = 0usize;
    let matched_count_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut matched_count)) };
    run_set_search(compiled, input, &mut workspace, matched, matched_count_ptr);
    if workspace.status != t.RegexStatus.ok {
        return t.set_matches_result(workspace.status, false, matched_count, 0usize);
    }
    if matched_count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    let written: usize = write_set_matches(matched, compiled.pattern_count, out_pattern_ids, out_capacity);
    return t.set_matches_result(t.RegexStatus.ok, true, matched_count, written);
}

fn find_set_input(compiled: &t.RegexSet, input: InputView, start_offset: usize) -> t.SetMatchSpan {
    if compiled.pattern_count == 0usize {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.no_match);
    }
    if start_offset > input.len {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.no_match);
    }
    if set_has_literal_automaton(compiled) {
        return run_literal_set_find(compiled, input, align_forward_boundary(input, start_offset));
    }
    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, 2usize, compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, workspace.status);
    }
    return run_set_find(compiled, input, align_forward_boundary(input, start_offset), start_offset, &mut workspace);
}

fn scan_set_input(compiled: &t.RegexSet, input: InputView, callback: t.SetScanCallback) -> t.SetMatchesResult {
    if set_has_literal_automaton(compiled) {
        return scan_literal_set_input(compiled, input, callback);
    }
    var cursor: usize = 0usize;
    var count: usize = 0usize;
    while cursor <= input.len {
        let found: t.SetMatchSpan = find_set_input(compiled, input, cursor);
        if found.status == t.RegexStatus.no_match || !found.matched {
            if count == 0usize {
                return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
            }
            return t.set_matches_result(t.RegexStatus.ok, true, count, count);
        }
        if found.status != t.RegexStatus.ok {
            return t.set_matches_result(found.status, count > 0usize, count, count);
        }
        let status: t.RegexStatus = callback(found.pattern_id, found.start, found.end);
        if status != t.RegexStatus.ok {
            return t.set_matches_result(status, count > 0usize, count, count);
        }
        count += 1usize;
        cursor = next_match_cursor(input, found.start, found.end);
    }
    if count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    return t.set_matches_result(t.RegexStatus.ok, true, count, count);
}

fn scan_set_all_spans_input(compiled: &t.RegexSet, input: InputView, callback: t.SetScanCallback) -> t.SetMatchesResult {
    if compiled.pattern_count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    if set_has_literal_automaton(compiled) {
        return scan_literal_set_all_spans(compiled, input, callback);
    }
    let emitted: *mut bool = alloc.alloc_zeroed<bool>(compiled.pattern_count, sizeof<bool>());
    if emitted == null {
        return t.set_matches_result(t.RegexStatus.out_of_memory, false, 0usize, 0usize);
    }
    defer alloc.free_typed<bool>(emitted);

    var workspace: Workspace = create_workspace_with_limit(compiled.state_len, 2usize, compiled.options.max_workspace_states);
    if workspace.status != t.RegexStatus.ok {
        return t.set_matches_result(workspace.status, false, 0usize, 0usize);
    }
    workspace.newline_mode = input.newline_mode;
    let start_filter: StartFilter = build_set_start_filter(compiled, &mut workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.set_matches_result(workspace.status, false, 0usize, 0usize);
    }

    var cursor: usize = 0usize;
    var count: usize = 0usize;
    let count_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut count)) };
    while cursor <= input.len {
        let status: t.RegexStatus = run_set_collect_at(compiled, input, cursor, start_filter, &mut workspace, emitted, callback, count_ptr);
        if status != t.RegexStatus.ok {
            return t.set_matches_result(status, count > 0usize, count, count);
        }
        if cursor >= input.len {
            break;
        }
        cursor = next_boundary(input, cursor);
    }
    if count == 0usize {
        return t.set_matches_result(t.RegexStatus.no_match, false, 0usize, 0usize);
    }
    return t.set_matches_result(t.RegexStatus.ok, true, count, count);
}

fn run_set_collect_at(
    compiled: &t.RegexSet,
    input: InputView,
    start: usize,
    start_filter: StartFilter,
    workspace: &mut Workspace,
    emitted: *mut bool,
    callback: t.SetScanCallback,
    count: *mut usize
) -> t.RegexStatus {
    clear_marks(workspace);
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    let current_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut next_len)) };
    if set_start_filter_allows(compiled, start_filter, input, start, workspace) &&
        set_literal_prefix_matches(compiled, start_filter, input, start, workspace) {
        init_capture_seed_with_search_start(workspace.seed_caps, workspace.capture_slot_count, start, start);
        add_set_closure(
            compiled,
            workspace.current,
            workspace.current_caps,
            current_len_ptr,
            workspace,
            stamp,
            compiled.start,
            start,
            input,
            input.len,
            workspace.seed_caps
        );
    }
    if workspace.status != t.RegexStatus.ok {
        return workspace.status;
    }
    var position: usize = start;
    while true {
        clear_emitted_patterns(emitted, compiled.pattern_count);
        let status: t.RegexStatus = emit_set_accepts(compiled, workspace, workspace.current, workspace.current_caps, current_len, position, emitted, callback, count);
        if status != t.RegexStatus.ok {
            return status;
        }
        if position >= input.len || current_len == 0usize {
            break;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        for index in range(current_len) {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = transition_out<t.RegexSet>(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_set_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input.len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return workspace.status;
                }
            }
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
    return t.RegexStatus.ok;
}

fn emit_set_accepts(
    compiled: &t.RegexSet,
    workspace: &Workspace,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: usize,
    position: usize,
    emitted: *mut bool,
    callback: t.SetScanCallback,
    count: *mut usize
) -> t.RegexStatus {
    for index in range(list_len) {
        let state_id: usize = unsafe { list[index] };
        if state_id < compiled.state_len && unsafe { compiled.states[state_id].opcode } == t.OP_MATCH {
            let pattern_id: usize = unsafe { compiled.states[state_id].value };
            if pattern_id < compiled.pattern_count && !unsafe { emitted[pattern_id] } {
                let row: *mut usize = capture_row_ptr(list_caps, index, workspace.capture_slot_count);
                let start: usize = unsafe { row[0usize] };
                let status: t.RegexStatus = callback(pattern_id, start, position);
                if status != t.RegexStatus.ok {
                    return status;
                }
                unsafe {
                    emitted[pattern_id] = true;
                    *count = *count + 1usize;
                }
            }
        }
    }
    return t.RegexStatus.ok;
}

fn clear_emitted_patterns(emitted: *mut bool, pattern_count: usize) -> void {
    for index in range(pattern_count) {
        unsafe {
            emitted[index] = false;
        }
    }
}

fn run_set_search(
    compiled: &t.RegexSet,
    input: InputView,
    workspace: &mut Workspace,
    matched: *mut bool,
    matched_count: *mut usize
) -> void {
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    let start_filter: StartFilter = build_set_start_filter(compiled, workspace);
    if workspace.status != t.RegexStatus.ok {
        return;
    }
    clear_marks(workspace);
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    let input_len: usize = input.len;
    let current_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut next_len)) };
    var position: usize = 0usize;
    while true {
        if current_len == 0usize && start_filter.byte_filter_enabled {
            position = advance_to_next_start_byte_candidate(start_filter, input, position, workspace);
        } else if current_len == 0usize && start_filter.literal_prefix_enabled {
            position = advance_to_next_set_prefix_candidate(compiled, start_filter, input, position, workspace);
        }
        if set_start_filter_allows(compiled, start_filter, input, position, workspace) &&
            set_literal_prefix_matches(compiled, start_filter, input, position, workspace) {
            init_capture_seed_with_search_start(workspace.seed_caps, workspace.capture_slot_count, position, 0usize);
            add_set_closure(
                compiled,
                workspace.current,
                workspace.current_caps,
                current_len_ptr,
                workspace,
                stamp,
                compiled.start,
                position,
                input,
                input_len,
                workspace.seed_caps
            );
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
        update_set_accepts(compiled, workspace.current, current_len, matched, matched_count);
        if unsafe { *matched_count } >= compiled.pattern_count {
            return;
        }
        if position >= input_len {
            return;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        for index in range(current_len) {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = transition_out<t.RegexSet>(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_set_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input_len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return;
                }
            }
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
}

fn run_set_find(
    compiled: &t.RegexSet,
    input: InputView,
    start: usize,
    search_start: usize,
    workspace: &mut Workspace
) -> t.SetMatchSpan {
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    let start_filter: StartFilter = build_set_start_filter(compiled, workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.set_match_span(false, t.NO_CAPTURE, start, start, workspace.status);
    }
    clear_marks(workspace);
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    var best_matched: bool = false;
    var best_pattern_id: usize = t.NO_CAPTURE;
    var best_start: usize = start;
    var best_end: usize = start;
    let input_len: usize = input.len;
    let current_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut next_len)) };
    let best_matched_ptr: *mut bool = unsafe { ptrat<*mut bool>(ptraddr(&mut best_matched)) };
    let best_pattern_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut best_pattern_id)) };
    let best_start_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut best_start)) };
    let best_end_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut best_end)) };
    var position: usize = start;
    while true {
        if !best_matched && current_len == 0usize && start_filter.byte_filter_enabled {
            position = advance_to_next_start_byte_candidate(start_filter, input, position, workspace);
        } else if !best_matched && current_len == 0usize && start_filter.literal_prefix_enabled {
            position = advance_to_next_set_prefix_candidate(compiled, start_filter, input, position, workspace);
        }
        if best_matched && !list_has_start_at_or_before(workspace.current_caps, current_len, workspace.capture_slot_count, best_start) {
            return t.set_match_span(true, best_pattern_id, best_start, best_end, t.RegexStatus.ok);
        }
        if !best_matched && set_start_filter_allows(compiled, start_filter, input, position, workspace) &&
            set_literal_prefix_matches(compiled, start_filter, input, position, workspace) {
            init_capture_seed_with_search_start(workspace.seed_caps, workspace.capture_slot_count, position, search_start);
            add_set_closure(
                compiled,
                workspace.current,
                workspace.current_caps,
                current_len_ptr,
                workspace,
                stamp,
                compiled.start,
                position,
                input,
                input_len,
                workspace.seed_caps
            );
        }
        if workspace.status != t.RegexStatus.ok {
            return t.set_match_span(false, t.NO_CAPTURE, position, position, workspace.status);
        }
        update_set_best_accept(
            compiled,
            workspace,
            workspace.current,
            workspace.current_caps,
            current_len,
            position,
            best_matched_ptr,
            best_pattern_ptr,
            best_start_ptr,
            best_end_ptr
        );
        if position >= input_len {
            break;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        for index in range(current_len) {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = transition_out<t.RegexSet>(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_set_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input_len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return t.set_match_span(false, t.NO_CAPTURE, position, position, workspace.status);
                }
            }
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
    if best_matched {
        return t.set_match_span(true, best_pattern_id, best_start, best_end, t.RegexStatus.ok);
    }
    return t.set_match_span(false, t.NO_CAPTURE, 0usize, 0usize, t.RegexStatus.no_match);
}

fn run_search(compiled: &t.Regex, input: InputView, start: usize, workspace: &mut Workspace) -> t.MatchResult {
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    let start_filter: StartFilter = build_start_filter(compiled, workspace);
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, start, start, workspace.status);
    }
    clear_marks(workspace);
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    var best_matched: bool = false;
    var best_start: usize = start;
    var best_end: usize = start;
    let input_len: usize = input.len;
    let current_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut next_len)) };
    let best_matched_ptr: *mut bool = unsafe { ptrat<*mut bool>(ptraddr(&mut best_matched)) };
    let best_start_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut best_start)) };
    let best_end_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut best_end)) };
    var position: usize = start;
    while true {
        if !best_matched && current_len == 0usize && start_filter.byte_filter_enabled {
            position = advance_to_next_start_byte_candidate(start_filter, input, position, workspace);
        } else if !best_matched && current_len == 0usize && start_filter.literal_prefix_enabled {
            position = advance_to_next_prefix_candidate(compiled, start_filter, input, position, workspace);
        }
        if best_matched && !list_has_start_at_or_before(workspace.current_caps, current_len, workspace.capture_slot_count, best_start) {
            return t.match_result(true, best_start, best_end, t.RegexStatus.ok);
        }
        if !best_matched && start_filter_allows(compiled, start_filter, input, position, workspace) &&
            literal_prefix_matches(compiled, start_filter, input, position, workspace) {
            init_capture_seed_with_search_start(workspace.seed_caps, workspace.capture_slot_count, position, start);
            add_closure(
                compiled,
                workspace.current,
                workspace.current_caps,
                current_len_ptr,
                workspace,
                stamp,
                compiled.start,
                position,
                input,
                input_len,
                workspace.seed_caps
            );
        }
        if workspace.status != t.RegexStatus.ok {
            return t.match_result(false, position, position, workspace.status);
        }
        let accept_state: u8 = update_search_accept(
            compiled,
            workspace,
            workspace.current,
            workspace.current_caps,
            current_len,
            position,
            input,
            input_len,
            best_matched_ptr,
            best_start_ptr,
            best_end_ptr
        );
        if accept_state == ACCEPT_READY {
            return t.match_result(true, best_start, best_end, t.RegexStatus.ok);
        }
        if position >= input_len {
            break;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        for index in range(current_len) {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = transition_out<t.Regex>(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input_len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return t.match_result(false, position, position, workspace.status);
                }
            }
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
    if best_matched {
        return t.match_result(true, best_start, best_end, t.RegexStatus.ok);
    }
    return t.match_result(false, 0usize, 0usize, t.RegexStatus.no_match);
}

fn add_set_closure(
    compiled: &t.RegexSet,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: *mut usize,
    workspace: &mut Workspace,
    stamp: usize,
    first_state: usize,
    position: usize,
    input: InputView,
    input_len: usize,
    source_caps: *mut usize
) -> void {
    var stack_len: usize = 0usize;
    let stack_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut stack_len)) };
    push_set_state(workspace, stack_len_ptr, stamp, first_state, source_caps);
    while stack_len > 0usize {
        stack_len -= 1usize;
        let state_id: usize = unsafe { workspace.stack[stack_len] };
        if state_id == t.NO_STATE || state_id >= compiled.state_len {
            continue;
        }
        let row: *mut usize = capture_row_ptr(workspace.stack_caps, stack_len, workspace.capture_slot_count);
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_EPSILON || opcode == t.OP_SAVE {
            push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_SPLIT {
            push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out2 }, row);
            push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_ASSERT_START {
            if assert_start_matches(input, position, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_END {
            if assert_end_matches(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_ABSOLUTE_START {
            if position == 0usize {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_ABSOLUTE_END {
            if position == input_len {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_BOUNDARY {
            if is_word_boundary_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_NOT_WORD_BOUNDARY {
            if !is_word_boundary_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_START {
            if is_word_start_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_END {
            if is_word_end_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_SEARCH_START {
            if workspace.capture_slot_count > 1usize && position == unsafe { row[1usize] } {
                push_set_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else {
            if unsafe { *list_len } >= workspace.capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return;
            }
            unsafe {
                list[*list_len] = state_id;
            }
            copy_capture_row(capture_row_ptr(list_caps, unsafe { *list_len }, workspace.capture_slot_count), row, workspace.capture_slot_count);
            unsafe {
                *list_len = *list_len + 1usize;
            }
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
    }
}

fn push_set_state(workspace: &mut Workspace, stack_len: *mut usize, stamp: usize, state_id: usize, source_caps: *mut usize) -> void {
    if state_id == t.NO_STATE || state_id >= workspace.capacity {
        return;
    }
    if unsafe { workspace.marks[state_id] } == stamp {
        return;
    }
    if unsafe { *stack_len } >= workspace.capacity {
        workspace.status = t.RegexStatus.workspace_too_large;
        return;
    }
    unsafe {
        workspace.marks[state_id] = stamp;
        workspace.stack[*stack_len] = state_id;
    }
    copy_capture_row(capture_row_ptr(workspace.stack_caps, unsafe { *stack_len }, workspace.capture_slot_count), source_caps, workspace.capture_slot_count);
    unsafe {
        *stack_len = *stack_len + 1usize;
    }
}

fn update_set_accepts(
    compiled: &t.RegexSet,
    list: *mut usize,
    list_len: usize,
    matched: *mut bool,
    matched_count: *mut usize
) -> void {
    for index in range(list_len) {
        let state_id: usize = unsafe { list[index] };
        if state_id < compiled.state_len && unsafe { compiled.states[state_id].opcode } == t.OP_MATCH {
            let pattern_id: usize = unsafe { compiled.states[state_id].value };
            if pattern_id < compiled.pattern_count && !unsafe { matched[pattern_id] } {
                unsafe {
                    matched[pattern_id] = true;
                    *matched_count = *matched_count + 1usize;
                }
            }
        }
    }
}

fn update_set_best_accept(
    compiled: &t.RegexSet,
    workspace: &Workspace,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: usize,
    position: usize,
    best_matched: *mut bool,
    best_pattern_id: *mut usize,
    best_start: *mut usize,
    best_end: *mut usize
) -> void {
    for index in range(list_len) {
        let state_id: usize = unsafe { list[index] };
        if state_id < compiled.state_len && unsafe { compiled.states[state_id].opcode } == t.OP_MATCH {
            let pattern_id: usize = unsafe { compiled.states[state_id].value };
            let candidate_caps: *mut usize = capture_row_ptr(list_caps, index, workspace.capture_slot_count);
            let candidate_start: usize = unsafe { candidate_caps[0usize] };
            let replace: bool = !unsafe { *best_matched } ||
                candidate_start < unsafe { *best_start } ||
                (candidate_start == unsafe { *best_start } && position < unsafe { *best_end }) ||
                (candidate_start == unsafe { *best_start } && position == unsafe { *best_end } && pattern_id < unsafe { *best_pattern_id });
            if pattern_id < compiled.pattern_count && replace {
                unsafe {
                    *best_matched = true;
                    *best_pattern_id = pattern_id;
                    *best_start = candidate_start;
                    *best_end = position;
                }
            }
        }
    }
}

fn captures_from_match(compiled: &t.Regex, found: t.MatchResult, capture_slots: *mut usize) -> t.Captures {
    if found.status != t.RegexStatus.ok {
        return t.empty_captures(found.status);
    }
    if !found.matched {
        return t.empty_captures(t.RegexStatus.no_match);
    }
    return results.create_captures(compiled, found.start, found.end, capture_slots);
}

fn captures_from_input_into(
    compiled: &t.Regex,
    input: InputView,
    start_offset: usize,
    workspace: &mut Workspace,
    captures: &mut t.Captures
) -> t.RegexStatus {
    if workspace.status != t.RegexStatus.ok {
        results.reset_captures(captures, workspace.status);
        return workspace.status;
    }
    let found: t.MatchResult = search_with_workspace(compiled, input, start_offset, workspace);
    if found.status != t.RegexStatus.ok {
        results.reset_captures(captures, found.status);
        return found.status;
    }
    if !found.matched {
        results.reset_captures(captures, t.RegexStatus.no_match);
        return t.RegexStatus.no_match;
    }
    let status: t.RegexStatus = results.fill_captures(compiled, found.start, found.end, workspace.best_caps, captures);
    return status;
}

fn run_at(compiled: &t.Regex, input: InputView, start: usize, require_end: bool, workspace: &mut Workspace) -> t.MatchResult {
    workspace.status = t.RegexStatus.ok;
    workspace.newline_mode = input.newline_mode;
    clear_marks(workspace);
    init_capture_seed(workspace.best_caps, workspace.capture_slot_count, start);
    var stamp: usize = 1usize;
    var current_len: usize = 0usize;
    var next_len: usize = 0usize;
    var best_matched: bool = false;
    var best_end: usize = start;
    let input_len: usize = input.len;
    let current_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut current_len)) };
    let next_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut next_len)) };
    add_closure(
        compiled,
        workspace.current,
        workspace.current_caps,
        current_len_ptr,
        workspace,
        stamp,
        compiled.start,
        start,
        input,
        input_len,
        workspace.best_caps
    );
    if workspace.status != t.RegexStatus.ok {
        return t.match_result(false, start, start, workspace.status);
    }
    var position: usize = start;
    while true {
        let accept_state: u8 = update_best_accept(
            compiled,
            workspace,
            workspace.current,
            workspace.current_caps,
            current_len,
            position,
            input,
            input_len
        );
        if accept_state != ACCEPT_NONE {
            best_matched = true;
            best_end = position;
            if !require_end && accept_state == ACCEPT_READY {
                return t.match_result(true, start, position, t.RegexStatus.ok);
            }
        }
        if position >= input_len {
            break;
        }
        if current_len == 0usize {
            break;
        }
        stamp += 1usize;
        next_len = 0usize;
        let decoded: InputDecode = decode_at(input, position);
        let value: usize = decoded.value;
        let next_position: usize = decoded.next;
        for index in range(current_len) {
            let state_id: usize = unsafe { workspace.current[index] };
            let out1: usize = transition_out<t.Regex>(compiled, state_id, value, workspace);
            if out1 != t.NO_STATE {
                add_closure(
                    compiled,
                    workspace.next,
                    workspace.next_caps,
                    next_len_ptr,
                    workspace,
                    stamp,
                    out1,
                    next_position,
                    input,
                    input_len,
                    capture_row_ptr(workspace.current_caps, index, workspace.capture_slot_count)
                );
                if workspace.status != t.RegexStatus.ok {
                    return t.match_result(false, start, start, workspace.status);
                }
            }
        }
        swap_lists(workspace);
        current_len = next_len;
        position = next_position;
    }
    if best_matched {
        if !require_end || best_end == input_len {
            return t.match_result(true, start, best_end, t.RegexStatus.ok);
        }
    }
    return t.match_result(false, start, start, t.RegexStatus.no_match);
}

fn add_closure(
    compiled: &t.Regex,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: *mut usize,
    workspace: &mut Workspace,
    stamp: usize,
    first_state: usize,
    position: usize,
    input: InputView,
    input_len: usize,
    source_caps: *mut usize
) -> void {
    var stack_len: usize = 0usize;
    let stack_len_ptr: *mut usize = unsafe { ptrat<*mut usize>(ptraddr(&mut stack_len)) };
    push_state(workspace, stack_len_ptr, stamp, first_state, source_caps);
    while stack_len > 0usize {
        stack_len -= 1usize;
        let state_id: usize = unsafe { workspace.stack[stack_len] };
        if state_id == t.NO_STATE || state_id >= compiled.state_len {
            continue;
        }
        let row: *mut usize = capture_row_ptr(workspace.stack_caps, stack_len, workspace.capture_slot_count);
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_EPSILON {
            push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_SPLIT {
            push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out2 }, row);
            push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_SAVE {
            let slot: usize = unsafe { compiled.states[state_id].class_start };
            if slot >= workspace.capture_slot_count {
                workspace.status = t.RegexStatus.program_too_large;
                return;
            }
            unsafe {
                row[slot] = position;
            }
            push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
        } else if opcode == t.OP_ASSERT_START {
            if assert_start_matches(input, position, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_END {
            if assert_end_matches(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_ABSOLUTE_START {
            if position == 0usize {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_ABSOLUTE_END {
            if position == input_len {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_BOUNDARY {
            if is_word_boundary_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_NOT_WORD_BOUNDARY {
            if !is_word_boundary_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_START {
            if is_word_start_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_WORD_END {
            if is_word_end_flags(input, position, input_len, unsafe { compiled.states[state_id].flags }) {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else if opcode == t.OP_ASSERT_SEARCH_START {
            if workspace.capture_slot_count > 1usize && position == unsafe { row[1usize] } {
                push_state(workspace, stack_len_ptr, stamp, unsafe { compiled.states[state_id].out1 }, row);
            }
        } else {
            if unsafe { *list_len } >= workspace.capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return;
            }
            unsafe {
                list[*list_len] = state_id;
            }
            copy_capture_row(capture_row_ptr(list_caps, unsafe { *list_len }, workspace.capture_slot_count), row, workspace.capture_slot_count);
            unsafe {
                *list_len = *list_len + 1usize;
            }
        }
        if workspace.status != t.RegexStatus.ok {
            return;
        }
    }
}

fn push_state(workspace: &mut Workspace, stack_len: *mut usize, stamp: usize, state_id: usize, source_caps: *mut usize) -> void {
    if state_id == t.NO_STATE || state_id >= workspace.capacity {
        return;
    }
    if unsafe { workspace.marks[state_id] } == stamp {
        return;
    }
    if unsafe { *stack_len } >= workspace.capacity {
        workspace.status = t.RegexStatus.workspace_too_large;
        return;
    }
    unsafe {
        workspace.marks[state_id] = stamp;
        workspace.stack[*stack_len] = state_id;
    }
    copy_capture_row(capture_row_ptr(workspace.stack_caps, unsafe { *stack_len }, workspace.capture_slot_count), source_caps, workspace.capture_slot_count);
    unsafe {
        *stack_len = *stack_len + 1usize;
    }
}

fn starts_with_input_start_assertion(compiled: &t.Regex) -> bool {
    var steps: usize = 0usize;
    var state_id: usize = compiled.start;
    while state_id != t.NO_STATE && state_id < compiled.state_len {
        let opcode: u8 = unsafe { compiled.states[state_id].opcode };
        if opcode == t.OP_EPSILON || opcode == t.OP_SAVE {
            state_id = unsafe { compiled.states[state_id].out1 };
        } else if opcode == t.OP_ASSERT_START {
            return !has_flag(unsafe { compiled.states[state_id].flags }, t.FLAG_MULTILINE);
        } else {
            return opcode == t.OP_ASSERT_ABSOLUTE_START;
        }
        steps += 1usize;
        if steps > compiled.state_len {
            return false;
        }
    }
    return false;
}

fn update_best_accept(
    compiled: &t.Regex,
    workspace: &mut Workspace,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: usize,
    position: usize,
    input: InputView,
    input_len: usize
) -> u8 {
    for index in range(list_len) {
        let state_id: usize = unsafe { list[index] };
        if state_id == compiled.accept {
            copy_capture_row(workspace.best_caps, capture_row_ptr(list_caps, index, workspace.capture_slot_count), workspace.capture_slot_count);
            if workspace.capture_slot_count > 1usize {
                unsafe {
                    workspace.best_caps[1usize] = position;
                }
            }
            if has_higher_priority_consumer(compiled, list, index, input, position, input_len, workspace) {
                return ACCEPT_DEFERRED;
            }
            return ACCEPT_READY;
        }
    }
    return ACCEPT_NONE;
}

fn update_search_accept(
    compiled: &t.Regex,
    workspace: &mut Workspace,
    list: *mut usize,
    list_caps: *mut usize,
    list_len: usize,
    position: usize,
    input: InputView,
    input_len: usize,
    best_matched: *mut bool,
    best_start: *mut usize,
    best_end: *mut usize
) -> u8 {
    for index in range(list_len) {
        let state_id: usize = unsafe { list[index] };
        if state_id == compiled.accept {
            let candidate_caps: *mut usize = capture_row_ptr(list_caps, index, workspace.capture_slot_count);
            let candidate_start: usize = unsafe { candidate_caps[0usize] };
            if !unsafe { *best_matched } || candidate_start < unsafe { *best_start } ||
                candidate_start == unsafe { *best_start } {
                copy_capture_row(workspace.best_caps, candidate_caps, workspace.capture_slot_count);
                if workspace.capture_slot_count > 1usize {
                    unsafe {
                        workspace.best_caps[1usize] = position;
                    }
                }
                unsafe {
                    *best_matched = true;
                    *best_start = candidate_start;
                    *best_end = position;
                }
            }
            if has_higher_priority_consumer(compiled, list, index, input, position, input_len, workspace) {
                return ACCEPT_DEFERRED;
            }
            return ACCEPT_READY;
        }
    }
    return ACCEPT_NONE;
}

fn has_higher_priority_consumer(
    compiled: &t.Regex,
    list: *mut usize,
    accept_index: usize,
    input: InputView,
    position: usize,
    input_len: usize,
    workspace: &mut Workspace
) -> bool {
    if position >= input_len {
        return false;
    }
    let value: usize = decode_at(input, position).value;
    for index in range(accept_index) {
        let state_id: usize = unsafe { list[index] };
        if transition_out<t.Regex>(compiled, state_id, value, workspace) != t.NO_STATE {
            return true;
        }
    }
    return false;
}

fn transition_out<P>(
    program: &P,
    state_id: usize,
    value: usize,
    workspace: &mut Workspace
) -> usize where P: RegexVmProgram {
    let states: *mut t.State = program.state_storage();
    if state_matches<P>(program, state_id, value, workspace) {
        return unsafe { states[state_id].out1 };
    }
    if program.input_mode() != t.MODE_TEXT {
        return t.NO_STATE;
    }
    return full_fold_sequence_out(unsafe { ptrcast<*const t.State>(states) }, program.state_count(), state_id, value);
}

fn state_matches<P>(
    program: &P,
    state_id: usize,
    value: usize,
    workspace: &mut Workspace
) -> bool where P: RegexVmProgram {
    let states: *mut t.State = program.state_storage();
    let opcode: u8 = unsafe { states[state_id].opcode };
    if opcode == t.OP_LITERAL {
        let expected: usize = unsafe { states[state_id].value };
        if has_flag(unsafe { states[state_id].flags }, t.FLAG_CASE_INSENSITIVE) {
            return folded_equals(expected, value, has_flag(unsafe { states[state_id].flags }, t.FLAG_ASCII));
        }
        return expected == value;
    }
    if opcode == t.OP_ANY {
        return has_flag(unsafe { states[state_id].flags }, t.FLAG_DOTALL) || !is_line_break_mode(workspace.newline_mode, value);
    }
    if opcode == t.OP_CLASS {
        return class_state_matches<P>(program, state_id, value, workspace);
    }
    return false;
}

fn full_fold_sequence_out(states: *const t.State, state_len: usize, state_id: usize, value: usize) -> usize {
    let fold_len: usize = unicode.full_fold_len(value);
    if fold_len <= 1usize {
        return t.NO_STATE;
    }
    var current: usize = state_id;
    for index in range(fold_len) {
        if current == t.NO_STATE || current >= state_len {
            return t.NO_STATE;
        }
        let state: t.State = unsafe { states[current] };
        if state.opcode != t.OP_LITERAL ||
            !has_flag(state.flags, t.FLAG_CASE_INSENSITIVE) ||
            has_flag(state.flags, t.FLAG_ASCII) {
            return t.NO_STATE;
        }
        if !folded_equals(state.value, unicode.full_fold_at(value, index), false) {
            return t.NO_STATE;
        }
        if index + 1usize == fold_len {
            return state.out1;
        }
        current = next_full_fold_literal(states, state_len, state.out1);
    }
    return t.NO_STATE;
}

fn next_full_fold_literal(states: *const t.State, state_len: usize, first_state: usize) -> usize {
    var state_id: usize = first_state;
    var steps: usize = 0usize;
    while state_id != t.NO_STATE && state_id < state_len && steps <= state_len {
        let opcode: u8 = unsafe { states[state_id].opcode };
        if opcode == t.OP_LITERAL {
            return state_id;
        }
        if opcode != t.OP_EPSILON {
            return t.NO_STATE;
        }
        state_id = unsafe { states[state_id].out1 };
        steps += 1usize;
    }
    return t.NO_STATE;
}

fn class_state_matches<P>(
    program: &P,
    state_id: usize,
    value: usize,
    workspace: &mut Workspace
) -> bool where P: RegexVmProgram {
    let states: *mut t.State = program.state_storage();
    let class_start: usize = unsafe { states[state_id].class_start };
    let class_len: usize = unsafe { states[state_id].class_len };
    let flags: u8 = unsafe { states[state_id].flags };
    let negated: bool = has_flag(flags, t.FLAG_CLASS_NEGATED);
    let matched: bool = class_expr_matches(
        program.range_storage(),
        class_start,
        class_len,
        value,
        workspace,
        has_flag(flags, t.FLAG_CASE_INSENSITIVE),
        has_flag(flags, t.FLAG_ASCII)
    );
    if negated {
        return !matched;
    }
    return matched;
}

fn class_expr_matches(
    ranges: *mut t.ClassRange,
    class_start: usize,
    class_len: usize,
    value: usize,
    workspace: &mut Workspace,
    folded: bool,
    ascii_mode: bool
) -> bool {
    var depth: usize = 0usize;
    for offset in range(class_len) {
        let range_index: usize = class_start + offset;
        let kind: u8 = unsafe { ranges[range_index].kind };
        let first: usize = unsafe { ranges[range_index].first };
        let last: usize = unsafe { ranges[range_index].last };
        if kind == t.CLASS_RANGE_SCALAR || kind == t.CLASS_RANGE_PROPERTY || kind == t.CLASS_RANGE_PROPERTY_NEGATED {
            if depth >= workspace.class_capacity {
                workspace.status = t.RegexStatus.workspace_too_large;
                return false;
            }
            unsafe {
                workspace.class_stack[depth] = class_primitive_matches(kind, first, last, value, folded, ascii_mode);
            }
            depth += 1usize;
        } else if kind == t.CLASS_EXPR_COMPLEMENT {
            if depth == 0usize {
                return false;
            }
            unsafe {
                workspace.class_stack[depth - 1usize] = !workspace.class_stack[depth - 1usize];
            }
        } else {
            if depth < 2usize {
                return false;
            }
            let right: bool = unsafe { workspace.class_stack[depth - 1usize] };
            let left: bool = unsafe { workspace.class_stack[depth - 2usize] };
            depth -= 1usize;
            unsafe {
                workspace.class_stack[depth - 1usize] = apply_class_expr_op(kind, left, right);
            }
        }
    }
    if depth != 1usize {
        return false;
    }
    return unsafe { workspace.class_stack[0usize] };
}

fn class_primitive_matches(kind: u8, first: usize, last: usize, value: usize, folded: bool, ascii_mode: bool) -> bool {
    if kind == t.CLASS_RANGE_SCALAR {
        if folded {
            if ascii_mode {
                return ascii_fold_equivalent_in_range(value, first, last);
            }
            return unicode.fold_equivalent_in_range(value, first, last);
        }
        return first <= value && value <= last;
    }
    if ascii_mode && is_ascii_shorthand_property(first) {
        let matched_ascii: bool = ascii_property_matches(first, value);
        if kind == t.CLASS_RANGE_PROPERTY {
            return matched_ascii;
        }
        return !matched_ascii;
    }
    if kind == t.CLASS_RANGE_PROPERTY {
        if folded {
            return unicode.property_case_fold_matches(first, value);
        }
        return unicode.property_matches(first, value);
    }
    if folded {
        return !unicode.property_case_fold_matches(first, value);
    }
    return !unicode.property_matches(first, value);
}

fn apply_class_expr_op(kind: u8, left: bool, right: bool) -> bool {
    if kind == t.CLASS_EXPR_UNION {
        return left || right;
    }
    if kind == t.CLASS_EXPR_INTERSECTION {
        return left && right;
    }
    if kind == t.CLASS_EXPR_DIFFERENCE {
        return left && !right;
    }
    if kind == t.CLASS_EXPR_SYMMETRIC_DIFFERENCE {
        return left != right;
    }
    return false;
}

fn has_flag(flags: u8, flag: u8) -> bool {
    return (flags & flag) != t.FLAGS_NONE;
}

fn folded_equals(expected: usize, value: usize, ascii_mode: bool) -> bool {
    if ascii_mode {
        if expected > ASCII_BYTE_MAX || value > ASCII_BYTE_MAX {
            return expected == value;
        }
        return ascii.to_lower(((expected) as u8)) == ascii.to_lower(((value) as u8));
    }
    return unicode.simple_fold(expected) == unicode.simple_fold(value);
}

fn ascii_fold_equivalent_in_range(value: usize, first: usize, last: usize) -> bool {
    if first <= value && value <= last {
        return true;
    }
    if value > ASCII_BYTE_MAX {
        return false;
    }
    let lower: usize = ((ascii.to_lower(((value) as u8))) as usize);
    if first <= lower && lower <= last {
        return true;
    }
    let upper: usize = ((ascii.to_upper(((value) as u8))) as usize);
    return first <= upper && upper <= last;
}

fn is_ascii_shorthand_property(kind: usize) -> bool {
    return kind == unicode.PROPERTY_GC_ND ||
        kind == unicode.PROPERTY_WORD ||
        kind == unicode.PROPERTY_WHITE_SPACE;
}

fn ascii_property_matches(kind: usize, value: usize) -> bool {
    if value > ASCII_BYTE_MAX {
        return false;
    }
    let byte: u8 = ((value) as u8);
    if kind == unicode.PROPERTY_GC_ND {
        return ascii.is_digit(byte);
    }
    if kind == unicode.PROPERTY_WORD {
        return ascii.is_word(byte);
    }
    if kind == unicode.PROPERTY_WHITE_SPACE {
        return ascii.is_ascii_whitespace(byte);
    }
    return unicode.property_matches(kind, value);
}

fn is_line_break(input: InputView, value: usize) -> bool {
    return is_line_break_mode(input.newline_mode, value);
}

fn is_line_break_mode(newline_mode: u8, value: usize) -> bool {
    if newline_mode == t.NEWLINE_LF {
        return value == unicode.LINE_FEED;
    }
    if newline_mode == t.NEWLINE_CRLF {
        return value == unicode.LINE_FEED || value == unicode.CARRIAGE_RETURN;
    }
    return unicode.is_line_break_scalar(value);
}

fn assert_start_matches(input: InputView, position: usize, flags: u8) -> bool {
    if is_line_start(input, position) {
        if position == 0usize {
            return true;
        }
        return has_flag(flags, t.FLAG_MULTILINE);
    }
    return false;
}

fn assert_end_matches(input: InputView, position: usize, input_len: usize, flags: u8) -> bool {
    if is_line_end(input, position, input_len) {
        if position == input_len {
            return true;
        }
        return has_flag(flags, t.FLAG_MULTILINE);
    }
    return false;
}

fn is_line_start(input: InputView, position: usize) -> bool {
    if position == 0usize {
        return !input_match_flag_enabled(input, t.MATCH_NOT_BOL);
    }
    let previous: InputDecode = previous_decode(input, position);
    return previous.valid && is_line_break(input, previous.value);
}

fn is_line_end(input: InputView, position: usize, input_len: usize) -> bool {
    if position == input_len {
        return !input_match_flag_enabled(input, t.MATCH_NOT_EOL);
    }
    let current: InputDecode = decode_at(input, position);
    return current.valid && is_line_break(input, current.value);
}

fn is_word_boundary_flags(input: InputView, position: usize, input_len: usize, flags: u8) -> bool {
    let left: InputDecode = previous_decode(input, position);
    let right: InputDecode = decode_at(input, position);
    let left_is_word: bool = position > 0usize && left.valid && is_word_flags(input, left.value, flags);
    let right_is_word: bool = position < input_len && right.valid && is_word_flags(input, right.value, flags);
    let boundary: bool = left_is_word != right_is_word;
    if boundary && position == 0usize && right_is_word && input_match_flag_enabled(input, t.MATCH_NOT_BOW) {
        return false;
    }
    if boundary && position == input_len && left_is_word && input_match_flag_enabled(input, t.MATCH_NOT_EOW) {
        return false;
    }
    return boundary;
}

fn is_word_start_flags(input: InputView, position: usize, input_len: usize, flags: u8) -> bool {
    if position >= input_len {
        return false;
    }
    if position == 0usize && input_match_flag_enabled(input, t.MATCH_NOT_BOW) {
        return false;
    }
    let left: InputDecode = previous_decode(input, position);
    let right: InputDecode = decode_at(input, position);
    let left_is_word: bool = position > 0usize && left.valid && is_word_flags(input, left.value, flags);
    let right_is_word: bool = right.valid && is_word_flags(input, right.value, flags);
    return !left_is_word && right_is_word;
}

fn is_word_end_flags(input: InputView, position: usize, input_len: usize, flags: u8) -> bool {
    if position == 0usize {
        return false;
    }
    if position == input_len && input_match_flag_enabled(input, t.MATCH_NOT_EOW) {
        return false;
    }
    let left: InputDecode = previous_decode(input, position);
    let right: InputDecode = decode_at(input, position);
    let left_is_word: bool = left.valid && is_word_flags(input, left.value, flags);
    let right_is_word: bool = position < input_len && right.valid && is_word_flags(input, right.value, flags);
    return left_is_word && !right_is_word;
}

fn write_set_matches(matched: *mut bool, pattern_count: usize, out_pattern_ids: *mut usize, out_capacity: usize) -> usize {
    var written: usize = 0usize;
    for index in range(pattern_count) {
        if unsafe { matched[index] } {
            if written < out_capacity && out_pattern_ids != null {
                unsafe {
                    out_pattern_ids[written] = index;
                }
            }
            written += 1usize;
        }
    }
    if written > out_capacity {
        return out_capacity;
    }
    return written;
}
