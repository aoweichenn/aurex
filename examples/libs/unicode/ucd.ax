        return contains_ranges(SCRIPT_CARIAN_RANGES[:], SCRIPT_CARIAN_RANGES_COUNT, value);
    }
    if script == 20usize {
        return contains_ranges(SCRIPT_CAUCASIANALBANIAN_RANGES[:], SCRIPT_CAUCASIANALBANIAN_RANGES_COUNT, value);
