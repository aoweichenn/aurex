pub fn decode_at(text_value: str, offset: usize) -> Decode {
    let len: usize = strblen(text_value);
    if offset >= len {
        return Decode { value: 0usize, next: offset, valid: false };
    }
    let b0: u8 = ascii.byte_at(text_value, offset);
    if b0 < 0x80u8 {
        return Decode { value: cast<usize>(b0), next: offset + 1usize, valid: true };
    }
    if UTF8_TWO_MIN <= b0 && b0 <= UTF8_TWO_MAX {
        if offset + 1usize >= len {
            return invalid_decode(b0, offset);
        }
        let b1: u8 = ascii.byte_at(text_value, offset + 1usize);
        if !is_continuation(b1) {
            return invalid_decode(b0, offset);
        }
        let value: usize = (cast<usize>(b0) - 0xc0usize) * UTF8_PAYLOAD_6 + (cast<usize>(b1) - 0x80usize);
        return Decode { value: value, next: offset + 2usize, valid: true };
    }
    if UTF8_THREE_MIN <= b0 && b0 <= UTF8_THREE_MAX {
        if offset + 2usize >= len {
            return invalid_decode(b0, offset);
        }
        let b1: u8 = ascii.byte_at(text_value, offset + 1usize);
        let b2: u8 = ascii.byte_at(text_value, offset + 2usize);
        if !valid_second_for_three(b0, b1) || !is_continuation(b2) {
            return invalid_decode(b0, offset);
        }
        let value: usize = (cast<usize>(b0) - 0xe0usize) * UTF8_PAYLOAD_12 +
            (cast<usize>(b1) - 0x80usize) * UTF8_PAYLOAD_6 +
            (cast<usize>(b2) - 0x80usize);
        return Decode { value: value, next: offset + 3usize, valid: true };
    }
    if UTF8_FOUR_MIN <= b0 && b0 <= UTF8_FOUR_MAX {
        if offset + 3usize >= len {
            return invalid_decode(b0, offset);
        }
        let b1: u8 = ascii.byte_at(text_value, offset + 1usize);
        let b2: u8 = ascii.byte_at(text_value, offset + 2usize);
        let b3: u8 = ascii.byte_at(text_value, offset + 3usize);
        if !valid_second_for_four(b0, b1) || !is_continuation(b2) || !is_continuation(b3) {
            return invalid_decode(b0, offset);
        }
        let value: usize = (cast<usize>(b0) - 0xf0usize) * UTF8_PAYLOAD_18 +
            (cast<usize>(b1) - 0x80usize) * UTF8_PAYLOAD_12 +
            (cast<usize>(b2) - 0x80usize) * UTF8_PAYLOAD_6 +
            (cast<usize>(b3) - 0x80usize);
        return Decode { value: value, next: offset + 4usize, valid: true };
    }
    return invalid_decode(b0, offset);
}

pub fn next_boundary(text_value: str, offset: usize) -> usize {
    let len: usize = strblen(text_value);
    if offset >= len {
        return len;
    }
    let decoded: Decode = decode_at(text_value, offset);
    if decoded.next <= offset {
        return offset + 1usize;
    }
    return decoded.next;
}

pub fn align_forward_boundary(text_value: str, offset: usize) -> usize {
    let len: usize = strblen(text_value);
    if offset >= len {
        return len;
    }
    var at: usize = offset;
    while at < len && is_continuation(ascii.byte_at(text_value, at)) {
        at += 1usize;
    }
    return at;
}

pub fn previous_boundary(text_value: str, offset: usize) -> usize {
    if offset == 0usize {
        return 0usize;
    }
    var at: usize = offset - 1usize;
    var steps: usize = 0usize;
    while at > 0usize && steps < 3usize && is_continuation(ascii.byte_at(text_value, at)) {
        at -= 1usize;
        steps += 1usize;
    }
    return at;
}

pub fn previous_decode(text_value: str, offset: usize) -> Decode {
    let start: usize = previous_boundary(text_value, offset);
    let decoded: Decode = decode_at(text_value, start);
    if decoded.valid && decoded.next == offset {
        return decoded;
    }
    if offset == 0usize {
        return Decode { value: 0usize, next: 0usize, valid: false };
    }
    let fallback: u8 = ascii.byte_at(text_value, offset - 1usize);
    return Decode { value: cast<usize>(fallback), next: offset, valid: false };
}

pub fn is_word(value: usize) -> bool {
    return property_matches(PROPERTY_WORD, value);
}

pub fn is_line_break_scalar(value: usize) -> bool {
    return value == LINE_FEED || value == CARRIAGE_RETURN || value == VERTICAL_TAB ||
        value == FORM_FEED || value == NEXT_LINE || value == LINE_SEPARATOR || value == PARAGRAPH_SEPARATOR;
}

pub fn property_kind_from_name(pattern: str, name_start: usize, name_len: usize) -> usize {
    let separator: usize = find_property_separator(pattern, name_start, name_len);
    if separator != PROPERTY_NAME_NO_SEPARATOR {
        let key_len: usize = separator - name_start;
        let value_start: usize = separator + 1usize;
        let value_len: usize = name_start + name_len - value_start;
        if normalized_name_matches(pattern, name_start, key_len, "gc") ||
            normalized_name_matches(pattern, name_start, key_len, "generalcategory") {
            return alias_lookup(GC_ALIASES[:], GC_ALIASES_COUNT, pattern, value_start, value_len);
        }
        if normalized_name_matches(pattern, name_start, key_len, "sc") ||
            normalized_name_matches(pattern, name_start, key_len, "script") {
            return alias_lookup(SCRIPT_ALIASES[:], SCRIPT_ALIASES_COUNT, pattern, value_start, value_len);
        }
        if normalized_name_matches(pattern, name_start, key_len, "scx") ||
            normalized_name_matches(pattern, name_start, key_len, "scriptextensions") {
            return alias_lookup(SCX_ALIASES[:], SCX_ALIASES_COUNT, pattern, value_start, value_len);
        }
        return PROPERTY_NONE;
    }
    let direct: usize = alias_lookup(PROPERTY_ALIASES[:], PROPERTY_ALIASES_COUNT, pattern, name_start, name_len);
    if direct != PROPERTY_NONE {
        return direct;
    }
    return PROPERTY_NONE;
}

pub fn property_matches(kind: usize, value: usize) -> bool {
    if value > CODEPOINT_MAX {
        return false;
    }
    if kind >= PROPERTY_SCRIPT_EXTENSIONS_BASE && kind < PROPERTY_SCRIPT_EXTENSIONS_BASE + SCRIPT_COUNT {
        return script_extensions_match(kind - PROPERTY_SCRIPT_EXTENSIONS_BASE, value);
    }
    if kind >= PROPERTY_SCRIPT_BASE && kind < PROPERTY_SCRIPT_BASE + SCRIPT_COUNT {
        return script_match(kind - PROPERTY_SCRIPT_BASE, value);
    }
    if kind == PROPERTY_ANY {
        return true;
    }
    if kind == PROPERTY_ASSIGNED {
        return !contains_ranges(GC_CN_RANGES[:], GC_CN_RANGES_COUNT, value);
    }
    if kind == PROPERTY_ASCII {
        return value <= 0x7fusize;
    }
    if kind == PROPERTY_ALNUM {
        return property_matches(PROPERTY_ALPHABETIC, value) || contains_ranges(GC_ND_RANGES[:], GC_ND_RANGES_COUNT, value);
    }
    if kind == PROPERTY_WORD {
        return property_matches(PROPERTY_ALPHABETIC, value) ||
            contains_ranges(GC_ND_RANGES[:], GC_ND_RANGES_COUNT, value) ||
            is_mark_category(value) ||
            contains_ranges(GC_PC_RANGES[:], GC_PC_RANGES_COUNT, value) ||
            property_matches(PROPERTY_JOIN_CONTROL, value) ||
            value == 0x5fusize;
    }
    if kind == PROPERTY_BLANK {
        return value == 0x09usize || contains_ranges(GC_ZS_RANGES[:], GC_ZS_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GRAPH {
        return property_matches(PROPERTY_ASSIGNED, value) && !is_separator_category(value) && !is_other_category(value);
    }
    if kind == PROPERTY_PRINT {
        return property_matches(PROPERTY_GRAPH, value) || contains_ranges(GC_ZS_RANGES[:], GC_ZS_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_LC {
        return contains_ranges(GC_LU_RANGES[:], GC_LU_RANGES_COUNT, value) ||
            contains_ranges(GC_LL_RANGES[:], GC_LL_RANGES_COUNT, value) ||
            contains_ranges(GC_LT_RANGES[:], GC_LT_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_L {
        return is_letter_category(value);
    }
    if kind == PROPERTY_GC_M {
        return is_mark_category(value);
    }
    if kind == PROPERTY_GC_N {
        return is_number_category(value);
    }
    if kind == PROPERTY_GC_P {
        return is_punctuation_category(value);
    }
    if kind == PROPERTY_GC_S {
        return is_symbol_category(value);
    }
    if kind == PROPERTY_GC_Z {
        return is_separator_category(value);
    }
    if kind == PROPERTY_GC_C {
        return is_other_category(value);
    }

    if kind == PROPERTY_GC_LU {
        return contains_ranges(GC_LU_RANGES[:], GC_LU_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_LL {
        return contains_ranges(GC_LL_RANGES[:], GC_LL_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_LT {
        return contains_ranges(GC_LT_RANGES[:], GC_LT_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_LM {
        return contains_ranges(GC_LM_RANGES[:], GC_LM_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_LO {
        return contains_ranges(GC_LO_RANGES[:], GC_LO_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_MN {
        return contains_ranges(GC_MN_RANGES[:], GC_MN_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_MC {
        return contains_ranges(GC_MC_RANGES[:], GC_MC_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_ME {
        return contains_ranges(GC_ME_RANGES[:], GC_ME_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_ND {
        return contains_ranges(GC_ND_RANGES[:], GC_ND_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_NL {
        return contains_ranges(GC_NL_RANGES[:], GC_NL_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_NO {
        return contains_ranges(GC_NO_RANGES[:], GC_NO_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_PC {
        return contains_ranges(GC_PC_RANGES[:], GC_PC_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_PD {
        return contains_ranges(GC_PD_RANGES[:], GC_PD_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_PS {
        return contains_ranges(GC_PS_RANGES[:], GC_PS_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_PE {
        return contains_ranges(GC_PE_RANGES[:], GC_PE_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_PI {
        return contains_ranges(GC_PI_RANGES[:], GC_PI_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_PF {
        return contains_ranges(GC_PF_RANGES[:], GC_PF_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_PO {
        return contains_ranges(GC_PO_RANGES[:], GC_PO_RANGES_COUNT, value);
