fn script_extensions_match(script: usize, value: usize) -> bool {
    if script_match(script, value) {
        return true;
    }

    if script == 0usize {
        return contains_ranges(SCX_ADLAM_RANGES[:], SCX_ADLAM_RANGES_COUNT, value);
    }
    if script == 3usize {
        return contains_ranges(SCX_ARABIC_RANGES[:], SCX_ARABIC_RANGES_COUNT, value);
    }
    if script == 4usize {
        return contains_ranges(SCX_ARMENIAN_RANGES[:], SCX_ARMENIAN_RANGES_COUNT, value);
    }
    if script == 5usize {
        return contains_ranges(SCX_AVESTAN_RANGES[:], SCX_AVESTAN_RANGES_COUNT, value);
    }
    if script == 10usize {
        return contains_ranges(SCX_BENGALI_RANGES[:], SCX_BENGALI_RANGES_COUNT, value);
    }
    if script == 13usize {
        return contains_ranges(SCX_BOPOMOFO_RANGES[:], SCX_BOPOMOFO_RANGES_COUNT, value);
    }
    if script == 16usize {
        return contains_ranges(SCX_BUGINESE_RANGES[:], SCX_BUGINESE_RANGES_COUNT, value);
    }
    if script == 17usize {
        return contains_ranges(SCX_BUHID_RANGES[:], SCX_BUHID_RANGES_COUNT, value);
    }
    if script == 19usize {
        return contains_ranges(SCX_CARIAN_RANGES[:], SCX_CARIAN_RANGES_COUNT, value);
    }
    if script == 20usize {
        return contains_ranges(SCX_CAUCASIANALBANIAN_RANGES[:], SCX_CAUCASIANALBANIAN_RANGES_COUNT, value);
    }
    if script == 21usize {
        return contains_ranges(SCX_CHAKMA_RANGES[:], SCX_CHAKMA_RANGES_COUNT, value);
    }
    if script == 23usize {
        return contains_ranges(SCX_CHEROKEE_RANGES[:], SCX_CHEROKEE_RANGES_COUNT, value);
