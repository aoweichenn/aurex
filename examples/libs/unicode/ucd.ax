    }
    if kind == PROPERTY_GCB_LVT {
        return grapheme_cluster_break(value) == GCB_LVT;
    }
    return false;
}

pub fn simple_fold(value: usize) -> usize {
    var low: usize = 0usize;
    var high: usize = CASE_FOLD_COUNT;
    while low < high {
        let mid: usize = (low + high) / 2usize;
        let source: usize = CASE_FOLD_TABLE[mid * 2usize];
        if value < source {
            high = mid;
        } else if value > source {
            low = mid + 1usize;
        } else {
            return CASE_FOLD_TABLE[mid * 2usize + 1usize];
        }
    }
    return value;
}


pub fn full_fold_len(value: usize) -> usize {
    let offset: usize = full_fold_offset(value);
    if offset == CODEPOINT_SENTINEL {
        return 0usize;
    }
    return FULL_CASE_FOLD_TABLE[offset + 1usize];
}

pub fn full_fold_at(value: usize, index: usize) -> usize {
    let offset: usize = full_fold_offset(value);
    if offset == CODEPOINT_SENTINEL {
        return CODEPOINT_SENTINEL;
    }
    let len: usize = FULL_CASE_FOLD_TABLE[offset + 1usize];
    if index >= len {
        return CODEPOINT_SENTINEL;
    }
    return FULL_CASE_FOLD_TABLE[offset + 2usize + index];
}

pub fn grapheme_cluster_break(value: usize) -> u8 {
    var low: usize = 0usize;
    var high: usize = GRAPHEME_CLUSTER_BREAK_COUNT;
    while low < high {
        let mid: usize = (low + high) / 2usize;
        let offset: usize = mid * GRAPHEME_CLUSTER_BREAK_STRIDE;
        let first: usize = GRAPHEME_CLUSTER_BREAK_TABLE[offset];
        let last: usize = GRAPHEME_CLUSTER_BREAK_TABLE[offset + 1usize];
        if value < first {
            high = mid;
        } else if value > last {
            low = mid + 1usize;
        } else {
            return cast<u8>(GRAPHEME_CLUSTER_BREAK_TABLE[offset + 2usize]);
        }
    }
    return GCB_OTHER;
}

fn full_fold_offset(value: usize) -> usize {
    var low: usize = 0usize;
    var high: usize = FULL_CASE_FOLD_COUNT;
    while low < high {
        let mid: usize = (low + high) / 2usize;
        let offset: usize = mid * FULL_CASE_FOLD_STRIDE;
        let source: usize = FULL_CASE_FOLD_TABLE[offset];
        if value < source {
            high = mid;
        } else if value > source {
            low = mid + 1usize;
        } else {
            return offset;
        }
    }
    return CODEPOINT_SENTINEL;
}

pub fn fold_equivalent_in_range(value: usize, first: usize, last: usize) -> bool {
    let folded: usize = simple_fold(value);
    if first <= folded && folded <= last {
        return true;
    }
    var index: usize = 0usize;
    while index < CASE_FOLD_COUNT {
        if CASE_FOLD_TABLE[index * 2usize + 1usize] == folded {
            let source: usize = CASE_FOLD_TABLE[index * 2usize];
            if first <= source && source <= last {
                return true;
            }
        }
        index += 1usize;
    }
    return false;
}

pub fn property_case_fold_matches(kind: usize, value: usize) -> bool {
    if property_matches(kind, value) {
        return true;
    }
    let folded: usize = simple_fold(value);
    if folded != value && property_matches(kind, folded) {
        return true;
    }
    var index: usize = 0usize;
    while index < CASE_FOLD_COUNT {
        if CASE_FOLD_TABLE[index * 2usize + 1usize] == folded && property_matches(kind, CASE_FOLD_TABLE[index * 2usize]) {
            return true;
        }
        index += 1usize;
    }
    return false;
}

fn is_continuation(value: u8) -> bool {
    return (value & UTF8_CONTINUATION_MASK) == UTF8_CONTINUATION_TAG;
}

fn valid_second_for_three(first: u8, second: u8) -> bool {
    if first == 0xe0u8 {
        return UTF8_E0_SECOND_MIN <= second && second <= UTF8_HIGH_TRAIL;
    }
    if first == 0xedu8 {
        return UTF8_LOW_TRAIL <= second && second <= UTF8_ED_SECOND_MAX;
    }
    return is_continuation(second);
}

fn valid_second_for_four(first: u8, second: u8) -> bool {
    if first == 0xf0u8 {
        return UTF8_F0_SECOND_MIN <= second && second <= UTF8_HIGH_TRAIL;
    }
    if first == 0xf4u8 {
        return UTF8_LOW_TRAIL <= second && second <= UTF8_F4_SECOND_MAX;
    }
    return is_continuation(second);
}

fn invalid_decode(first: u8, offset: usize) -> Decode {
    return Decode { value: cast<usize>(first), next: offset + 1usize, valid: false };
}

fn is_letter_category(value: usize) -> bool {
    return contains_ranges(GC_LU_RANGES[:], GC_LU_RANGES_COUNT, value) ||
        contains_ranges(GC_LL_RANGES[:], GC_LL_RANGES_COUNT, value) ||
        contains_ranges(GC_LT_RANGES[:], GC_LT_RANGES_COUNT, value) ||
        contains_ranges(GC_LM_RANGES[:], GC_LM_RANGES_COUNT, value) ||
        contains_ranges(GC_LO_RANGES[:], GC_LO_RANGES_COUNT, value);
}

fn is_mark_category(value: usize) -> bool {
    return contains_ranges(GC_MN_RANGES[:], GC_MN_RANGES_COUNT, value) ||
        contains_ranges(GC_MC_RANGES[:], GC_MC_RANGES_COUNT, value) ||
        contains_ranges(GC_ME_RANGES[:], GC_ME_RANGES_COUNT, value);
}

fn is_number_category(value: usize) -> bool {
    return contains_ranges(GC_ND_RANGES[:], GC_ND_RANGES_COUNT, value) ||
        contains_ranges(GC_NL_RANGES[:], GC_NL_RANGES_COUNT, value) ||
        contains_ranges(GC_NO_RANGES[:], GC_NO_RANGES_COUNT, value);
}

fn is_punctuation_category(value: usize) -> bool {
    return contains_ranges(GC_PC_RANGES[:], GC_PC_RANGES_COUNT, value) ||
        contains_ranges(GC_PD_RANGES[:], GC_PD_RANGES_COUNT, value) ||
        contains_ranges(GC_PS_RANGES[:], GC_PS_RANGES_COUNT, value) ||
        contains_ranges(GC_PE_RANGES[:], GC_PE_RANGES_COUNT, value) ||
        contains_ranges(GC_PI_RANGES[:], GC_PI_RANGES_COUNT, value) ||
        contains_ranges(GC_PF_RANGES[:], GC_PF_RANGES_COUNT, value) ||
        contains_ranges(GC_PO_RANGES[:], GC_PO_RANGES_COUNT, value);
}

fn is_symbol_category(value: usize) -> bool {
    return contains_ranges(GC_SM_RANGES[:], GC_SM_RANGES_COUNT, value) ||
        contains_ranges(GC_SC_RANGES[:], GC_SC_RANGES_COUNT, value) ||
        contains_ranges(GC_SK_RANGES[:], GC_SK_RANGES_COUNT, value) ||
        contains_ranges(GC_SO_RANGES[:], GC_SO_RANGES_COUNT, value);
}

fn is_separator_category(value: usize) -> bool {
    return contains_ranges(GC_ZS_RANGES[:], GC_ZS_RANGES_COUNT, value) ||
        contains_ranges(GC_ZL_RANGES[:], GC_ZL_RANGES_COUNT, value) ||
        contains_ranges(GC_ZP_RANGES[:], GC_ZP_RANGES_COUNT, value);
}

fn is_other_category(value: usize) -> bool {
    return contains_ranges(GC_CC_RANGES[:], GC_CC_RANGES_COUNT, value) ||
        contains_ranges(GC_CF_RANGES[:], GC_CF_RANGES_COUNT, value) ||
        contains_ranges(GC_CS_RANGES[:], GC_CS_RANGES_COUNT, value) ||
        contains_ranges(GC_CO_RANGES[:], GC_CO_RANGES_COUNT, value) ||
        contains_ranges(GC_CN_RANGES[:], GC_CN_RANGES_COUNT, value);
}

fn contains_ranges(ranges: []const usize, count: usize, value: usize) -> bool {
    var low: usize = 0usize;
    var high: usize = count;
    while low < high {
        let mid: usize = (low + high) / 2usize;
        let first: usize = ranges[mid * 2usize];
        let last: usize = ranges[mid * 2usize + 1usize];
        if value < first {
            high = mid;
        } else if value > last {
            low = mid + 1usize;
        } else {
            return true;
        }
    }
    return false;
}

fn alias_lookup(aliases: []const PropertyAlias, count: usize, pattern: str, name_start: usize, name_len: usize) -> usize {
    var index: usize = 0usize;
    while index < count {
        if normalized_name_matches(pattern, name_start, name_len, aliases[index].name) {
            return aliases[index].kind;
        }
        index += 1usize;
    }
    return PROPERTY_NONE;
}

fn normalized_name_matches(pattern: str, name_start: usize, name_len: usize, expected: str) -> bool {
    let end: usize = name_start + name_len;
    let expected_len: usize = strblen(expected);
    var at: usize = name_start;
    var expected_at: usize = 0usize;
    while at < end {
        let value: u8 = ascii.byte_at(pattern, at);
        if is_property_name_ignored(value) {
            at += 1usize;
        } else {
            if expected_at >= expected_len {
                return false;
            }
            if ascii.to_lower(value) != ascii.byte_at(expected, expected_at) {
                return false;
            }
            expected_at += 1usize;
            at += 1usize;
        }
    }
    return expected_at == expected_len;
}

fn is_property_name_ignored(value: u8) -> bool {
    return value == ascii.UNDERSCORE || value == ascii.HYPHEN || value == ascii.SPACE;
}

fn find_property_separator(pattern: str, name_start: usize, name_len: usize) -> usize {
    let end: usize = name_start + name_len;
    var at: usize = name_start;
    while at < end {
        let value: u8 = ascii.byte_at(pattern, at);
        if value == ascii.EQUAL || value == ascii.COLON {
            return at;
        }
        at += 1usize;
    }
    return PROPERTY_NAME_NO_SEPARATOR;
}

fn script_match(script: usize, value: usize) -> bool {

    if script == 0usize {
        return contains_ranges(SCRIPT_ADLAM_RANGES[:], SCRIPT_ADLAM_RANGES_COUNT, value);
    }
    if script == 1usize {
        return contains_ranges(SCRIPT_AHOM_RANGES[:], SCRIPT_AHOM_RANGES_COUNT, value);
    }
    if script == 2usize {
        return contains_ranges(SCRIPT_ANATOLIANHIEROGLYPHS_RANGES[:], SCRIPT_ANATOLIANHIEROGLYPHS_RANGES_COUNT, value);
