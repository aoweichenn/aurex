    if kind == PROPERTY_GC_CC {
        return contains_ranges(GC_CC_RANGES[:], GC_CC_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_CF {
        return contains_ranges(GC_CF_RANGES[:], GC_CF_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_CS {
        return contains_ranges(GC_CS_RANGES[:], GC_CS_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_CO {
        return contains_ranges(GC_CO_RANGES[:], GC_CO_RANGES_COUNT, value);
    }
    if kind == PROPERTY_GC_CN {
        return contains_ranges(GC_CN_RANGES[:], GC_CN_RANGES_COUNT, value);
    }
    if kind == PROPERTY_ASCII_HEX_DIGIT {
        return contains_ranges(ASCII_HEX_DIGIT_RANGES[:], ASCII_HEX_DIGIT_RANGES_COUNT, value);
    }
    if kind == PROPERTY_ALPHABETIC {
        return contains_ranges(ALPHABETIC_RANGES[:], ALPHABETIC_RANGES_COUNT, value);
    }
    if kind == PROPERTY_BIDI_CONTROL {
        return contains_ranges(BIDI_CONTROL_RANGES[:], BIDI_CONTROL_RANGES_COUNT, value);
    }
    if kind == PROPERTY_CASE_IGNORABLE {
        return contains_ranges(CASE_IGNORABLE_RANGES[:], CASE_IGNORABLE_RANGES_COUNT, value);
    }
    if kind == PROPERTY_CASED {
        return contains_ranges(CASED_RANGES[:], CASED_RANGES_COUNT, value);
    }
    if kind == PROPERTY_CHANGES_WHEN_CASEFOLDED {
        return contains_ranges(CHANGES_WHEN_CASEFOLDED_RANGES[:], CHANGES_WHEN_CASEFOLDED_RANGES_COUNT, value);
    }
    if kind == PROPERTY_CHANGES_WHEN_CASEMAPPED {
        return contains_ranges(CHANGES_WHEN_CASEMAPPED_RANGES[:], CHANGES_WHEN_CASEMAPPED_RANGES_COUNT, value);
    }
    if kind == PROPERTY_CHANGES_WHEN_LOWERCASED {
        return contains_ranges(CHANGES_WHEN_LOWERCASED_RANGES[:], CHANGES_WHEN_LOWERCASED_RANGES_COUNT, value);
    }
    if kind == PROPERTY_CHANGES_WHEN_TITLECASED {
        return contains_ranges(CHANGES_WHEN_TITLECASED_RANGES[:], CHANGES_WHEN_TITLECASED_RANGES_COUNT, value);
    }
    if kind == PROPERTY_CHANGES_WHEN_UPPERCASED {
        return contains_ranges(CHANGES_WHEN_UPPERCASED_RANGES[:], CHANGES_WHEN_UPPERCASED_RANGES_COUNT, value);
    }
    if kind == PROPERTY_DASH {
        return contains_ranges(DASH_RANGES[:], DASH_RANGES_COUNT, value);
    }
    if kind == PROPERTY_DEFAULT_IGNORABLE_CODE_POINT {
        return contains_ranges(DEFAULT_IGNORABLE_CODE_POINT_RANGES[:], DEFAULT_IGNORABLE_CODE_POINT_RANGES_COUNT, value);
    }
    if kind == PROPERTY_DEPRECATED {
        return contains_ranges(DEPRECATED_RANGES[:], DEPRECATED_RANGES_COUNT, value);
    }
    if kind == PROPERTY_DIACRITIC {
        return contains_ranges(DIACRITIC_RANGES[:], DIACRITIC_RANGES_COUNT, value);
    }
    if kind == PROPERTY_EMOJI {
        return contains_ranges(EMOJI_RANGES[:], EMOJI_RANGES_COUNT, value);
    }
    if kind == PROPERTY_EMOJI_COMPONENT {
        return contains_ranges(EMOJI_COMPONENT_RANGES[:], EMOJI_COMPONENT_RANGES_COUNT, value);
    }
    if kind == PROPERTY_EMOJI_MODIFIER {
        return contains_ranges(EMOJI_MODIFIER_RANGES[:], EMOJI_MODIFIER_RANGES_COUNT, value);
    }
    if kind == PROPERTY_EMOJI_MODIFIER_BASE {
        return contains_ranges(EMOJI_MODIFIER_BASE_RANGES[:], EMOJI_MODIFIER_BASE_RANGES_COUNT, value);
    }
    if kind == PROPERTY_EMOJI_PRESENTATION {
        return contains_ranges(EMOJI_PRESENTATION_RANGES[:], EMOJI_PRESENTATION_RANGES_COUNT, value);
    }
    if kind == PROPERTY_EXTENDED_PICTOGRAPHIC {
        return contains_ranges(EXTENDED_PICTOGRAPHIC_RANGES[:], EXTENDED_PICTOGRAPHIC_RANGES_COUNT, value);
    }
    if kind == PROPERTY_EXTENDER {
