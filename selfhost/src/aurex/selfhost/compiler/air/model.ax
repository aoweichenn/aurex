module aurex.selfhost.compiler.air.model;

const AIR_MAX_BLOCKS: i32 = 64;
const AIR_MAX_VALUES: i32 = 768;
const AIR_MAX_BLOCK_VALUES: i32 = 768;
const AIR_MAX_VALUE_ARGS: i32 = 512;
const AIR_MAX_INSTRUCTIONS: i32 = 256;
const AIR_MAX_BLOCK_INSTRUCTIONS: i32 = 256;
const AIR_MAX_PARAMS: i32 = 64;
const AIR_MAX_LOCALS: i32 = 128;
const AIR_MAX_SLOTS: i32 = 192;
const AIR_MAX_LVALUES: i32 = 256;
const AIR_MAX_EDGES: i32 = 512;

const AIR_VALUE_NONE: i32 = 0;
const AIR_VALUE_TEMP: i32 = 1;
const AIR_VALUE_PARAM: i32 = 2;
const AIR_VALUE_LOCAL: i32 = 3;
const AIR_VALUE_INTEGER: i32 = 4;
const AIR_VALUE_NAME: i32 = 5;
const AIR_VALUE_STRING: i32 = 6;
const AIR_VALUE_C_STRING: i32 = 7;
const AIR_VALUE_BOOL: i32 = 8;
const AIR_VALUE_NULL: i32 = 9;
const AIR_VALUE_UNARY: i32 = 10;
const AIR_VALUE_BINARY: i32 = 11;
const AIR_VALUE_CALL: i32 = 12;
const AIR_VALUE_FIELD: i32 = 13;
const AIR_VALUE_INDEX: i32 = 14;
const AIR_VALUE_STRUCT_LITERAL: i32 = 15;
const AIR_VALUE_CAST: i32 = 16;
const AIR_VALUE_TYPE_OP: i32 = 17;
const AIR_VALUE_PTR_ADDR: i32 = 18;
const AIR_VALUE_SLOT_ADDR: i32 = 19;
const AIR_VALUE_FIELD_ADDR: i32 = 20;
const AIR_VALUE_INDEX_ADDR: i32 = 21;
const AIR_VALUE_DEREF_ADDR: i32 = 22;
const AIR_VALUE_STORE: i32 = 23;
const AIR_VALUE_LOAD: i32 = 24;

const AIR_TERM_NONE: i32 = 0;
const AIR_TERM_JUMP: i32 = 1;
const AIR_TERM_BRANCH: i32 = 2;
const AIR_TERM_RETURN: i32 = 3;
const AIR_TERM_FALLTHROUGH: i32 = 4;
const AIR_TERM_EDGES: i32 = 5;

const AIR_EDGE_FALLTHROUGH: i32 = 1;
const AIR_EDGE_SCOPE: i32 = 2;
const AIR_EDGE_IF_TRUE: i32 = 3;
const AIR_EDGE_IF_FALSE: i32 = 4;
const AIR_EDGE_WHILE_TRUE: i32 = 5;
const AIR_EDGE_WHILE_FALSE: i32 = 6;
const AIR_EDGE_LOOP_BACK: i32 = 7;
const AIR_EDGE_RETURN: i32 = 8;

const AIR_INST_NONE: i32 = 0;
const AIR_INST_EXPR: i32 = 1;
const AIR_INST_LET: i32 = 2;
const AIR_INST_VAR: i32 = 3;
const AIR_INST_ASSIGN: i32 = 4;
const AIR_INST_SCOPE: i32 = 5;

const AIR_LINKAGE_INTERNAL: i32 = 1;
const AIR_LINKAGE_EXPORT_C: i32 = 2;

const AIR_LOCAL_PARAM: i32 = 1;
const AIR_LOCAL_LET: i32 = 2;
const AIR_LOCAL_VAR: i32 = 3;

const AIR_SLOT_PARAM: i32 = 1;
const AIR_SLOT_LOCAL: i32 = 2;

const AIR_BIND_NONE: i32 = 0;
const AIR_BIND_PARAM: i32 = 1;
const AIR_BIND_LOCAL: i32 = 2;
const AIR_BIND_ITEM: i32 = 3;

const AIR_LVALUE_BINDING: i32 = 1;
const AIR_LVALUE_FIELD: i32 = 2;
const AIR_LVALUE_INDEX: i32 = 3;
const AIR_LVALUE_DEREF: i32 = 4;

const AIR_SEMA_UNKNOWN: i32 = 0;
const AIR_SEMA_TYPE_ID: i32 = 1;
const AIR_SEMA_PRIMITIVE: i32 = 2;
const AIR_SEMA_INTEGER: i32 = 3;
const AIR_SEMA_NULL: i32 = 4;
const AIR_SEMA_ITEM: i32 = 5;
const AIR_SEMA_C_STRING: i32 = 6;

struct AirParam {
    ast_param_id: i32;
    name_begin: i32;
    name_end: i32;
    type_id: i32;
    value_id: i32;
    slot_id: i32;
}

struct AirLocal {
    kind: i32;
    ast_stmt_id: i32;
    scope_block: i32;
    name_begin: i32;
    name_end: i32;
    type_id: i32;
    slot_id: i32;
}

struct AirSlot {
    kind: i32;
    owner_id: i32;
    type_id: i32;
    name_begin: i32;
    name_end: i32;
}

struct AirLValue {
    kind: i32;
    ast_expr_id: i32;
    type_id: i32;
    base_value: i32;
    index_value: i32;
    slot_id: i32;
    binding_kind: i32;
    binding_id: i32;
    name_begin: i32;
    name_end: i32;
}

struct AirValueArg {
    value_id: i32;
    name_begin: i32;
    name_end: i32;
}

struct AirValue {
    kind: i32;
    ast_expr_id: i32;
    type_id: i32;
    sema_kind: i32;
    sema_payload: i32;
    name_begin: i32;
    name_end: i32;
    op: i32;
    lhs: i32;
    rhs: i32;
    first_arg: i32;
    arg_count: i32;
    slot_id: i32;
    lvalue_id: i32;
    address_value: i32;
    read_value: i32;
    binding_kind: i32;
    binding_id: i32;
}

struct AirInstruction {
    kind: i32;
    ast_stmt_id: i32;
    name_begin: i32;
    name_end: i32;
    type_id: i32;
    lhs: i32;
    rhs: i32;
    target: i32;
    slot_id: i32;
    lvalue_id: i32;
    address_value: i32;
    effect_value: i32;
    binding_kind: i32;
    binding_id: i32;
}

struct AirTerminator {
    kind: i32;
    condition: i32;
    value: i32;
    target: i32;
    then_target: i32;
    else_target: i32;
}

struct AirEdge {
    kind: i32;
    ast_stmt_id: i32;
    source: i32;
    target: i32;
    condition: i32;
    value: i32;
}

struct AirBlock {
    ast_block_id: i32;
    first_stmt: i32;
    stmt_count: i32;
    fallthrough_target: i32;
    fallthrough_kind: i32;
    first_value: i32;
    value_count: i32;
    first_instruction: i32;
    instruction_count: i32;
    terminator: AirTerminator;
}

struct AirFunction {
    ok: bool;
    block_count: i32;
    value_count: i32;
    block_value_count: i32;
    value_arg_count: i32;
    instruction_count: i32;
    block_instruction_count: i32;
    param_count: i32;
    local_count: i32;
    slot_count: i32;
    lvalue_count: i32;
    edge_count: i32;
    ast_item_id: i32;
    name_begin: i32;
    name_end: i32;
    return_type: i32;
    linkage: i32;
    entry_block: i32;
    blocks: *mut AirBlock;
    values: *mut AirValue;
    block_values: *mut i32;
    value_args: *mut AirValueArg;
    instructions: *mut AirInstruction;
    block_instructions: *mut i32;
    params: *mut AirParam;
    locals: *mut AirLocal;
    slots: *mut AirSlot;
    lvalues: *mut AirLValue;
    edges: *mut AirEdge;
}

extern c {
    fn malloc(size: usize) -> *mut void @name("malloc");
    fn free(ptr: *mut void) -> void @name("free");
}

fn air_make_terminator(kind: i32, condition: i32, value: i32, target: i32, then_target: i32, else_target: i32) -> AirTerminator {
    return AirTerminator {
        kind: kind,
        condition: condition,
        value: value,
        target: target,
        then_target: then_target,
        else_target: else_target
    };
}

fn air_none_terminator() -> AirTerminator {
    return air_make_terminator(AIR_TERM_NONE, -1, -1, -1, -1, -1);
}

fn air_jump_terminator(target: i32) -> AirTerminator {
    return air_make_terminator(AIR_TERM_JUMP, -1, -1, target, -1, -1);
}

fn air_branch_terminator(condition: i32, then_target: i32, else_target: i32) -> AirTerminator {
    return air_make_terminator(AIR_TERM_BRANCH, condition, -1, -1, then_target, else_target);
}

fn air_return_terminator(value: i32) -> AirTerminator {
    return air_make_terminator(AIR_TERM_RETURN, -1, value, -1, -1, -1);
}

fn air_fallthrough_terminator() -> AirTerminator {
    return air_make_terminator(AIR_TERM_FALLTHROUGH, -1, -1, -1, -1, -1);
}

fn air_edges_terminator() -> AirTerminator {
    return air_make_terminator(AIR_TERM_EDGES, -1, -1, -1, -1, -1);
}

fn air_make_edge(kind: i32, ast_stmt_id: i32, source: i32, target: i32, condition: i32, value: i32) -> AirEdge {
    return AirEdge {
        kind: kind,
        ast_stmt_id: ast_stmt_id,
        source: source,
        target: target,
        condition: condition,
        value: value
    };
}

fn air_make_value(kind: i32, ast_expr_id: i32, type_id: i32) -> AirValue {
    return AirValue {
        kind: kind,
        ast_expr_id: ast_expr_id,
        type_id: type_id,
        sema_kind: AIR_SEMA_UNKNOWN,
        sema_payload: -1,
        name_begin: -1,
        name_end: -1,
        op: 0,
        lhs: -1,
        rhs: -1,
        first_arg: 0,
        arg_count: 0,
        slot_id: -1,
        lvalue_id: -1,
        address_value: -1,
        read_value: -1,
        binding_kind: AIR_BIND_NONE,
        binding_id: -1
    };
}

fn air_make_param(ast_param_id: i32, name_begin: i32, name_end: i32, type_id: i32, value_id: i32, slot_id: i32) -> AirParam {
    return AirParam {
        ast_param_id: ast_param_id,
        name_begin: name_begin,
        name_end: name_end,
        type_id: type_id,
        value_id: value_id,
        slot_id: slot_id
    };
}

fn air_make_local(kind: i32, ast_stmt_id: i32, scope_block: i32, name_begin: i32, name_end: i32, type_id: i32, slot_id: i32) -> AirLocal {
    return AirLocal {
        kind: kind,
        ast_stmt_id: ast_stmt_id,
        scope_block: scope_block,
        name_begin: name_begin,
        name_end: name_end,
        type_id: type_id,
        slot_id: slot_id
    };
}

fn air_make_slot(kind: i32, owner_id: i32, type_id: i32, name_begin: i32, name_end: i32) -> AirSlot {
    return AirSlot {
        kind: kind,
        owner_id: owner_id,
        type_id: type_id,
        name_begin: name_begin,
        name_end: name_end
    };
}

fn air_make_lvalue(kind: i32, ast_expr_id: i32, type_id: i32) -> AirLValue {
    return AirLValue {
        kind: kind,
        ast_expr_id: ast_expr_id,
        type_id: type_id,
        base_value: -1,
        index_value: -1,
        slot_id: -1,
        binding_kind: AIR_BIND_NONE,
        binding_id: -1,
        name_begin: -1,
        name_end: -1
    };
}

fn air_make_value_arg(value_id: i32, name_begin: i32, name_end: i32) -> AirValueArg {
    return AirValueArg {
        value_id: value_id,
        name_begin: name_begin,
        name_end: name_end
    };
}

fn air_make_instruction(kind: i32, ast_stmt_id: i32, lhs: i32, rhs: i32, target: i32, type_id: i32, name_begin: i32, name_end: i32) -> AirInstruction {
    return AirInstruction {
        kind: kind,
        ast_stmt_id: ast_stmt_id,
        name_begin: name_begin,
        name_end: name_end,
        type_id: type_id,
        lhs: lhs,
        rhs: rhs,
        target: target,
        slot_id: -1,
        lvalue_id: -1,
        address_value: -1,
        effect_value: -1,
        binding_kind: AIR_BIND_NONE,
        binding_id: -1
    };
}

fn air_make_block(ast_block_id: i32, first_stmt: i32, stmt_count: i32, first_value: i32, first_instruction: i32) -> AirBlock {
    return AirBlock {
        ast_block_id: ast_block_id,
        first_stmt: first_stmt,
        stmt_count: stmt_count,
        fallthrough_target: -1,
        fallthrough_kind: AIR_EDGE_FALLTHROUGH,
        first_value: first_value,
        value_count: 0,
        first_instruction: first_instruction,
        instruction_count: 0,
        terminator: air_none_terminator()
    };
}

fn air_make_function() -> AirFunction {
    let blocks: *mut AirBlock = ptr_cast(*mut AirBlock, malloc(size_of(AirBlock) * cast(usize, AIR_MAX_BLOCKS)));
    let values: *mut AirValue = ptr_cast(*mut AirValue, malloc(size_of(AirValue) * cast(usize, AIR_MAX_VALUES)));
    let block_values: *mut i32 = ptr_cast(*mut i32, malloc(size_of(i32) * cast(usize, AIR_MAX_BLOCK_VALUES)));
    let value_args: *mut AirValueArg = ptr_cast(*mut AirValueArg, malloc(size_of(AirValueArg) * cast(usize, AIR_MAX_VALUE_ARGS)));
    let instructions: *mut AirInstruction = ptr_cast(*mut AirInstruction, malloc(size_of(AirInstruction) * cast(usize, AIR_MAX_INSTRUCTIONS)));
    let block_instructions: *mut i32 = ptr_cast(*mut i32, malloc(size_of(i32) * cast(usize, AIR_MAX_BLOCK_INSTRUCTIONS)));
    let params: *mut AirParam = ptr_cast(*mut AirParam, malloc(size_of(AirParam) * cast(usize, AIR_MAX_PARAMS)));
    let locals: *mut AirLocal = ptr_cast(*mut AirLocal, malloc(size_of(AirLocal) * cast(usize, AIR_MAX_LOCALS)));
    let slots: *mut AirSlot = ptr_cast(*mut AirSlot, malloc(size_of(AirSlot) * cast(usize, AIR_MAX_SLOTS)));
    let lvalues: *mut AirLValue = ptr_cast(*mut AirLValue, malloc(size_of(AirLValue) * cast(usize, AIR_MAX_LVALUES)));
    let edges: *mut AirEdge = ptr_cast(*mut AirEdge, malloc(size_of(AirEdge) * cast(usize, AIR_MAX_EDGES)));
    return AirFunction {
        ok: blocks != null && values != null && block_values != null && value_args != null && instructions != null && block_instructions != null && params != null && locals != null && slots != null && lvalues != null && edges != null,
        block_count: 0,
        value_count: 0,
        block_value_count: 0,
        value_arg_count: 0,
        instruction_count: 0,
        block_instruction_count: 0,
        param_count: 0,
        local_count: 0,
        slot_count: 0,
        lvalue_count: 0,
        edge_count: 0,
        ast_item_id: -1,
        name_begin: 0,
        name_end: 0,
        return_type: -1,
        linkage: AIR_LINKAGE_INTERNAL,
        entry_block: -1,
        blocks: blocks,
        values: values,
        block_values: block_values,
        value_args: value_args,
        instructions: instructions,
        block_instructions: block_instructions,
        params: params,
        locals: locals,
        slots: slots,
        lvalues: lvalues,
        edges: edges
    };
}

fn air_free_function(function: AirFunction) -> void {
    free(ptr_cast(*mut void, function.blocks));
    free(ptr_cast(*mut void, function.values));
    free(ptr_cast(*mut void, function.block_values));
    free(ptr_cast(*mut void, function.value_args));
    free(ptr_cast(*mut void, function.instructions));
    free(ptr_cast(*mut void, function.block_instructions));
    free(ptr_cast(*mut void, function.params));
    free(ptr_cast(*mut void, function.locals));
    free(ptr_cast(*mut void, function.slots));
    free(ptr_cast(*mut void, function.lvalues));
    free(ptr_cast(*mut void, function.edges));
}

fn air_set_function_header(function: *mut AirFunction, ast_item_id: i32, name_begin: i32, name_end: i32, return_type: i32, linkage: i32) -> bool {
    if !function.ok || name_begin >= name_end {
        function.ok = false;
        return false;
    }
    function.ast_item_id = ast_item_id;
    function.name_begin = name_begin;
    function.name_end = name_end;
    function.return_type = return_type;
    function.linkage = linkage;
    return true;
}

fn air_add_block(function: *mut AirFunction, ast_block_id: i32) -> i32 {
    return air_add_block_segment(function, ast_block_id, 0, -1);
}

fn air_add_block_segment(function: *mut AirFunction, ast_block_id: i32, first_stmt: i32, stmt_count: i32) -> i32 {
    if !function.ok || function.block_count >= AIR_MAX_BLOCKS {
        function.ok = false;
        return -1;
    }
    let id: i32 = function.block_count;
    function.blocks[id] = air_make_block(ast_block_id, first_stmt, stmt_count, function.block_value_count, function.block_instruction_count);
    function.block_count = function.block_count + 1;
    if function.entry_block < 0 {
        function.entry_block = id;
    }
    return id;
}

fn air_set_block_fallthrough(function: *mut AirFunction, block_id: i32, target: i32, kind: i32) -> bool {
    if !function.ok || block_id < 0 || block_id >= function.block_count {
        function.ok = false;
        return false;
    }
    function.blocks[block_id].fallthrough_target = target;
    function.blocks[block_id].fallthrough_kind = kind;
    return true;
}

fn air_add_value(function: *mut AirFunction, block_id: i32, value: AirValue) -> i32 {
    if !function.ok || block_id < 0 || block_id >= function.block_count ||
        function.value_count >= AIR_MAX_VALUES || function.block_value_count >= AIR_MAX_BLOCK_VALUES {
        function.ok = false;
        return -1;
    }
    if function.blocks[block_id].value_count == 0 {
        function.blocks[block_id].first_value = function.block_value_count;
    }
    let value_id: i32 = function.value_count;
    function.values[value_id] = value;
    function.value_count = function.value_count + 1;
    function.block_values[function.block_value_count] = value_id;
    function.block_value_count = function.block_value_count + 1;
    function.blocks[block_id].value_count = function.blocks[block_id].value_count + 1;
    return value_id;
}

fn air_add_detached_value(function: *mut AirFunction, value: AirValue) -> i32 {
    if !function.ok || function.value_count >= AIR_MAX_VALUES {
        function.ok = false;
        return -1;
    }
    let value_id: i32 = function.value_count;
    function.values[value_id] = value;
    function.value_count = function.value_count + 1;
    return value_id;
}

fn air_add_param(function: *mut AirFunction, ast_param_id: i32, name_begin: i32, name_end: i32, type_id: i32) -> i32 {
    if !function.ok || function.param_count >= AIR_MAX_PARAMS || name_begin >= name_end {
        function.ok = false;
        return -1;
    }
    let value_id: i32 = air_add_detached_value(function, air_make_value(AIR_VALUE_PARAM, -1, type_id));
    if value_id < 0 {
        return -1;
    }
    let id: i32 = function.param_count;
    let slot_id: i32 = air_add_slot(function, air_make_slot(AIR_SLOT_PARAM, id, type_id, name_begin, name_end));
    if slot_id < 0 {
        return -1;
    }
    function.params[id] = air_make_param(ast_param_id, name_begin, name_end, type_id, value_id, slot_id);
    function.param_count = function.param_count + 1;
    return id;
}

fn air_add_local(function: *mut AirFunction, kind: i32, ast_stmt_id: i32, scope_block: i32, name_begin: i32, name_end: i32, type_id: i32) -> i32 {
    if !function.ok || function.local_count >= AIR_MAX_LOCALS || name_begin >= name_end {
        function.ok = false;
        return -1;
    }
    let id: i32 = function.local_count;
    let slot_id: i32 = air_add_slot(function, air_make_slot(AIR_SLOT_LOCAL, id, type_id, name_begin, name_end));
    if slot_id < 0 {
        return -1;
    }
    function.locals[id] = air_make_local(kind, ast_stmt_id, scope_block, name_begin, name_end, type_id, slot_id);
    function.local_count = function.local_count + 1;
    return id;
}

fn air_add_slot(function: *mut AirFunction, slot: AirSlot) -> i32 {
    if !function.ok || function.slot_count >= AIR_MAX_SLOTS {
        function.ok = false;
        return -1;
    }
    let slot_id: i32 = function.slot_count;
    function.slots[slot_id] = slot;
    function.slot_count = function.slot_count + 1;
    return slot_id;
}

fn air_add_lvalue(function: *mut AirFunction, lvalue: AirLValue) -> i32 {
    if !function.ok || function.lvalue_count >= AIR_MAX_LVALUES {
        function.ok = false;
        return -1;
    }
    let lvalue_id: i32 = function.lvalue_count;
    function.lvalues[lvalue_id] = lvalue;
    function.lvalue_count = function.lvalue_count + 1;
    return lvalue_id;
}

fn air_add_instruction(function: *mut AirFunction, block_id: i32, instruction: AirInstruction) -> i32 {
    if !function.ok || block_id < 0 || block_id >= function.block_count ||
        function.instruction_count >= AIR_MAX_INSTRUCTIONS ||
        function.block_instruction_count >= AIR_MAX_BLOCK_INSTRUCTIONS {
        function.ok = false;
        return -1;
    }
    if function.blocks[block_id].instruction_count == 0 {
        function.blocks[block_id].first_instruction = function.block_instruction_count;
    }
    let instruction_id: i32 = function.instruction_count;
    function.instructions[instruction_id] = instruction;
    function.instruction_count = function.instruction_count + 1;
    function.block_instructions[function.block_instruction_count] = instruction_id;
    function.block_instruction_count = function.block_instruction_count + 1;
    function.blocks[block_id].instruction_count = function.blocks[block_id].instruction_count + 1;
    return instruction_id;
}

fn air_set_terminator(function: *mut AirFunction, block_id: i32, terminator: AirTerminator) -> bool {
    if !function.ok || block_id < 0 || block_id >= function.block_count {
        function.ok = false;
        return false;
    }
    function.blocks[block_id].terminator = terminator;
    return true;
}

fn air_clear_edges(function: *mut AirFunction) -> void {
    function.edge_count = 0;
}

fn air_add_edge(function: *mut AirFunction, edge: AirEdge) -> i32 {
    if !function.ok || function.edge_count >= AIR_MAX_EDGES {
        function.ok = false;
        return -1;
    }
    let edge_id: i32 = function.edge_count;
    function.edges[edge_id] = edge;
    function.edge_count = function.edge_count + 1;
    return edge_id;
}

fn air_add_value_arg_named(function: *mut AirFunction, value_id: i32, arg_value_id: i32, name_begin: i32, name_end: i32) -> bool {
    if !function.ok || value_id < 0 || value_id >= function.value_count ||
        function.value_arg_count >= AIR_MAX_VALUE_ARGS {
        function.ok = false;
        return false;
    }
    if function.values[value_id].arg_count == 0 {
        function.values[value_id].first_arg = function.value_arg_count;
    } else {
        if function.values[value_id].first_arg + function.values[value_id].arg_count != function.value_arg_count {
            function.ok = false;
            return false;
        }
    }
    function.value_args[function.value_arg_count] = air_make_value_arg(arg_value_id, name_begin, name_end);
    function.value_arg_count = function.value_arg_count + 1;
    function.values[value_id].arg_count = function.values[value_id].arg_count + 1;
    return true;
}

fn air_add_value_arg(function: *mut AirFunction, value_id: i32, arg_value_id: i32) -> bool {
    return air_add_value_arg_named(function, value_id, arg_value_id, -1, -1);
}
