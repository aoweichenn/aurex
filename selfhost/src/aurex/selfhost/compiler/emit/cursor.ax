module aurex.selfhost.compiler.emit.cursor;

import aurex.selfhost.lexer.core;

fn advance(source: *const u8, index: *mut i32, current: *mut TokenSpan) -> TokenSpan {
    let previous: TokenSpan = *current;
    *current = scan_token(source, index);
    return previous;
}

fn check(current: *mut TokenSpan, kind: i32) -> bool {
    return current.kind == kind;
}

fn match_token(source: *const u8, index: *mut i32, current: *mut TokenSpan, kind: i32) -> bool {
    if check(current, kind) {
        advance(source, index, current);
        return true;
    }
    return false;
}

fn expect_token(source: *const u8, index: *mut i32, current: *mut TokenSpan, kind: i32) -> bool {
    return match_token(source, index, current, kind);
}

fn emit_parse_path_tail(source: *const u8, index: *mut i32, current: *mut TokenSpan) -> bool {
    while match_token(source, index, current, TK_DOT) {
        if !(match_token(source, index, current, TK_IDENTIFIER) || match_token(source, index, current, TK_KW_C)) {
            return false;
        }
    }
    return true;
}

fn parse_module_or_import(source: *const u8, index: *mut i32, current: *mut TokenSpan, keyword: i32) -> bool {
    if !expect_token(source, index, current, keyword) {
        return false;
    }
    if !(match_token(source, index, current, TK_IDENTIFIER) || match_token(source, index, current, TK_KW_C)) {
        return false;
    }
    if !emit_parse_path_tail(source, index, current) {
        return false;
    }
    return expect_token(source, index, current, TK_SEMICOLON);
}
