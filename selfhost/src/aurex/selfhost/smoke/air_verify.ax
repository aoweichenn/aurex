module aurex.selfhost.smoke.air_verify;

import aurex.selfhost.compiler.air.model;
import aurex.selfhost.compiler.air.verify;

extern c {
    fn puts(s: *const u8) -> i32 @name("puts");
}

fn check_valid_air_function() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let exit: i32 = air_add_block(&function, 1);
    let param_id: i32 = air_add_param(&function, 0, 0, 5, 1);
    let left: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 0, -1));
    let right: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 1, -1));
    var condition_value: AirValue = air_make_value(AIR_VALUE_BINARY, 2, -1);
    condition_value.lhs = left;
    condition_value.rhs = right;
    let condition: i32 = air_add_value(&function, entry, condition_value);
    var callee_value: AirValue = air_make_value(AIR_VALUE_NAME, 3, -1);
    callee_value.binding_kind = AIR_BIND_PARAM;
    callee_value.binding_id = param_id;
    let callee: i32 = air_add_value(&function, exit, callee_value);
    let arg: i32 = air_add_value(&function, exit, air_make_value(AIR_VALUE_INTEGER, 4, -1));
    var call_value: AirValue = air_make_value(AIR_VALUE_CALL, 5, -1);
    call_value.lhs = callee;
    let result: i32 = air_add_value(&function, exit, call_value);
    air_add_value_arg(&function, result, arg);
    var let_inst: AirInstruction = air_make_instruction(AIR_INST_VAR, 0, left, -1, -1, -1, 0, 1);
    let_inst.binding_kind = AIR_BIND_LOCAL;
    let_inst.binding_id = 0;
    air_add_instruction(&function, entry, let_inst);
    var assign_inst: AirInstruction = air_make_instruction(AIR_INST_ASSIGN, 1, left, right, -1, -1, 0, 0);
    assign_inst.binding_kind = AIR_BIND_LOCAL;
    assign_inst.binding_id = 0;
    air_add_instruction(&function, entry, assign_inst);
    air_add_instruction(&function, exit, air_make_instruction(AIR_INST_EXPR, 2, result, -1, -1, -1, 0, 0));
    air_add_local(&function, AIR_LOCAL_VAR, 0, entry, 0, 1, 1);
    let ok: bool = air_set_terminator(&function, entry, air_branch_terminator(condition, exit, exit)) &&
        air_set_terminator(&function, exit, air_return_terminator(result)) &&
        param_id >= 0 &&
        air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_missing_terminator_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    air_add_block(&function, 0);
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_branch_target_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let condition: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_TEMP, 0, -1));
    air_set_terminator(&function, entry, air_branch_terminator(condition, 99, entry));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_return_value_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    air_set_terminator(&function, entry, air_return_terminator(42));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_binary_operand_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let left: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 0, -1));
    var binary: AirValue = air_make_value(AIR_VALUE_BINARY, 1, -1);
    binary.lhs = left;
    binary.rhs = 99;
    let result: i32 = air_add_value(&function, entry, binary);
    air_set_terminator(&function, entry, air_return_terminator(result));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_call_arg_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let callee: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_NAME, 0, -1));
    var call_value: AirValue = air_make_value(AIR_VALUE_CALL, 1, -1);
    call_value.lhs = callee;
    let result: i32 = air_add_value(&function, entry, call_value);
    air_add_value_arg(&function, result, 99);
    air_set_terminator(&function, entry, air_return_terminator(result));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

