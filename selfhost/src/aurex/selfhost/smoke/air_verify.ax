fn check_bad_assign_missing_lvalue_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let left: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_NAME, 0, -1));
    let right: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 1, -1));
    let local_id: i32 = air_add_local(&function, AIR_LOCAL_VAR, 0, entry, 0, 1, 1);
    var instruction: AirInstruction = air_make_instruction(AIR_INST_ASSIGN, 0, left, right, -1, -1, 0, 0);
    instruction.binding_kind = AIR_BIND_LOCAL;
    instruction.binding_id = local_id;
    instruction.address_value = right;
    instruction.effect_value = right;
    air_add_instruction(&function, entry, instruction);
    air_set_terminator(&function, entry, air_return_terminator(right));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_valid_complex_lvalues() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let base: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_NAME, 0, -1));
    let index: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 1, -1));
    let rhs: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 2, -1));
    var field_lvalue: AirLValue = air_make_lvalue(AIR_LVALUE_FIELD, 0, 1);
    field_lvalue.base_value = base;
    field_lvalue.name_begin = 0;
    field_lvalue.name_end = 1;
    let field_id: i32 = air_add_lvalue(&function, field_lvalue);
    var index_lvalue: AirLValue = air_make_lvalue(AIR_LVALUE_INDEX, 1, 1);
    index_lvalue.base_value = base;
    index_lvalue.index_value = index;
    let index_id: i32 = air_add_lvalue(&function, index_lvalue);
    var deref_lvalue: AirLValue = air_make_lvalue(AIR_LVALUE_DEREF, 2, 1);
    deref_lvalue.base_value = base;
    let deref_id: i32 = air_add_lvalue(&function, deref_lvalue);
    var field_assign: AirInstruction = air_make_instruction(AIR_INST_ASSIGN, 0, base, rhs, -1, -1, 0, 0);
    field_assign.lvalue_id = field_id;
    air_add_assignment_store(&function, entry, &field_assign, rhs);
    air_add_instruction(&function, entry, field_assign);
    var index_assign: AirInstruction = air_make_instruction(AIR_INST_ASSIGN, 1, base, rhs, -1, -1, 0, 0);
    index_assign.lvalue_id = index_id;
    air_add_assignment_store(&function, entry, &index_assign, rhs);
    air_add_instruction(&function, entry, index_assign);
    var deref_assign: AirInstruction = air_make_instruction(AIR_INST_ASSIGN, 2, base, rhs, -1, -1, 0, 0);
    deref_assign.lvalue_id = deref_id;
    air_add_assignment_store(&function, entry, &deref_assign, rhs);
    air_add_instruction(&function, entry, deref_assign);
    let ok: bool = field_id >= 0 &&
        index_id >= 0 &&
        deref_id >= 0 &&
        air_set_terminator(&function, entry, air_return_terminator(rhs)) &&
        air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn main() -> i32 {
    if check_valid_air_function() &&
        check_bad_edge_target_rejected() &&
        check_bad_edge_condition_rejected() &&
        check_bad_branch_edge_mismatch_rejected() &&
        check_valid_block_param_edge_args() &&
        check_missing_edge_arg_rejected() &&
        check_valid_join_block_param_edge_args() &&
        check_bad_edge_arg_type_rejected() &&
        check_bad_edge_arg_scope_rejected() &&
        check_missing_terminator_rejected() &&
        check_bad_branch_target_rejected() &&
        check_bad_return_value_rejected() &&
        check_bad_binary_operand_rejected() &&
        check_bad_call_arg_rejected() &&
        check_bad_name_binding_rejected() &&
        check_bad_non_name_binding_rejected() &&
        check_bad_let_binding_rejected() &&
        check_bad_let_kind_rejected() &&
        check_bad_assign_let_target_rejected() &&
        check_bad_struct_arg_name_rejected() &&
        check_bad_value_name_rejected() &&
        check_bad_instruction_value_rejected() &&
        check_scope_instruction_rejected() &&
        check_missing_header_rejected() &&
        check_bad_param_value_rejected() &&
        check_bad_local_block_rejected() &&
        check_bad_param_slot_rejected() &&
        check_bad_slot_owner_rejected() &&
        check_bad_lvalue_base_rejected() &&
        check_bad_lvalue_index_rejected() &&
        check_bad_assign_missing_lvalue_rejected() &&
        check_valid_complex_lvalues() {
        puts(c"selfhost air verifier ok");
        return 0;
    }
    puts(c"selfhost air verifier failed");
    return 1;
}
