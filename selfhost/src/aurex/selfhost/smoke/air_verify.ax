fn check_missing_header_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    let entry: i32 = air_add_block(&function, 0);
    air_set_terminator(&function, entry, air_return_terminator(-1));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_param_value_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    air_add_param(&function, 0, 0, 5, 1);
    function.params[0].value_id = 99;
    air_set_terminator(&function, entry, air_return_terminator(-1));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_local_block_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    air_add_local(&function, AIR_LOCAL_VAR, 0, 99, 0, 1, 1);
    air_set_terminator(&function, entry, air_return_terminator(-1));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

export c fn main(argc: i32, argv: *mut *mut u8) -> i32 {
    if check_valid_air_function() &&
        check_missing_terminator_rejected() &&
        check_bad_branch_target_rejected() &&
        check_bad_return_value_rejected() &&
        check_bad_binary_operand_rejected() &&
        check_bad_call_arg_rejected() &&
        check_bad_name_binding_rejected() &&
        check_bad_non_name_binding_rejected() &&
        check_bad_let_binding_rejected() &&
        check_bad_let_kind_rejected() &&
        check_bad_assign_let_target_rejected() &&
        check_bad_struct_arg_name_rejected() &&
        check_bad_value_name_rejected() &&
        check_bad_instruction_value_rejected() &&
        check_bad_scope_target_rejected() &&
        check_missing_header_rejected() &&
        check_bad_param_value_rejected() &&
        check_bad_local_block_rejected() {
        puts(c"selfhost air verifier ok");
        return 0;
    }
    puts(c"selfhost air verifier failed");
    return 1;
}
