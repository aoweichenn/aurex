module aurex.selfhost.smoke.air_verify;

import aurex.selfhost.compiler.air.model;
import aurex.selfhost.compiler.air.verify;
import aurex.selfhost.compiler.air.memory;

extern c {
    fn puts(s: *const u8) -> i32 @name("puts");
}

fn check_valid_air_function() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let exit: i32 = air_add_block(&function, 1);
    let param_id: i32 = air_add_param(&function, 0, 0, 5, 1);
    let local_id: i32 = air_add_local(&function, AIR_LOCAL_VAR, 0, entry, 0, 1, 1);
    let left: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 0, -1));
    let right: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 1, -1));
    var condition_value: AirValue = air_make_value(AIR_VALUE_BINARY, 2, -1);
    condition_value.lhs = left;
    condition_value.rhs = right;
    let condition: i32 = air_add_value(&function, entry, condition_value);
    var callee_value: AirValue = air_make_value(AIR_VALUE_NAME, 3, -1);
    callee_value.binding_kind = AIR_BIND_PARAM;
    callee_value.binding_id = param_id;
    let callee: i32 = air_add_value(&function, exit, callee_value);
    let arg: i32 = air_add_value(&function, exit, air_make_value(AIR_VALUE_INTEGER, 4, -1));
    var call_value: AirValue = air_make_value(AIR_VALUE_CALL, 5, -1);
    call_value.lhs = callee;
    let result: i32 = air_add_value(&function, exit, call_value);
    air_add_value_arg(&function, result, arg);
    var let_inst: AirInstruction = air_make_instruction(AIR_INST_VAR, 0, left, -1, -1, -1, 0, 1);
    let_inst.binding_kind = AIR_BIND_LOCAL;
    let_inst.binding_id = local_id;
    let_inst.slot_id = function.locals[local_id].slot_id;
    air_add_slot_init_store(&function, entry, &let_inst, left);
    air_add_instruction(&function, entry, let_inst);
    var lvalue: AirLValue = air_make_lvalue(AIR_LVALUE_BINDING, 0, 1);
    lvalue.slot_id = function.locals[local_id].slot_id;
    lvalue.binding_kind = AIR_BIND_LOCAL;
    lvalue.binding_id = local_id;
    lvalue.name_begin = 0;
    lvalue.name_end = 1;
    let lvalue_id: i32 = air_add_lvalue(&function, lvalue);
    var assign_inst: AirInstruction = air_make_instruction(AIR_INST_ASSIGN, 1, left, right, -1, -1, 0, 0);
    assign_inst.binding_kind = AIR_BIND_LOCAL;
    assign_inst.binding_id = local_id;
    assign_inst.lvalue_id = lvalue_id;
    air_add_assignment_store(&function, entry, &assign_inst, right);
    air_add_instruction(&function, entry, assign_inst);
    air_add_instruction(&function, exit, air_make_instruction(AIR_INST_EXPR, 2, result, -1, -1, -1, 0, 0));
    let ok: bool = air_set_terminator(&function, entry, air_branch_terminator(condition, exit, exit)) &&
        air_set_terminator(&function, exit, air_return_terminator(result)) &&
        air_add_edge(&function, air_make_edge(AIR_EDGE_IF_TRUE, 0, entry, exit, condition, -1)) >= 0 &&
        air_add_edge(&function, air_make_edge(AIR_EDGE_IF_FALSE, 0, entry, exit, condition, -1)) >= 0 &&
        air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 2, exit, -1, -1, result)) >= 0 &&
        param_id >= 0 &&
        local_id >= 0 &&
        lvalue_id >= 0 &&
        air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_edge_target_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let value: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 0, -1));
    air_set_terminator(&function, entry, air_return_terminator(value));
    air_add_edge(&function, air_make_edge(AIR_EDGE_SCOPE, 0, entry, 99, -1, -1));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_edge_condition_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let exit: i32 = air_add_block(&function, 1);
    let value: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 0, -1));
    air_set_terminator(&function, entry, air_branch_terminator(value, exit, exit));
    air_set_terminator(&function, exit, air_return_terminator(value));
    air_add_edge(&function, air_make_edge(AIR_EDGE_IF_TRUE, 0, entry, exit, 99, -1));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_branch_edge_mismatch_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let then_block: i32 = air_add_block(&function, 1);
    let else_block: i32 = air_add_block(&function, 2);
    let condition: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_TEMP, 0, -1));
    let value: i32 = air_add_value(&function, then_block, air_make_value(AIR_VALUE_INTEGER, 1, -1));
    air_set_terminator(&function, entry, air_branch_terminator(condition, then_block, else_block));
    air_set_terminator(&function, then_block, air_return_terminator(value));
    air_set_terminator(&function, else_block, air_return_terminator(value));
    air_add_edge(&function, air_make_edge(AIR_EDGE_IF_TRUE, 0, entry, else_block, condition, -1));
    air_add_edge(&function, air_make_edge(AIR_EDGE_IF_FALSE, 0, entry, then_block, condition, -1));
    air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 1, then_block, -1, -1, value));
    air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 2, else_block, -1, -1, value));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_valid_block_param_edge_args() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let join: i32 = air_add_block(&function, 1);
    let input: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 0, 1));
    let block_param: i32 = air_add_block_param(&function, join, 1, 4, 9);
    let param_value: i32 = function.block_params[block_param].value_id;
    let edge_id: i32 = air_add_edge(&function, air_make_edge(AIR_EDGE_FALLTHROUGH, -1, entry, join, -1, -1));
    let ok: bool = block_param >= 0 &&
        param_value >= 0 &&
        edge_id >= 0 &&
        air_add_edge_arg(&function, edge_id, input) &&
        air_set_terminator(&function, entry, air_jump_terminator(join)) &&
        air_set_terminator(&function, join, air_return_terminator(param_value)) &&
        air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 0, join, -1, -1, param_value)) >= 0 &&
        air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_missing_edge_arg_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let join: i32 = air_add_block(&function, 1);
    let block_param: i32 = air_add_block_param(&function, join, 1, 4, 9);
    let param_value: i32 = function.block_params[block_param].value_id;
    air_set_terminator(&function, entry, air_jump_terminator(join));
    air_set_terminator(&function, join, air_return_terminator(param_value));
    air_add_edge(&function, air_make_edge(AIR_EDGE_FALLTHROUGH, -1, entry, join, -1, -1));
    air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 0, join, -1, -1, param_value));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_valid_join_block_param_edge_args() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let then_block: i32 = air_add_block(&function, 1);
    let else_block: i32 = air_add_block(&function, 2);
    let join: i32 = air_add_block(&function, 3);
    let condition: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_BOOL, 0, 1));
    let left: i32 = air_add_value(&function, then_block, air_make_value(AIR_VALUE_INTEGER, 1, 1));
    let right: i32 = air_add_value(&function, else_block, air_make_value(AIR_VALUE_INTEGER, 2, 1));
    let block_param: i32 = air_add_block_param(&function, join, 1, 4, 9);
    let param_value: i32 = function.block_params[block_param].value_id;
    let then_edge: i32 = air_add_edge(&function, air_make_edge(AIR_EDGE_FALLTHROUGH, -1, then_block, join, -1, -1));
    let else_edge: i32 = air_add_edge(&function, air_make_edge(AIR_EDGE_FALLTHROUGH, -1, else_block, join, -1, -1));
    let ok: bool = block_param >= 0 &&
        then_edge >= 0 &&
        else_edge >= 0 &&
        air_add_edge(&function, air_make_edge(AIR_EDGE_IF_TRUE, 0, entry, then_block, condition, -1)) >= 0 &&
        air_add_edge(&function, air_make_edge(AIR_EDGE_IF_FALSE, 0, entry, else_block, condition, -1)) >= 0 &&
        air_add_edge_arg(&function, then_edge, left) &&
        air_add_edge_arg(&function, else_edge, right) &&
        air_set_terminator(&function, entry, air_branch_terminator(condition, then_block, else_block)) &&
        air_set_terminator(&function, then_block, air_jump_terminator(join)) &&
        air_set_terminator(&function, else_block, air_jump_terminator(join)) &&
        air_set_terminator(&function, join, air_return_terminator(param_value)) &&
        air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 1, join, -1, -1, param_value)) >= 0 &&
        air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_edge_arg_type_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let join: i32 = air_add_block(&function, 1);
    let input: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 0, 2));
    let block_param: i32 = air_add_block_param(&function, join, 1, 4, 9);
    let param_value: i32 = function.block_params[block_param].value_id;
    let edge_id: i32 = air_add_edge(&function, air_make_edge(AIR_EDGE_FALLTHROUGH, -1, entry, join, -1, -1));
    air_add_edge_arg(&function, edge_id, input);
    air_set_terminator(&function, entry, air_jump_terminator(join));
    air_set_terminator(&function, join, air_return_terminator(param_value));
    air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 0, join, -1, -1, param_value));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_edge_arg_scope_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let other: i32 = air_add_block(&function, 1);
    let join: i32 = air_add_block(&function, 2);
    let foreign: i32 = air_add_value(&function, other, air_make_value(AIR_VALUE_INTEGER, 0, 1));
    let block_param: i32 = air_add_block_param(&function, join, 1, 4, 9);
    let param_value: i32 = function.block_params[block_param].value_id;
    let edge_id: i32 = air_add_edge(&function, air_make_edge(AIR_EDGE_FALLTHROUGH, -1, entry, join, -1, -1));
    air_add_edge_arg(&function, edge_id, foreign);
    air_set_terminator(&function, entry, air_jump_terminator(join));
    air_set_terminator(&function, other, air_return_terminator(foreign));
    air_set_terminator(&function, join, air_return_terminator(param_value));
    air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 0, other, -1, -1, foreign));
    air_add_edge(&function, air_make_edge(AIR_EDGE_RETURN, 1, join, -1, -1, param_value));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

