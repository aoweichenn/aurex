    let entry: i32 = air_add_block(&function, 0);
    air_add_instruction(&function, entry, air_make_instruction(AIR_INST_EXPR, 0, 99, -1, -1, -1, 0, 0));
    air_set_terminator(&function, entry, air_return_terminator(-1));
