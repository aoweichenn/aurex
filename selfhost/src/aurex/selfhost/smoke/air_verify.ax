fn check_bad_struct_arg_name_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let field_value: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 0, -1));
    let literal: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_STRUCT_LITERAL, 1, -1));
    air_add_value_arg(&function, literal, field_value);
    air_set_terminator(&function, entry, air_return_terminator(literal));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

fn check_bad_value_name_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    var field: AirValue = air_make_value(AIR_VALUE_FIELD, 1, -1);
    field.lhs = air_add_value(&function, entry, air_make_value(AIR_VALUE_NAME, 0, -1));
    field.name_begin = 4;
    field.name_end = 4;
    let value: i32 = air_add_value(&function, entry, field);
    air_set_terminator(&function, entry, air_return_terminator(value));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

