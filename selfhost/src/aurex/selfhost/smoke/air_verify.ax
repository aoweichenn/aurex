    let entry: i32 = air_add_block(&function, 0);
    let base: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_NAME, 0, -1));
    var lvalue: AirLValue = air_make_lvalue(AIR_LVALUE_INDEX, 0, 1);
    lvalue.base_value = base;
    lvalue.index_value = 99;
    air_add_lvalue(&function, lvalue);
    air_set_terminator(&function, entry, air_return_terminator(base));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
