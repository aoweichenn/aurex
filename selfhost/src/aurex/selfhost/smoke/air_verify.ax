fn check_bad_assign_let_target_rejected() -> bool {
    var function: AirFunction = air_make_function();
    if !function.ok {
        air_free_function(function);
        return false;
    }
    air_set_function_header(&function, 0, 0, 4, 0, AIR_LINKAGE_INTERNAL);
    let entry: i32 = air_add_block(&function, 0);
    let left: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_NAME, 0, -1));
    let right: i32 = air_add_value(&function, entry, air_make_value(AIR_VALUE_INTEGER, 1, -1));
    let local_id: i32 = air_add_local(&function, AIR_LOCAL_LET, 0, entry, 0, 1, 1);
    var lvalue: AirLValue = air_make_lvalue(AIR_LVALUE_BINDING, 0, 1);
    lvalue.slot_id = function.locals[local_id].slot_id;
    lvalue.binding_kind = AIR_BIND_LOCAL;
    lvalue.binding_id = local_id;
    lvalue.name_begin = 0;
    lvalue.name_end = 1;
    let lvalue_id: i32 = air_add_lvalue(&function, lvalue);
    var instruction: AirInstruction = air_make_instruction(AIR_INST_ASSIGN, 0, left, right, -1, -1, 0, 0);
    instruction.binding_kind = AIR_BIND_LOCAL;
    instruction.binding_id = local_id;
    instruction.lvalue_id = lvalue_id;
    air_add_assignment_store(&function, entry, &instruction, right);
    air_add_instruction(&function, entry, instruction);
    air_set_terminator(&function, entry, air_return_terminator(right));
    let ok: bool = !air_verify_function(&function);
    air_free_function(function);
    return ok;
}

