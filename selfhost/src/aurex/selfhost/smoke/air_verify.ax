    let exit: i32 = air_add_block(&function, 1);
    air_add_instruction(&function, entry, air_make_instruction(AIR_INST_SCOPE, 0, -1, -1, exit, -1, 0, 0));
    air_set_terminator(&function, entry, air_return_terminator(-1));
