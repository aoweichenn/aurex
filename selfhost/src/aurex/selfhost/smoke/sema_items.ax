fn check_valid_typing() -> bool {
    let source: *const u8 = c"module sema.typing.valid; struct Pair { value: i32; } fn add(left: i32, right: i32) -> i32 { return left + right; } fn id_pair(pair: Pair) -> Pair { return pair; } export c fn main(argc: i32, argv: *mut *mut u8) -> i32 { let pair: Pair = id_pair(Pair { value: 1 }); let result: i32 = add(pair.value, 2); if result == 3 { return result; } return 0; }";
    var ast: AstModule = parse_seed_ast(source);
    if !ast.ok {
        ast_free_module(ast);
        return false;
    }
    let ok: bool = sema_check_module_typing(source, &ast);
    ast_free_module(ast);
    return ok;
}

