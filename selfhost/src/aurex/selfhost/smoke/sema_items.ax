fn check_condition_type_mismatch() -> bool {
    let source: *const u8 = c"module sema.typing.condition_mismatch; export c fn main(argc: i32, argv: *mut *mut u8) -> i32 { if 1 { return 1; } while 2 { return 2; } return 0; }";
    var ast: AstModule = parse_seed_ast(source);
    if !ast.ok {
        ast_free_module(ast);
        return false;
    }
    let ok: bool = !sema_check_module_typing(source, &ast);
    ast_free_module(ast);
    return ok;
}

export c fn main(argc: i32, argv: *mut *mut u8) -> i32 {
    if check_valid_items() &&
        check_duplicate_items() &&
        check_valid_locals() &&
        check_duplicate_params() &&
        check_duplicate_local_with_param() &&
        check_duplicate_locals() &&
        check_duplicate_nested_locals() &&
        check_valid_members() &&
        check_duplicate_struct_fields() &&
        check_duplicate_enum_cases() &&
        check_duplicate_field_inits() &&
        check_valid_resolution() &&
        check_unresolved_identifier() &&
        check_valid_types() &&
        check_unknown_named_type() &&
        check_literal_requires_struct() &&
        check_literal_unknown_field() &&
        check_valid_calls() &&
        check_call_arity() &&
        check_call_const() &&
        check_call_type() &&
        check_valid_typing() &&
        check_return_type_mismatch() &&
        check_local_type_mismatch() &&
        check_call_arg_type_mismatch() &&
        check_condition_type_mismatch() {
        puts(c"selfhost sema items ok");
        return 0;
    }
    puts(c"selfhost sema items failed");
    return 1;
}
