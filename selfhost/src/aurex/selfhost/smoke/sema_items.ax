extern c {
    fn puts(s: *const u8) -> i32 @name("puts");
}

fn check_valid_items() -> bool {
    let source: *const u8 = c"module sema.valid; extern c { fn puts(s: *const u8) -> i32 @name(\"puts\"); } opaque struct Native; enum Tag: u8 { zero = 0, } struct Pair { value: i32; tag: Tag; } const ANSWER: i32 = 42; fn helper(pair: Pair) -> i32 { return pair.value + ANSWER; } fn main() -> i32 { return helper(Pair { value: 1, tag: Tag_zero }); }";
    var ast: AstModule = parse_seed_ast(source);
    if !ast.ok {
        ast_free_module(ast);
        return false;
    }
    var table: SemaItemTable = sema_make_item_table();
    if !table.ok {
        sema_free_item_table(table);
        ast_free_module(ast);
        return false;
    }
    let ok: bool = sema_collect_module_items(source, &ast, &table) &&
        table.symbol_count == 7 &&
        table.type_count == 3 &&
        table.value_count == 1 &&
        table.function_count == 3 &&
        table.duplicate_count == 0;
    sema_free_item_table(table);
    ast_free_module(ast);
    return ok;
}

fn check_duplicate_items() -> bool {
    let source: *const u8 = c"module sema.dupe; extern c { fn puts(s: *const u8) -> i32 @name(\"puts\"); } struct Pair { value: i32; } const Pair: i32 = 1; fn main() -> i32 { return 0; }";
    var ast: AstModule = parse_seed_ast(source);
    if !ast.ok {
        ast_free_module(ast);
        return false;
    }
    var table: SemaItemTable = sema_make_item_table();
    if !table.ok {
        sema_free_item_table(table);
        ast_free_module(ast);
        return false;
    }
    let collected: bool = sema_collect_module_items(source, &ast, &table);
    let ok: bool = !collected &&
        !table.ok &&
        table.duplicate_count == 1 &&
        table.symbol_count == 2;
    sema_free_item_table(table);
    ast_free_module(ast);
    return ok;
}

fn check_valid_locals() -> bool {
    let source: *const u8 = c"module sema.locals.valid; fn helper(value: i32, limit: i32) -> i32 { let total: i32 = value; { let inner: i32 = limit; } if total < limit { let then_step: i32 = 1; } else { let else_step: i32 = 2; } while total < limit { let loop_step: i32 = 1; } return total; } fn main() -> i32 { return helper(1, 2); }";
    var ast: AstModule = parse_seed_ast(source);
    if !ast.ok {
        ast_free_module(ast);
        return false;
    }
    let ok: bool = sema_check_module_locals(source, &ast);
    ast_free_module(ast);
    return ok;
}

