module trait_default_method_override;

trait Reader {
    fn read(self: &Self) -> i32;

    fn is_empty(self: &Self) -> bool {
        return false;
    }
}

struct File {
    value: i32;
}

impl Reader for File {
    fn read(self: &File) -> i32 {
        return self.value;
    }

    fn is_empty(self: &File) -> bool {
        return self.value == 0;
    }
}

fn main() -> i32 {
    return 0;
}
