module samplelib.visibility;

pub const answer: i32 = 41;
priv const hidden_answer: i32 = 99;

pub type PublicInt = i32;
priv type HiddenInt = i32;

pub struct PublicBox {
    pub value: i32;
    priv secret: i32;
}

priv struct HiddenBox {
    pub value: i32;
}

pub enum PublicChoice: u8 {
    yes = 1,
    no = 2,
}

priv enum HiddenChoice: u8 {
    yes = 1,
}

pub fn exported(value: i32) -> i32 {
    return add_secret(value);
}

pub fn make_box(value: i32) -> PublicBox {
    return PublicBox {
        value: value,
        secret: hidden_answer,
    };
}

pub fn keep[T](value: T) -> T {
    return value;
}

impl PublicBox {
    pub fn new(value: i32) -> PublicBox {
        return PublicBox {
            value: value,
            secret: hidden_answer,
        };
    }

    pub fn read(self: *const PublicBox) -> i32 {
        return self.value;
    }

    pub fn bump(self: *mut PublicBox, delta: i32) -> i32 {
        self.value = self.value + delta;
        return self.value;
    }

    priv fn secret_value(self: *const PublicBox) -> i32 {
        return self.secret;
    }
}

priv fn add_secret(value: i32) -> i32 {
    return value + answer;
}
