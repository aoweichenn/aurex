module for_loop;

fn push_digit(log: *mut i32, value: i32) -> void {
    *log = *log * 10 + value;
}

fn for_defer_continue() -> i32 {
    var log: i32 = 0;
    for var i: i32 = 0; i < 3; i = i + 1 {
        defer push_digit(&log, 1);
        if i == 0 {
            continue;
        }
        if i == 1 {
            break;
        }
    }
    return log;
}

fn main() -> i32 {
    var sum: i32 = 0;

    for var i: i32 = 0; i < 5; i = i + 1 {
        if i == 3 {
            continue;
        }
        sum = sum + i;
    }

    var j: i32 = 0;
    for ; ; j = j + 1 {
        if j == 2 {
            break;
        }
        sum = sum + 10;
    }

    var range_sum: i32 = 0;
    for i in range(4) {
        range_sum += i;
    }
    for k in range(2, 5) {
        range_sum += k;
    }

    if sum == 27 && range_sum == 15 && for_defer_continue() == 11 {
        return 0;
    }
    return sum;
}
