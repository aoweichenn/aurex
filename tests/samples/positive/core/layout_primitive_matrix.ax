module layout_primitive_matrix;

fn main() -> i32 {
    if sizeof<i8>() != ((1) as usize) || alignof<i8>() != ((1) as usize) {
        return 1;
    }
    if sizeof<i16>() != ((2) as usize) || alignof<i16>() != ((2) as usize) {
        return 2;
    }
    if sizeof<i64>() != ((8) as usize) || alignof<i64>() != ((8) as usize) {
        return 3;
    }
    if sizeof<isize>() != sizeof<usize>() || alignof<isize>() != alignof<usize>() {
        return 4;
    }
    if sizeof<f32>() != ((4) as usize) || alignof<f32>() != ((4) as usize) {
        return 5;
    }
    if sizeof<f64>() != ((8) as usize) || alignof<f64>() != ((8) as usize) {
        return 6;
    }
    if sizeof<str>() != ((16) as usize) || alignof<str>() != ((8) as usize) {
        return 7;
    }
    return 0;
}
