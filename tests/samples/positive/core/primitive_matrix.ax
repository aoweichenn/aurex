module primitive_matrix;

extern c {
    @name("observe_scalars")
    fn observe_scalars(
        a: i8,
        b: i16,
        scalar_c: isize,
        d: f32,
        e: f64,
        s: str
    ) -> void;
}

struct Small {
    value: u16;
}

enum Code: u16 {
    hex = 0x2A,
    bin = 0b1010,
    dec = 1_000,
}

enum Packet: u8 {
    small(Small) = 1,
    none = 2,
}

fn score(packet: Packet) -> i32 {
    return match packet {
        .small(value) => ((value.value) as i32),
        .none => 0,
    };
}

fn main() -> i32 {
    let text: str = "hi";
    let a: i8 = ((1) as i8);
    let b: i16 = ((2) as i16);
    let scalar_c: isize = ((3) as isize);
    let d: f32 = ((4) as f32);
    let e: f64 = ((5) as f64);
    let p: *const u8 = null;
    let f32_bits: f32 = unsafe { bitcast<f32>(((0) as u32)) };
    let f64_bits: f64 = unsafe { bitcast<f64>(((0) as u64)) };
    let pointer_bits: usize = ptraddr(p);
    let small = Small { value: ((42) as u16) };
    if sizeof<str>() == ((0) as usize) || alignof<Packet>() == ((0) as usize) {
        return 3;
    }
    if score(Packet.small(small)) != 42 {
        return 1;
    }
    if score(Packet.none) != 0 {
        return 2;
    }
    return ((a) as i32) + ((b) as i32) + ((scalar_c) as i32) - 6;
}
