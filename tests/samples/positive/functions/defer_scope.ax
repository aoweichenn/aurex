module defer_scope;

extern c {
    @name("calloc")
    fn calloc(count: usize, size: usize) -> *mut void;
    @name("free")
    fn free(ptr: *mut void) -> void;
    @name("strcmp")
    fn strcmp(left: *const u8, right: *const u8) -> i32;
}

fn alloc_zeroed_bytes(count: usize, size: usize) -> *mut u8 {
    return unsafe { ptrcast<*mut u8>(calloc(count, size)) };
}

fn free_bytes(ptr: *mut u8) -> void {
    free(unsafe { ptrcast<*mut void>(ptr) });
}

fn c_string_equal(left: *const u8, right: *const u8) -> bool {
    return strcmp(left, right) == 0;
}

fn index_ptr(index: &mut usize) -> *mut usize {
    return unsafe { ptrat<*mut usize>(ptraddr(index)) };
}

fn push(log: *mut u8, index: *mut usize, value: u8) -> void {
    unsafe {
        log[*index] = value;
        *index = *index + cast<usize>(1);
    }
}

fn normal_scope(log: *mut u8, index: *mut usize) -> void {
    defer push(log, index, b'A');
    {
        defer push(log, index, b'B');
        push(log, index, b'C');
    }
    push(log, index, b'D');
}

fn early_return(log: *mut u8, index: *mut usize) -> i32 {
    defer push(log, index, b'E');
    {
        defer push(log, index, b'F');
        return 7;
    }
}

fn loop_paths(log: *mut u8, index: *mut usize) -> void {
    var i: i32 = 0;
    while i < 3 {
        defer push(log, index, b'L');
        if i == 0 {
            i = i + 1;
            continue;
        }
        if i == 1 {
            i = i + 1;
            break;
        }
        i = i + 1;
    }
    push(log, index, b'Z');
}

fn for_paths(log: *mut u8, index: *mut usize) -> void {
    for var i: i32 = 0; i < 3; i = i + 1 {
        defer push(log, index, b'Q');
        if i == 0 {
            continue;
        }
        if i == 1 {
            break;
        }
    }
    push(log, index, b'R');
}

fn main() -> i32 {
    let log: *mut u8 = alloc_zeroed_bytes(cast<usize>(32), cast<usize>(1));
    if log == null {
        return 1;
    }
    defer free_bytes(log);

    var index: usize = 0;
    let index_ref: *mut usize = index_ptr(&mut index);
    normal_scope(log, index_ref);
    if early_return(log, index_ref) != 7 {
        return 2;
    }
    loop_paths(log, index_ref);
    for_paths(log, index_ref);

    if !c_string_equal(unsafe { ptrcast<*const u8>(log) }, c"CBDAFELLZQQR") {
        return 3;
    }
    return 0;
}
