module variadic_extern_c;

extern c {
    @name("calloc")
    fn calloc(count: usize, size: usize) -> *mut void;
    @name("free")
    fn free(ptr: *mut void) -> void;
    @name("strlen")
    fn c_strlen_abi(text: *const u8) -> usize;
    @name("strcmp")
    fn strcmp(left: *const u8, right: *const u8) -> i32;
    @name("snprintf")
    fn snprintf(buffer: *mut u8, size: usize, format: *const u8, ...) -> i32;
}

fn alloc_zeroed_bytes(count: usize, size: usize) -> *mut u8 {
    return unsafe { ptrcast<*mut u8>(calloc(count, size)) };
}

fn free_bytes(ptr: *mut u8) -> void {
    free(unsafe { ptrcast<*mut void>(ptr) });
}

fn c_strlen(text: *const u8) -> usize {
    return c_strlen_abi(text);
}

fn c_string_equal(left: *const u8, right: *const u8) -> bool {
    return strcmp(left, right) == 0;
}

fn main() -> i32 {
    let buffer: *mut u8 = alloc_zeroed_bytes(((96) as usize), ((1) as usize));
    if buffer == null {
        return 1;
    }
    let code: u8 = b'A';
    let narrow: i16 = ((7) as i16);
    let enabled: bool = true;
    let scale: f32 = ((2) as f32);
    let expected: *const u8 = c"value=7:ok small=65 narrow=7 flag=1 float=2.0";
    let written: i32 = snprintf(
        buffer,
        ((96) as usize),
        c"value=%d:%s small=%d narrow=%d flag=%d float=%.1f",
        7,
        c"ok",
        code,
        narrow,
        enabled,
        scale
    );
    if written != ((c_strlen(expected)) as i32) {
        free_bytes(buffer);
        return 2;
    }
    if !c_string_equal(unsafe { ptrcast<*const u8>(buffer) }, expected) {
        free_bytes(buffer);
        return 3;
    }
    free_bytes(buffer);
    return 0;
}
