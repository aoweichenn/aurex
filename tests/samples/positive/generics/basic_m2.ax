module basic_m2;

struct Box[T] {
    value: T;
}

struct Pair[A, B] {
    first: A;
    second: B;
}

fn id[T](x: T) -> T {
    return x;
}

fn first[A, B](p: Pair[A, B]) -> A {
    return p.first;
}

fn make_box[T](value: T) -> Box[T] {
    return Box[T] { value: value };
}

fn unwrap[T](box: Box[T]) -> T {
    return box.value;
}

fn same_ptr[T](value: *const T) -> *const T {
    return value;
}

fn make_pair[A, B](a: A, b: B) -> Pair[A, B] {
    return Pair[A, B] {
        first: a,
        second: b,
    };
}

fn main() -> i32 {
    let a: Box[i32] = Box[i32] { value: 1 };
    let p: Pair[i32, bool] = Pair[i32, bool] {
        first: id(41),
        second: id::[bool](true),
    };
    let nested: Box[Pair[i32, bool]] = make_box(p);
    let q = make_pair(1, false);
    let unwrapped = unwrap(Box[i32] { value: 2 });
    let value_ptr = same_ptr(&a.value);
    if first(p) == 41 && q.first == 1 && a.value == 1 && nested.value.second && unwrapped == 2 && *value_ptr == 1 {
        return id::[i32](0);
    }
    return 1;
}
