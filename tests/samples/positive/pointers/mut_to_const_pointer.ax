module mut_to_const_pointer;

fn as_mut_ptr(value: &mut i32) -> *mut i32 {
    return unsafe { ptrat<*mut i32>(ptraddr(value)) };
}

fn accept(ptr: *const i32) -> i32 {
    return unsafe { *ptr };
}

fn main() -> i32 {
    var value: i32 = 1;
    let ptr: *mut i32 = as_mut_ptr(&mut value);
    return accept(ptr) - 1;
}
