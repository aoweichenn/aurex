module std_bootstrap;

import std.core.result;
import std.core.text;
import std.core.vec;
import std.fs.file;
import std.io.console;
import std.sys.args;
import std.sys.host;
import std.sys.process;

fn check_args(argc: i32, argv: *mut *mut u8) -> bool {
    let parsed: Args = args(argc, argv);
    return arg_count(parsed) >= 1 && arg(parsed, 0) != null && arg(parsed, -1) == null;
}

fn check_buffer() -> bool {
    var buffer: VecU8 = VecU8.new();
    if !buffer.reserve(cast(usize, 2)) {
        return false;
    }
    if !buffer.push(b'a') || !buffer.push(b'b') || !buffer.push(b'c') {
        buffer.destroy();
        return false;
    }
    let ok: bool = buffer.len() == cast(usize, 3) &&
        bytes_equal(buffer.as_span(), c_span(c"abc"));
    buffer.destroy();
    return ok;
}

fn check_text() -> bool {
    let raw: SpanU8 = span_u8(c"  boot  ", cast(usize, 8));
    let trimmed: SpanU8 = bytes_trim_ascii_space(raw);
    return bytes_equal(trimmed, c_span(c"boot")) &&
        bytes_starts_with(c_span(c"bootstrap"), c_span(c"boot")) &&
        bytes_find_byte(c_span(c"abc"), b'b') == cast(usize, 1) &&
        c_parse_i32(c"42") == 42;
}

fn check_host_file_result() -> Result<bool, i32> {
    let path: *const u8 = c"/tmp/aurex_std_bootstrap_host.txt";
    let written: usize = write_host_text(path, c"host-ok")?;
    if written != c_strlen(c"host-ok") {
        return Result.ok(false);
    }
    var result: HostFileBytes = read_host_bytes(path)?;
    let ok: bool = bytes_equal(result.as_span(), c_span(c"host-ok"));
    result.destroy();
    remove_file(path);
    return Result.ok(ok);
}

fn check_host_file() -> bool {
    return match check_host_file_result() {
        .ok(ok) => ok,
        .err(_) => false,
    };
}

fn check_output_stream_result() -> Result<bool, i32> {
    let path: *const u8 = c"/tmp/aurex_std_bootstrap_stream.txt";
    let file: *mut void = open_output_handle(path);
    if file == null {
        return Result.ok(false);
    }
    if !write_output_text(file, c"value=") || !write_output_i32(file, 7) || !write_output_text(file, c"\n") {
        close_output_handle(file);
        return Result.ok(false);
    }
    if !close_output_handle(file) {
        return Result.ok(false);
    }
    var read_back: FileBytes = read_bytes(path)?;
    let ok: bool = bytes_equal(read_back.as_span(), c_span(c"value=7\n"));
    read_back.destroy();
    remove_file(path);
    return Result.ok(ok);
}

fn check_output_stream() -> bool {
    return match check_output_stream_result() {
        .ok(ok) => ok,
        .err(_) => false,
    };
}

fn main(argc: i32, argv: *mut *mut u8) -> i32 {
    if !check_args(argc, argv) {
        return 1;
    }
    if !check_buffer() {
        return 2;
    }
    if !check_text() {
        return 3;
    }
    if !check_host_file() {
        return 4;
    }
    if !check_output_stream() {
        return 5;
    }
    if env_or(c"AUREX_STD_BOOTSTRAP_TEST_UNSET", c"fallback") == null {
        return 6;
    }
    if !print(c"") || !flush_stdout() {
        return 7;
    }
    return EXIT_SUCCESS;
}
