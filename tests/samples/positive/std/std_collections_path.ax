module std_collections_path;

import std.core.result as result;
import std.core.map as map;
import std.core.string as string;
import std.core.text as text;
import std.core.vec as vec;
import std.fs.path as path;

fn check_vec() -> bool {
    var bytes: vec::Vec<u8> = vec::new<u8>();
    if !vec::push<u8>(&bytes, b'a') || !vec::extend<u8>(&bytes, text::c_span(c"bc")) {
        vec::destroy<u8>(&bytes);
        return false;
    }
    if !vec::set<u8>(&bytes, cast(usize, 1), b'B') {
        vec::destroy<u8>(&bytes);
        return false;
    }
    if !vec::insert<u8>(&bytes, cast(usize, 1), b'b') {
        vec::destroy<u8>(&bytes);
        return false;
    }
    let removed: u8 = match vec::remove<u8>(&bytes, cast(usize, 2)) {
        .some(value) => value,
        .none => b'?',
    };
    let swapped: u8 = match vec::swap_remove<u8>(&bytes, cast(usize, 1)) {
        .some(value) => value,
        .none => b'?',
    };
    let first: u8 = match vec::first<u8>(&bytes) {
        .some(value) => value,
        .none => b'?',
    };
    let middle: u8 = match vec::get<u8>(&bytes, cast(usize, 1)) {
        .some(value) => value,
        .none => b'?',
    };
    let last_before_pop: u8 = match vec::last<u8>(&bytes) {
        .some(value) => value,
        .none => b'?',
    };
    let missing_ok: bool = match vec::get<u8>(&bytes, cast(usize, 99)) {
        .some(value) => false,
        .none => true,
    };
    let popped: result::Option<u8> = vec::pop<u8>(&bytes);
    let last: u8 = match popped {
        .some(value) => value,
        .none => b'?',
    };
    if !vec::push<u8>(&bytes, b'd') || !vec::push<u8>(&bytes, b'e') {
        vec::destroy<u8>(&bytes);
        return false;
    }
    vec::truncate<u8>(&bytes, cast(usize, 1));
    let ok: bool = first == b'a' &&
        middle == b'c' &&
        removed == b'B' &&
        swapped == b'b' &&
        last_before_pop == b'c' &&
        last == b'c' &&
        missing_ok &&
        vec::len<u8>(&bytes) == cast(usize, 1) &&
        vec::capacity<u8>(&bytes) >= vec::len<u8>(&bytes) &&
        text::bytes_equal(vec::as_span<u8>(&bytes), text::c_span(c"a"));
    vec::destroy<u8>(&bytes);
    return ok;
}

fn check_vec_methods() -> bool {
    var bytes: vec::VecU8 = vec::new<u8>();
    if !bytes.push(b'x') ||
        !bytes.push(b'y') ||
        !bytes.insert(cast(usize, 1), b'w') ||
        !bytes.set(cast(usize, 1), b'z') {
        bytes.destroy();
        return false;
    }
    let first: u8 = match bytes.first() {
        .some(value) => value,
        .none => b'?',
    };
    let second: u8 = match bytes.get(cast(usize, 1)) {
        .some(value) => value,
        .none => b'?',
    };
    let last: u8 = match bytes.last() {
        .some(value) => value,
        .none => b'?',
    };
    let removed: u8 = match bytes.remove(cast(usize, 1)) {
        .some(value) => value,
        .none => b'?',
    };
    let swapped: u8 = match bytes.swap_remove(cast(usize, 0)) {
        .some(value) => value,
        .none => b'?',
    };
    let remaining: u8 = match bytes.last() {
        .some(value) => value,
        .none => b'?',
    };
    bytes.truncate(cast(usize, 0));
    let ok: bool = first == b'x' &&
        second == b'z' &&
        last == b'y' &&
        removed == b'z' &&
        swapped == b'x' &&
        remaining == b'y' &&
        bytes.is_empty() &&
        bytes.capacity() >= bytes.len();
    bytes.destroy();
    return ok;
}

fn check_vec_generic_methods() -> bool {
    var nums: vec::Vec<i32> = vec::new<i32>();
    if !nums.push(10) || !nums.push(20) || !nums.insert(cast(usize, 1), 15) {
        nums.destroy();
        return false;
    }
    if !nums.set(cast(usize, 2), 25) {
        nums.destroy();
        return false;
    }
    let first: i32 = match nums.first() {
        .some(value) => value,
        .none => -1,
    };
    let middle: i32 = match nums.get(cast(usize, 1)) {
        .some(value) => value,
        .none => -1,
    };
    let removed: i32 = match nums.remove(cast(usize, 2)) {
        .some(value) => value,
        .none => -1,
    };
    let last: i32 = match nums.last() {
        .some(value) => value,
        .none => -1,
    };
    nums.truncate(cast(usize, 1));
    let ok: bool = first == 10 &&
        middle == 15 &&
        removed == 25 &&
        last == 15 &&
        nums.len() == cast(usize, 1) &&
        nums.capacity() >= nums.len();
    nums.destroy();
    return ok;
}

fn check_result_option_methods() -> bool {
    let some: result::Option<i32> = Option.some(7);
    let none: result::Option<i32> = Option.none;
    let ok_from_some: result::Result<i32, u8> = some.ok_or<u8>(cast(u8, 1));
    let err_from_none: result::Result<i32, u8> = none.ok_or<u8>(cast(u8, 2));
    let ok_value: i32 = ok_from_some.unwrap_or(0);
    let err_value: i32 = err_from_none.unwrap_or(9);
    let direct_ok: result::Result<i32, u8> = Result.ok(12);
    let direct_err: result::Result<i32, u8> = Result.err(cast(u8, 4));
    return some.is_some() &&
        !some.is_none() &&
        none.is_none() &&
        some.unwrap_or(0) == 7 &&
        none.unwrap_or(5) == 5 &&
        ok_from_some.is_ok() &&
        !ok_from_some.is_err() &&
        err_from_none.is_err() &&
        ok_value == 7 &&
        err_value == 9 &&
        direct_ok.unwrap_or(0) == 12 &&
        direct_err.unwrap_or(6) == 6;
}

fn check_map() -> bool {
    var counts: map::Map<u8, i32> = map::new<u8, i32>();
    if !map::insert<u8, i32>(&counts, b'a', 1) ||
        !map::insert<u8, i32>(&counts, b'b', 2) ||
        !map::insert<u8, i32>(&counts, b'a', 3) {
        map::destroy<u8, i32>(&counts);
        return false;
    }
    let a_value: i32 = map::get<u8, i32>(&counts, b'a').unwrap_or(0);
    let b_value: i32 = map::get<u8, i32>(&counts, b'b').unwrap_or(0);
    let missing_ok: bool = map::get<u8, i32>(&counts, b'z').is_none();
    let removed: i32 = map::remove<u8, i32>(&counts, b'a').unwrap_or(0);
    let ok: bool = a_value == 3 &&
        b_value == 2 &&
        missing_ok &&
        removed == 3 &&
        !map::contains<u8, i32>(&counts, b'a') &&
        map::len<u8, i32>(&counts) == cast(usize, 1);
    map::destroy<u8, i32>(&counts);
    return ok;
}

fn check_map_methods() -> result::Result<bool, i32> {
    var scores: map::Map<u8, i32> = map::Map<u8, i32>.with_capacity(2)?;
    if !scores.insert(b'x', 10) ||
        !scores.insert(b'y', 20) ||
        !scores.set(b'y', 25) {
        scores.destroy();
        return Result.ok(false);
    }
    let x_value: i32 = scores.get(b'x').unwrap_or(0);
    let y_value: i32 = scores.get(b'y').unwrap_or(0);
    let missing_ok: bool = scores.find_index(b'z').is_none();
    let removed: i32 = scores.remove(b'x').unwrap_or(0);
    scores.clear();
    let ok: bool = x_value == 10 &&
        y_value == 25 &&
        missing_ok &&
        removed == 10 &&
        !scores.contains(b'x') &&
        scores.is_empty() &&
        scores.capacity() >= cast(usize, 2);
    scores.destroy();
    return Result.ok(ok);
}

fn check_cstring_usize_map() -> bool {
    var targets: map::CStringUsizeMap = map::cstring_usize_new();
    if !map::cstring_usize_insert(&targets, c"core", cast(usize, 0)) ||
        !map::cstring_usize_insert(&targets, c"app", cast(usize, 1)) ||
        !map::cstring_usize_insert(&targets, c"core", cast(usize, 2)) {
        map::cstring_usize_destroy(&targets);
        return false;
    }
    let core_value: usize = map::cstring_usize_get(&targets, c"core").unwrap_or(cast(usize, 99));
    let app_value: usize = map::cstring_usize_get(&targets, c"app").unwrap_or(cast(usize, 99));
    let missing_ok: bool = map::cstring_usize_get(&targets, c"missing").is_none();
    let absent_ok: bool = map::cstring_usize_insert_absent(&targets, c"core", cast(usize, 7));
    let stable_core_value: usize = map::cstring_usize_get(&targets, c"core").unwrap_or(cast(usize, 99));
    let removed: usize = map::cstring_usize_remove(&targets, c"app").unwrap_or(cast(usize, 99));
    let ok: bool =
        core_value == cast(usize, 2) &&
        app_value == cast(usize, 1) &&
        missing_ok &&
        absent_ok &&
        stable_core_value == cast(usize, 2) &&
        removed == cast(usize, 1) &&
        !map::cstring_usize_contains(&targets, c"app") &&
        map::cstring_usize_len(&targets) == cast(usize, 1);
    map::cstring_usize_destroy(&targets);
    return ok;
}

fn check_cstring_usize_map_methods() -> result::Result<bool, i32> {
    var targets: map::CStringUsizeMap = map::CStringUsizeMap.with_capacity(2)?;
    if !targets.insert(c"core", cast(usize, 0)) ||
        !targets.insert(c"app", cast(usize, 1)) ||
        !targets.set(c"app", cast(usize, 3)) ||
        !targets.insert_absent(c"core", cast(usize, 9)) {
        targets.destroy();
        return Result.ok(false);
    }
    let core_value: usize = targets.get(c"core").unwrap_or(cast(usize, 99));
    let app_value: usize = targets.get(c"app").unwrap_or(cast(usize, 99));
    let missing_ok: bool = targets.find_index(c"missing").is_none();
    let removed: usize = targets.remove(c"core").unwrap_or(cast(usize, 99));
    targets.clear();
    let ok: bool =
        core_value == cast(usize, 0) &&
        app_value == cast(usize, 3) &&
        missing_ok &&
        removed == cast(usize, 0) &&
        !targets.contains(c"core") &&
        targets.is_empty() &&
        targets.capacity() >= cast(usize, 2);
    targets.destroy();
    return Result.ok(ok);
}

fn check_string() -> result::Result<bool, i32> {
    var s: string::String = string::from_c(c"ab")?;
    if !string::push(&s, b'c') ||
        !string::append_c(&s, c"d") ||
        !string::insert(&s, cast(usize, 1), b'X') {
        string::destroy(&s);
        return Result.err(2);
    }
    let removed: u8 = match string::remove(&s, cast(usize, 2)) {
        .some(value) => value,
        .none => b'?',
    };
    let popped: u8 = match string::pop(&s) {
        .some(value) => value,
        .none => b'?',
    };
    string::truncate(&s, cast(usize, 2));
    let bytes: text::MutSpanU8 = string::as_mut_span(&s);
    bytes.data[cast(usize, 1)] = b'Y';
    let edited_ok: bool = removed == b'b' &&
        popped == b'd' &&
        string::len(&s) == cast(usize, 2) &&
        string::equals_span(&s, text::c_span(c"aY")) &&
        string::ends_with_byte(&s, b'Y') &&
        text::c_string_equal(string::c_str(&s), c"aY");
    string::clear(&s);
    let ok: bool = edited_ok &&
        string::is_empty(&s) &&
        text::c_string_equal(string::c_str(&s), c"");
    string::destroy(&s);
    return Result.ok(ok);
}

fn check_string_methods() -> result::Result<bool, i32> {
    var s: string::String = string::from_c(c"xy")?;
    if !s.insert(cast(usize, 1), b'z') || !s.push(b'!') {
        s.destroy();
        return Result.err(5);
    }
    let removed: u8 = match s.remove(cast(usize, 2)) {
        .some(value) => value,
        .none => b'?',
    };
    let popped: u8 = match s.pop() {
        .some(value) => value,
        .none => b'?',
    };
    s.truncate(cast(usize, 1));
    let ok_before_clear: bool = removed == b'y' &&
        popped == b'!' &&
        s.len() == cast(usize, 1) &&
        s.equals_span(text::c_span(c"x")) &&
        text::c_string_equal(s.c_str(), c"x");
    s.clear();
    let ok: bool = ok_before_clear &&
        s.is_empty() &&
        text::c_string_equal(s.c_str(), c"");
    s.destroy();
    return Result.ok(ok);
}

fn make_path() -> result::Result<path::Path, i32> {
    var root: path::Path = path::from_c(c"/tmp")?;
    var joined: path::Path = path::join_c(&root, c"aurex/std.txt")?;
    path::destroy(&root);
    return Result.ok(joined);
}

fn check_path() -> result::Result<bool, i32> {
    var p: path::Path = make_path()?;
    let parent: text::SpanU8 = match path::parent(&p) {
        .some(value) => value,
        .none => text::c_span(c""),
    };
    let extension: text::SpanU8 = match path::extension(&p) {
        .some(value) => value,
        .none => text::c_span(c""),
    };
    var joined: path::Path = path::join_span(&p, text::c_span(c"child.ax"))?;
    var absolute: path::Path = p.join_span(text::c_span(c"/var/tmp/out.o"))?;
    var renamed: path::Path = path::with_extension(&p, text::c_span(c"ax"))?;
    var object: path::Path = absolute.with_extension(text::c_span(c"obj"))?;
    let method_parent: text::SpanU8 = match absolute.parent() {
        .some(value) => value,
        .none => text::c_span(c""),
    };
    let method_extension: text::SpanU8 = match absolute.extension() {
        .some(value) => value,
        .none => text::c_span(c""),
    };
    let ok: bool = path::is_absolute(&p) &&
        p.is_absolute() &&
        text::bytes_equal(path::file_name(&p), text::c_span(c"std.txt")) &&
        text::bytes_equal(parent, text::c_span(c"/tmp/aurex")) &&
        text::bytes_equal(extension, text::c_span(c"txt")) &&
        text::bytes_equal(path::file_stem(&p), text::c_span(c"std")) &&
        text::bytes_equal(path::file_name(&joined), text::c_span(c"child.ax")) &&
        text::bytes_equal(absolute.file_name(), text::c_span(c"out.o")) &&
        text::bytes_equal(absolute.file_stem(), text::c_span(c"out")) &&
        text::bytes_equal(method_parent, text::c_span(c"/var/tmp")) &&
        text::bytes_equal(method_extension, text::c_span(c"o")) &&
        text::c_string_starts_with(path::as_c(&p), c"/tmp/aurex") &&
        text::c_string_equal(absolute.as_c(), c"/var/tmp/out.o") &&
        text::c_string_equal(renamed.as_c(), c"/tmp/aurex/std.ax") &&
        text::c_string_equal(object.as_c(), c"/var/tmp/out.obj");
    joined.destroy();
    absolute.destroy();
    renamed.destroy();
    object.destroy();
    path::destroy(&p);
    return Result.ok(ok);
}

fn run() -> result::Result<i32, i32> {
    if !check_vec() {
        return Result.err(1);
    }
    if !check_vec_methods() {
        return Result.err(2);
    }
    if !check_vec_generic_methods() {
        return Result.err(3);
    }
    if !check_result_option_methods() {
        return Result.err(4);
    }
    if !check_map() {
        return Result.err(5);
    }
    let map_methods_ok: bool = check_map_methods()?;
    if !map_methods_ok {
        return Result.err(6);
    }
    if !check_cstring_usize_map() {
        return Result.err(10);
    }
    let cstring_map_methods_ok: bool = check_cstring_usize_map_methods()?;
    if !cstring_map_methods_ok {
        return Result.err(11);
    }
    let string_ok: bool = check_string()?;
    if !string_ok {
        return Result.err(7);
    }
    let string_methods_ok: bool = check_string_methods()?;
    if !string_methods_ok {
        return Result.err(8);
    }
    let path_ok: bool = check_path()?;
    if !path_ok {
        return Result.err(9);
    }
    return Result.ok(0);
}

fn main() -> i32 {
    return match run() {
        .ok(code) => code,
        .err(code) => code,
    };
}
