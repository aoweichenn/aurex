module std_file;

import std.core.result;
import std.core.str as strings;
import std.core.string;
import std.core.text;
import std.fs.file;
import std.fs.path as paths;

fn check_path_apis() -> Result<bool, i32> {
    var file_path: paths::Path = paths::Path.from_str("/tmp/aurex_std_file_path_test.txt")?;
    var renamed_path: paths::Path = paths::Path.from_str("/tmp/aurex_std_file_path_test_renamed.txt")?;
    remove_file_path(&file_path);
    remove_file_path(&renamed_path);

    let raw_bytes: SpanU8 = span_u8(c"path-raw", cast(usize, 8));
    let raw_written: usize = write_bytes_path(&file_path, raw_bytes)?;
    var raw_read: FileBytes = read_bytes_path(&file_path)?;
    let raw_ok: bool = raw_written == raw_bytes.len && bytes_equal(raw_read.as_span(), raw_bytes);
    raw_read.destroy();

    let legacy_written: usize = write_text_path(&file_path, c"legacy-text")?;
    let legacy_ok: bool = legacy_written == c_strlen(c"legacy-text");

    let payload: str = "path\0text";
    let payload_bytes: SpanU8 = strings::as_bytes(payload);
    let written: usize = write_str_path(&file_path, payload)?;
    let meta: FileMetadata = metadata_path(&file_path)?;
    var read_back: FileBytes = read_bytes_path(&file_path)?;
    let bytes_ok: bool = bytes_equal(read_back.as_span(), payload_bytes);
    read_back.destroy();

    var text_back: String = read_text_path(&file_path)?;
    let text_ok: bool = text_back.equals(payload);
    text_back.destroy();

    let renamed_ok: bool = rename_file_path(&file_path, &renamed_path);
    let exists_old: bool = file_exists_path(&file_path);
    let exists_new: bool = file_exists_path(&renamed_path);
    let removed: bool = remove_file_path(&renamed_path);
    remove_file_path(&file_path);

    let null_path_ok: bool = metadata_path(null).is_err() &&
        read_bytes_path(null).is_err() &&
        read_text_path(null).is_err() &&
        write_bytes_path(null, raw_bytes).is_err() &&
        write_text_path(null, c"x").is_err() &&
        write_str_path(null, "x").is_err() &&
        !file_exists_path(null) &&
        !remove_file_path(null) &&
        !rename_file_path(null, &renamed_path) &&
        !rename_file_path(&file_path, null);

    file_path.destroy();
    renamed_path.destroy();
    return Result.ok(raw_ok &&
        legacy_ok &&
        written == payload_bytes.len &&
        meta.exists() &&
        meta.is_file() &&
        meta.size() == payload_bytes.len &&
        bytes_ok &&
        text_ok &&
        renamed_ok &&
        !exists_old &&
        exists_new &&
        removed &&
        null_path_ok);
}

fn run() -> Result<i32, i32> {
    let path: *const u8 = c"/tmp/aurex_std_file_test.txt";
    let bytes: SpanU8 = span_u8(c"stdlib-ok", cast(usize, 9));
    let written: usize = write_bytes(path, bytes)?;
    if written != bytes.len {
        return Result.ok(1);
    }
    var read_result: FileBytes = read_bytes(path)?;
    let read_span: SpanU8 = read_result.as_span();
    if !bytes_equal(bytes, read_span) {
        read_result.destroy();
        return Result.ok(3);
    }
    read_result.destroy();
    remove_file(path);
    let text_path: *const u8 = c"/tmp/aurex_std_file_text_test.txt";
    let text_written: usize = write_text(text_path, c"stdlib-text")?;
    if text_written != c_strlen(c"stdlib-text") {
        remove_file(text_path);
        return Result.ok(4);
    }
    var text: String = read_text(text_path)?;
    let text_ok: bool = text.equals_span(c_span(c"stdlib-text"));
    text.destroy();
    remove_file(text_path);
    if !text_ok {
        return Result.ok(5);
    }
    if !check_path_apis()? {
        return Result.ok(6);
    }
    return Result.ok(0);
}

fn main() -> i32 {
    return match run() {
        .ok(code) => code,
        .err(code) => code,
    };
}
