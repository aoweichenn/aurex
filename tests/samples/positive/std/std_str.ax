module std_str;

import std.core.result as result;
import std.core.str as strings;
import std.core.text as text;
import std.core.vec as vec;

fn check_lengths_and_views() -> bool {
    let ascii: str = "hello";
    let omega: str = "\u{03A9}";
    let bytes: text::SpanU8 = strings::as_bytes(ascii);
    return strings::byte_len(ascii) == cast(usize, 5) &&
        strings::byte_len(omega) == cast(usize, 2) &&
        !strings::is_empty(ascii) &&
        strings::is_empty("") &&
        bytes.len == cast(usize, 5) &&
        bytes.data[cast(usize, 0)] == b'h';
}

fn check_search_and_equality() -> bool {
    return strings::equals("build", "build") &&
        !strings::equals("build", "built") &&
        strings::starts_with("aurex", "aur") &&
        !strings::starts_with("aurex", "rex") &&
        strings::ends_with("aurex", "rex") &&
        !strings::ends_with("aurex", "aur");
}

fn check_boundaries_and_slices() -> bool {
    let ascii: str = "abcdef";
    let middle: str = strings::slice_bytes_checked(ascii, cast(usize, 1), cast(usize, 4)).unwrap_or("bad");
    let omega: str = "\u{03A9}";
    return strings::equals(middle, "bcd") &&
        strings::is_boundary(omega, cast(usize, 0)) &&
        !strings::is_boundary(omega, cast(usize, 1)) &&
        strings::is_boundary(omega, cast(usize, 2)) &&
        strings::slice_bytes_checked(omega, cast(usize, 0), cast(usize, 1)).is_err() &&
        strings::slice_bytes_checked(ascii, cast(usize, 4), cast(usize, 1)).is_err();
}

fn check_scalars() -> bool {
    let text: str = "a\u{03A9}\u{1F600}";
    let first: u32 = strings::scalar_at(text, cast(usize, 0)).unwrap_or(cast(u32, 0));
    let second: u32 = strings::scalar_at(text, cast(usize, 1)).unwrap_or(cast(u32, 0));
    let third: u32 = strings::scalar_at(text, cast(usize, 3)).unwrap_or(cast(u32, 0));
    let after_first: usize = strings::next_boundary(text, cast(usize, 0)).unwrap_or(cast(usize, 99));
    let after_second: usize = strings::next_boundary(text, cast(usize, 1)).unwrap_or(cast(usize, 99));
    let before_third: usize = strings::previous_boundary(text, cast(usize, 3)).unwrap_or(cast(usize, 99));
    return strings::byte_len(text) == cast(usize, 7) &&
        strings::scalar_count(text) == cast(usize, 3) &&
        strings::is_scalar_value(0x1F600) &&
        !strings::is_scalar_value(0xD800) &&
        strings::scalar_utf8_width(0x1F600).unwrap_or(cast(usize, 0)) == cast(usize, 4) &&
        strings::scalar_utf8_width(0xD800).is_err() &&
        strings::scalar_width_at(text, cast(usize, 0)).unwrap_or(cast(usize, 0)) == cast(usize, 1) &&
        strings::scalar_width_at(text, cast(usize, 1)).unwrap_or(cast(usize, 0)) == cast(usize, 2) &&
        strings::scalar_width_at(text, cast(usize, 3)).unwrap_or(cast(usize, 0)) == cast(usize, 4) &&
        strings::scalar_width_at(text, cast(usize, 2)).is_err() &&
        first == cast(u32, b'a') &&
        second == 0x03A9 &&
        third == 0x1F600 &&
        after_first == cast(usize, 1) &&
        after_second == cast(usize, 3) &&
        before_third == cast(usize, 1);
}

fn check_from_utf8() -> bool {
    let ok: str = strings::from_utf8(text::span_u8(c"ok", cast(usize, 2))).unwrap_or("bad");
    var invalid: vec::VecU8 = vec::new<u8>();
    if !vec::push<u8>(&invalid, cast(u8, 0xC3)) || !vec::push<u8>(&invalid, b'(') {
        invalid.destroy();
        return false;
    }
    let invalid_rejected: bool = strings::from_utf8(vec::as_span<u8>(&invalid)).is_err();
    invalid.destroy();
    return strings::equals(ok, "ok") && invalid_rejected;
}

fn main() -> i32 {
    if !check_lengths_and_views() {
        return 1;
    }
    if !check_search_and_equality() {
        return 2;
    }
    if !check_boundaries_and_slices() {
        return 3;
    }
    if !check_scalars() {
        return 4;
    }
    if !check_from_utf8() {
        return 5;
    }
    return 0;
}
