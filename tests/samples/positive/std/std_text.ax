module std_text;

import std.core.text as text;

fn main() -> i32 {
    let hello: *const u8 = c"hello";
    let same: text::SpanU8 = text::span_u8(hello, cast(usize, 5));
    let again: text::SpanU8 = text::span_u8(c"hello", cast(usize, 5));
    let different: text::SpanU8 = text::span_u8(c"world", cast(usize, 5));
    if !text::bytes_equal(same, again) {
        return 1;
    }
    if text::bytes_equal(same, different) {
        return 2;
    }
    if text::c_strlen(hello) != cast(usize, 5) {
        return 3;
    }
    if !text::is_ascii_digit(b'7') || !text::is_ascii_alpha(b'A') || !text::is_ascii_space(b'\n') {
        return 4;
    }
    var number: i32 = 41;
    let one: text::Span<i32> = text::span<i32>(ptr_cast(*const i32, &number), cast(usize, 1));
    if one.len != cast(usize, 1) || one.data[0] != 41 {
        return 5;
    }
    let writable: text::MutSpan<i32> = text::mut_span<i32>(&number, cast(usize, 1));
    writable.data[0] = 42;
    if number != 42 {
        return 6;
    }
    return 0;
}
