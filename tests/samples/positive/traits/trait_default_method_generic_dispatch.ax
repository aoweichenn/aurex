module trait_default_method_generic_dispatch;

trait Reader {
    fn read(self: &Self) -> i32;

    fn is_empty(self: &Self) -> bool {
        return self.read() == 0;
    }
}

struct File {
    value: i32;
}

impl Reader for File {
    fn read(self: &File) -> i32 {
        return self.value;
    }
}

fn is_zero[T](value: &T) -> bool where T: Reader {
    return value.is_empty();
}

fn main() -> i32 {
    let file = File { value: 0 };
    if is_zero[File](&file) {
        return 0;
    }
    return 1;
}
