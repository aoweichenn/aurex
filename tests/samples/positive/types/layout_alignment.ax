module layout_alignment;

struct Padded {
    tag: u8;
    value: u64;
}

struct PackedBytes {
    data: [3]u8;
}

enum Tag: u16 {
    zero = 0,
    one = 1,
}

enum Payload: u8 {
    small(u8) = 1,
    wide(u64) = 2,
    empty = 3,
}

fn main() -> i32 {
    if sizeof<Padded> != cast<usize>(16) {
        return 1;
    }
    if alignof<Padded> != cast<usize>(8) {
        return 2;
    }
    if sizeof<PackedBytes> != cast<usize>(3) {
        return 3;
    }
    if alignof<PackedBytes> != cast<usize>(1) {
        return 4;
    }
    if sizeof<Tag> != cast<usize>(2) {
        return 5;
    }
    if alignof<Tag> != cast<usize>(2) {
        return 6;
    }
    if sizeof<Payload> != cast<usize>(16) {
        return 7;
    }
    if alignof<Payload> != cast<usize>(8) {
        return 8;
    }
    return 0;
}
