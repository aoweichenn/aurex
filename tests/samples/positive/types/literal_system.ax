module literal_system;

const RAW: str = r"C:\tmp\a
next";
const CH: char = 'λ';
const ESCAPED_CH: char = '\u{03BB}';
const BYTES: [4]u8 = b"ab\n\0";
const U: usize = 42usize;
const F: f32 = 1.0f32;

fn main() -> i32 {
    let i: i8 = 1i8;
    let u: u16 = 255u16;
    let f: f64 = .5f64 + 1.;
    let ch: char = '\u{03BB}';
    let bytes: [3]u8 = b"abc";
    if ch != CH {
        return 1;
    }
    if ESCAPED_CH != CH {
        return 2;
    }
    if sizeof<char>() != ((4) as usize) {
        return 3;
    }
    if ((bytes[0]) as i32) != 97 {
        return 4;
    }
    if ((i) as i32) != 1 {
        return 5;
    }
    if ((u) as i32) != 255 {
        return 6;
    }
    if ((F) as i32) != 1 {
        return 7;
    }
    if ((f) as i32) != 1 {
        return 8;
    }
    return 0;
}
