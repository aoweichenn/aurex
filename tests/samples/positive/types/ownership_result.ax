module ownership_result;

enum Option<T>: u8 {
    some(T) = 1,
    none = 2,
}

enum Result<T, E>: u8 {
    ok(T) = 1,
    err(E) = 2,
}

const OPTION_TAG_SOME: u8 = 1;
const OPTION_TAG_NONE: u8 = 2;
const RESULT_TAG_OK: u8 = 1;
const RESULT_TAG_ERR: u8 = 2;

fn option_is_some_ref<T>(value: *const Option<T>) -> bool {
    if value == null {
        return false;
    }
    let tag: *const u8 = ptr_cast(*const u8, value);
    return *tag == OPTION_TAG_SOME;
}

fn option_is_none_ref<T>(value: *const Option<T>) -> bool {
    if value == null {
        return false;
    }
    let tag: *const u8 = ptr_cast(*const u8, value);
    return *tag == OPTION_TAG_NONE;
}

fn result_is_ok_ref<T, E>(value: *const Result<T, E>) -> bool {
    if value == null {
        return false;
    }
    let tag: *const u8 = ptr_cast(*const u8, value);
    return *tag == RESULT_TAG_OK;
}

fn result_is_err_ref<T, E>(value: *const Result<T, E>) -> bool {
    if value == null {
        return false;
    }
    let tag: *const u8 = ptr_cast(*const u8, value);
    return *tag == RESULT_TAG_ERR;
}

impl<T> Option<T> {
    fn is_some_ref(self: *const Option<T>) -> bool {
        return option_is_some_ref<T>(self);
    }

    fn is_none_ref(self: *const Option<T>) -> bool {
        return option_is_none_ref<T>(self);
    }
}

impl<T, E> Result<T, E> {
    fn is_ok_ref(self: *const Result<T, E>) -> bool {
        return result_is_ok_ref<T, E>(self);
    }

    fn is_err_ref(self: *const Result<T, E>) -> bool {
        return result_is_err_ref<T, E>(self);
    }
}

noncopy struct Owner {
    value: i32;
}

fn make_owner(value: i32) -> Owner {
    return Owner { value: value };
}

fn consume(owner: Owner) -> i32 {
    return owner.value;
}

fn wrap(owner: Owner) -> Result<Owner, i32> {
    return Result.ok(move(owner));
}

fn forward_result(value: i32) -> Result<Owner, i32> {
    var wrapped: Result<Owner, i32> = wrap(make_owner(value));
    return move(wrapped);
}

fn unwrap_or_code(input: Result<Owner, i32>) -> i32 {
    return match move(input) {
        .ok(owner) => consume(move(owner)),
        .err(code) => code,
    };
}

fn unwrap_local_try(value: i32) -> Result<i32, i32> {
    var wrapped: Result<Owner, i32> = forward_result(value);
    var owner: Owner = move(wrapped)?;
    let result: i32 = consume(move(owner));
    return Result.ok(result);
}

fn check_result_ref_status() -> bool {
    var ok_result: Result<Owner, i32> = forward_result(13);
    let ok_status: bool = ok_result.is_ok_ref() && !ok_result.is_err_ref();
    let ok_value: i32 = unwrap_or_code(move(ok_result));

    var err_result: Result<Owner, i32> = Result.err(17);
    let err_status: bool = err_result.is_err_ref() && !err_result.is_ok_ref();
    let err_value: i32 = unwrap_or_code(move(err_result));

    return ok_status && ok_value == 13 && err_status && err_value == 17;
}

fn check_option_ref_status() -> bool {
    var some_owner: Option<Owner> = Option.some(make_owner(19));
    let some_status: bool = some_owner.is_some_ref() && !some_owner.is_none_ref();
    let some_value: i32 = match move(some_owner) {
        .some(owner) => consume(move(owner)),
        .none => 0,
    };

    var no_owner: Option<Owner> = Option.none;
    let none_status: bool = no_owner.is_none_ref() && !no_owner.is_some_ref();
    let none_value: i32 = match move(no_owner) {
        .some(owner) => consume(move(owner)),
        .none => 23,
    };

    return some_status && some_value == 19 && none_status && none_value == 23;
}

fn main() -> i32 {
    let direct: i32 = unwrap_or_code(forward_result(11));
    let via_try: i32 = match unwrap_local_try(31) {
        .ok(value) => value,
        .err(code) => code,
    };
    if direct + via_try == 42 && check_result_ref_status() && check_option_ref_status() {
        return 0;
    }
    return direct + via_try;
}
