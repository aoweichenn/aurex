module result_value_flow;

enum OptionOwner: u8 {
    some(Owner) = 1,
    none = 2,
}

enum ResultOwnerI32: u8 {
    ok(Owner) = 1,
    err(i32) = 2,
}

enum ResultI32I32: u8 {
    ok(i32) = 1,
    err(i32) = 2,
}

const OPTION_TAG_SOME: u8 = 1;
const OPTION_TAG_NONE: u8 = 2;
const RESULT_TAG_OK: u8 = 1;
const RESULT_TAG_ERR: u8 = 2;

fn option_owner_is_some_ref(value: *const OptionOwner) -> bool {
    if value == null {
        return false;
    }
    let tag: *const u8 = unsafe { ptrcast[*const u8](value) };
    return unsafe { *tag } == OPTION_TAG_SOME;
}

fn option_owner_is_none_ref(value: *const OptionOwner) -> bool {
    if value == null {
        return false;
    }
    let tag: *const u8 = unsafe { ptrcast[*const u8](value) };
    return unsafe { *tag } == OPTION_TAG_NONE;
}

fn result_owner_i32_is_ok_ref(value: *const ResultOwnerI32) -> bool {
    if value == null {
        return false;
    }
    let tag: *const u8 = unsafe { ptrcast[*const u8](value) };
    return unsafe { *tag } == RESULT_TAG_OK;
}

fn result_owner_i32_is_err_ref(value: *const ResultOwnerI32) -> bool {
    if value == null {
        return false;
    }
    let tag: *const u8 = unsafe { ptrcast[*const u8](value) };
    return unsafe { *tag } == RESULT_TAG_ERR;
}

impl OptionOwner {
    fn is_some_ref(self: *const OptionOwner) -> bool {
        return option_owner_is_some_ref(self);
    }

    fn is_none_ref(self: *const OptionOwner) -> bool {
        return option_owner_is_none_ref(self);
    }
}

impl ResultOwnerI32 {
    fn is_ok_ref(self: *const ResultOwnerI32) -> bool {
        return result_owner_i32_is_ok_ref(self);
    }

    fn is_err_ref(self: *const ResultOwnerI32) -> bool {
        return result_owner_i32_is_err_ref(self);
    }
}

struct Owner {
    value: i32;
}

fn make_owner(value: i32) -> Owner {
    return Owner { value: value };
}

fn consume(owner: Owner) -> i32 {
    return owner.value;
}

fn wrap(owner: Owner) -> ResultOwnerI32 {
    return ResultOwnerI32.ok(owner);
}

fn forward_result(value: i32) -> ResultOwnerI32 {
    var wrapped: ResultOwnerI32 = wrap(make_owner(value));
    return wrapped;
}

fn unwrap_or_code(input: ResultOwnerI32) -> i32 {
    return match input {
        .ok(owner) => consume(owner),
        .err(code) => code,
    };
}

fn unwrap_local_try(value: i32) -> ResultI32I32 {
    var wrapped: ResultOwnerI32 = forward_result(value);
    var owner: Owner = wrapped?;
    let result: i32 = consume(owner);
    return ResultI32I32.ok(result);
}

fn check_result_ref_status() -> bool {
    var ok_result: ResultOwnerI32 = forward_result(13);
    let ok_status: bool = ok_result.is_ok_ref() && !ok_result.is_err_ref();
    let ok_value: i32 = unwrap_or_code(ok_result);

    var err_result: ResultOwnerI32 = ResultOwnerI32.err(17);
    let err_status: bool = err_result.is_err_ref() && !err_result.is_ok_ref();
    let err_value: i32 = unwrap_or_code(err_result);

    return ok_status && ok_value == 13 && err_status && err_value == 17;
}

fn check_option_ref_status() -> bool {
    var some_owner: OptionOwner = OptionOwner.some(make_owner(19));
    let some_status: bool = some_owner.is_some_ref() && !some_owner.is_none_ref();
    let some_value: i32 = match some_owner {
        .some(owner) => consume(owner),
        .none => 0,
    };

    var no_owner: OptionOwner = OptionOwner.none;
    let none_status: bool = no_owner.is_none_ref() && !no_owner.is_some_ref();
    let none_value: i32 = match no_owner {
        .some(owner) => consume(owner),
        .none => 23,
    };

    return some_status && some_value == 19 && none_status && none_value == 23;
}

fn main() -> i32 {
    let direct: i32 = unwrap_or_code(forward_result(11));
    let via_try: i32 = match unwrap_local_try(31) {
        .ok(value) => value,
        .err(code) => code,
    };
    if direct + via_try == 42 && check_result_ref_status() && check_option_ref_status() {
        return 0;
    }
    return direct + via_try;
}
