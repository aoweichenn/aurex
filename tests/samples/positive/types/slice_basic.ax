module slice_basic;

fn first(values: []i32) -> i32 {
    return values[0];
}

fn main() -> i32 {
    let values: [4]i32 = [1, 2, 3, 4];
    let all: []i32 = values[:];
    let prefix: []i32 = values[:3];
    let suffix: []i32 = values[1:];
    let middle: []i32 = all[1:3];
    let tail_from_slice: []i32 = all[2:];
    return first(all) + prefix[2] + suffix[0] + middle[1] + tail_from_slice[0] - 12;
}
