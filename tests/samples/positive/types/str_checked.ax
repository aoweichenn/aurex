module str_checked;

fn main() -> i32 {
    let ascii_bytes: [2]u8 = b"ok";
    let ascii: []u8 = ascii_bytes[:];
    let ascii_text = strfromutf8(ascii);
    if !strvalid(ascii) {
        return 1;
    }
    if strblen(ascii_text) != 2usize {
        return 3;
    }

    let scalar_bytes: [2]u8 = [0xCEu8, 0xBBu8];
    let scalar: []u8 = scalar_bytes[:];
    let scalar_text = strfromutf8(scalar);
    if !strvalid(scalar) {
        return 4;
    }
    if strblen(scalar_text) != 2usize {
        return 6;
    }

    let euro_bytes: [3]u8 = [0xE2u8, 0x82u8, 0xACu8];
    let euro: []u8 = euro_bytes[:];
    let euro_text = strfromutf8(euro);
    if !strvalid(euro) {
        return 7;
    }
    if strblen(euro_text) != 3usize {
        return 9;
    }

    let smile_bytes: [4]u8 = [0xF0u8, 0x9Fu8, 0x98u8, 0x80u8];
    let smile: []u8 = smile_bytes[:];
    let smile_text = strfromutf8(smile);
    if !strvalid(smile) {
        return 10;
    }
    if strblen(smile_text) != 4usize {
        return 12;
    }

    var mutable_bytes: [1]u8 = [0x41u8];
    let mutable: []mut u8 = mutable_bytes[:];
    let mutable_text = strfromutf8(mutable);
    if !strvalid(mutable) {
        return 13;
    }
    if strblen(mutable_text) != 1usize {
        return 15;
    }

    let bad_bytes: [1]u8 = [0x80u8];
    let bad: []u8 = bad_bytes[:];
    let bad_text = strfromutf8(bad);
    if strvalid(bad) {
        return 16;
    }
    if strblen(bad_text) != 0usize {
        return 18;
    }

    let overlong_bytes: [2]u8 = [0xC0u8, 0x80u8];
    let overlong: []u8 = overlong_bytes[:];
    if strvalid(overlong) {
        return 19;
    }
    if strblen(strfromutf8(overlong)) != 0usize {
        return 20;
    }

    let surrogate_bytes: [3]u8 = [0xEDu8, 0xA0u8, 0x80u8];
    let surrogate: []u8 = surrogate_bytes[:];
    if strvalid(surrogate) {
        return 21;
    }
    if strblen(strfromutf8(surrogate)) != 0usize {
        return 22;
    }

    let truncated_bytes: [1]u8 = [0xE2u8];
    let truncated: []u8 = truncated_bytes[:];
    if strvalid(truncated) {
        return 23;
    }
    if strblen(strfromutf8(truncated)) != 0usize {
        return 24;
    }

    return 0;
}
