module tuple_basic;

fn make_pair(value: i32) -> (i32, bool) {
    return (value, value > 0);
}

fn first<T, U>(pair: (T, U)) -> T where T: Copy, U: Copy {
    let (left, _) = pair;
    return left;
}

fn second<T, U>(pair: (T, U)) -> U where T: Copy, U: Copy {
    let (_, right) = pair;
    return right;
}

fn inc(value: i32) -> i32 {
    return value + 1;
}

fn as_const_ptr(value: &i32) -> *const i32 {
    return unsafe { ptrat<*const i32>(ptraddr(value)) };
}

fn main() -> i32 {
    let pair: (i32, bool) = make_pair(4);
    let direct_first: i32 = pair.0;
    let direct_second: bool = pair . 1;
    let (x, ok) = pair;
    let (_, flag) = pair;
    var (mutable_count, mutable_flag) = pair;
    mutable_count = mutable_count + 0;
    var pointer_source: i32 = 9;
    let pointer_value: *const i32 = as_const_ptr(&pointer_source);
    let bytes: [3]u8 = [1u8, 2u8, 3u8];
    let view: []const u8 = bytes[:];
    let triple: (i32, bool, u8) = (4, true, 7u8);
    let (triple_value, triple_ok, triple_byte) = triple;
    let complex: (*const i32, []const u8, fn(i32) -> i32) = (pointer_value, view, inc);
    let array_tuple: ([2]u8, i32) = ([1u8, 2u8], 3);
    let nested: ((i32, bool), (i32,)) = (pair, (x,));
    let (_, _, complex_func) = complex;
    let (array_values, array_count) = array_tuple;
    let ((left_value, left_ok), (single_value,)) = nested;
    let inferred = first(pair);

    if direct_first == 4 && direct_second && x == 4 && ok && flag && mutable_count == 4 && mutable_flag &&
        triple_value == 4 && triple_ok && triple_byte == 7u8 && complex_func(0) == 1 &&
        array_values[0] == 1u8 && array_count == 3 &&
        left_value == 4 && left_ok && single_value == 4 && inferred == 4 && second(pair) {
        return 0;
    }
    return 1;
}
