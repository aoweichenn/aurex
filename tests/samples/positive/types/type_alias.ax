module type_alias;

type Count = i32;
type CountPtr = *mut Count;
type Bytes4 = [4]u8;
type PacketAlias = Packet;

struct Packet {
    len: Count;
}

fn as_count_ptr(value: &mut Count) -> CountPtr {
    return unsafe { ptrat<CountPtr>(ptraddr(value)) };
}

fn read_count(value: CountPtr) -> Count {
    return unsafe { *value };
}

fn main() -> i32 {
    var count: Count = 41;
    let ptr: CountPtr = as_count_ptr(&mut count);
    let packet: PacketAlias = Packet { len: read_count(ptr) + 1 };
    return packet.len - ((sizeof<Bytes4>()) as i32) - 38;
}
