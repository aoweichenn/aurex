module reexport_import;

import samplelib.reexport_facade;

fn main() -> i32 {
    let value: Count = add_two(0);
    let pair: PairI32 = PairI32 {
        left: value,
        right: base,
    };
    let mode = Mode.ready;
    if mode != Mode.ready {
        return 1;
    }
    return pair.left + pair.right - 82;
}
