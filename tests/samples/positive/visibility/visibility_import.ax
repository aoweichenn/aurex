module visibility_import;

import samplelib.visibility;

fn main() -> i32 {
    let value: PublicInt = exported(answer);
    var box = make_box(value);
    let choice = PublicChoice_yes;
    if choice != PublicChoice.yes {
        return 1;
    }
    if box.read() != 82 {
        return 2;
    }
    if box.bump(1) != 83 {
        return 3;
    }
    return box.value - 83;
}
