module visibility_import;

import samplelib.visibility as visibility;

fn main() -> i32 {
    let value: visibility.PublicInt = visibility.exported(visibility.answer);
    var box = visibility.make_box(value);
    let choice = visibility.PublicChoice.yes;
    if choice != visibility.PublicChoice.yes {
        return 1;
    }
    if box.read() != 82 {
        return 2;
    }
    if box.bump(1) != 83 {
        return 3;
    }
    return box.value - 83;
}
